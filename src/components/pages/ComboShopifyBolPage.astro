---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import FaqList from '../template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { type Locale, localizedPath, localizeHref } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.comboShopifyBol;

// Icons are locale-invariant; merge them with the per-locale row copy by index.
const icons = [
    'fa-solid fa-arrows-left-right-to-line',
    'fa-solid fa-barcode',
    'fa-solid fa-arrows-rotate',
    'fa-solid fa-list-check',
    'fa-solid fa-shield-check',
];
const rows = p.rows.map((row, i) => ({ ...row, icon: icons[i] }));

// Times are locale-invariant; merge them with the per-locale step copy by index.
const times = ['08:30', '09:00', '11:00', '15:45'];
const dayInLife = p.dayInLife.map((step, i) => ({ ...step, time: times[i] }));

const faqs = p.faqs;

const pageUrl = `https://shoplinkr.com${localizedPath('integrations.shopifyBol', locale)}`;
const integrationsUrl = `https://shoplinkr.com${localizedPath('integrations', locale)}`;

const jsonLd = [
    {
        '@type': 'WebPage',
        name: p.jsonLdName,
        description: p.description,
        url: pageUrl,
    },
    {
        '@type': 'BreadcrumbList',
        itemListElement: [
            {
                '@type': 'ListItem',
                position: 1,
                name: p.crumbHome,
                item: 'https://shoplinkr.com',
            },
            {
                '@type': 'ListItem',
                position: 2,
                name: p.crumbIntegrations,
                item: integrationsUrl,
            },
            {
                '@type': 'ListItem',
                position: 3,
                name: p.crumbCurrent,
                item: pageUrl,
            },
        ],
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="integrations.shopifyBol"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <nav aria-label="Breadcrumb" class="mb-8">
                <ol class="flex flex-wrap items-center gap-2 text-sm text-gravel">
                    <li>
                        <a href={localizeHref('/', locale)} class="hover:text-charcoal dark:hover:text-paper transition-colors">{p.crumbHome}</a>
                    </li>
                    <li aria-hidden="true">
                        <i class="fa-solid fa-chevron-right text-[9px]"></i>
                    </li>
                    <li>
                        <a href={localizeHref('/integraties', locale)} class="hover:text-charcoal dark:hover:text-paper transition-colors">{p.crumbIntegrations}</a>
                    </li>
                    <li aria-hidden="true">
                        <i class="fa-solid fa-chevron-right text-[9px]"></i>
                    </li>
                    <li class="text-charcoal dark:text-paper font-medium" aria-current="page">
                        {p.crumbCurrent}
                    </li>
                </ol>
            </nav>

            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.register}
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.demo}
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.stockEyebrow}</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                    {p.stockHeading}
                </h2>
                <p class="mt-6 text-lg text-steel dark:text-gravel leading-relaxed">
                    {p.stockIntro}
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark dark:divide-flint border-y border-chalk-dark dark:border-flint">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal dark:text-paper tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel dark:text-gravel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light/60 dark:bg-graphite">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.dayEyebrow}</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                    {p.dayHeading}
                </h2>
                <p class="mt-6 text-lg text-steel dark:text-gravel leading-relaxed">
                    {p.dayIntro}
                </p>
            </div>

            <ol class="grid sm:grid-cols-2 gap-4 md:gap-5">
                {
                    dayInLife.map((step) => (
                        <li class="relative bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7">
                            <div class="flex items-baseline gap-3 mb-3">
                                <span class="text-xs font-mono font-semibold text-sunstone-deep tracking-wider">{step.time}</span>
                                <span class="h-px flex-1 bg-chalk-dark dark:bg-flint"></span>
                            </div>
                            <h3 class="text-base md:text-lg font-semibold text-charcoal dark:text-paper tracking-tight mb-2">
                                {step.title}
                            </h3>
                            <p class="text-sm text-steel dark:text-gravel leading-relaxed">
                                {step.body}
                            </p>
                        </li>
                    ))
                }
            </ol>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="max-w-3xl">
                <p class="eyebrow mb-4">{p.faqEyebrow}</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1] mb-10">
                    {p.faqHeading}
                </h2>

                <FaqList items={faqs} />
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
