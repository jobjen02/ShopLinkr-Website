---
import PageLayout from '../../layouts/PageLayout.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { type Locale, localizeHref } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.customerStories;

const story = {
    company: 'Schoongedaan.nl',
    logo: '/testimonials/Schoongedaan.png',
    intro: p.storyIntro,
    challenge: p.storyChallenge,
    solution: p.storySolution,
    metric: p.storyMetric,
};

// Quote text is locale-varying and already lives in t.testimonials.quotes (same
// order); author/company/logo are locale-invariant so they stay here.
const voices = [
    {
        quote: t.testimonials.quotes[0],
        author: 'Jasper de Waard',
        company: 'Schoongedaan',
        logo: '/testimonials/Schoongedaan.png',
    },
    {
        quote: t.testimonials.quotes[1],
        author: 'Tijn Zuijdervliet',
        company: 'Cryptoken',
        logo: '/testimonials/Cryptoken.svg',
    },
    {
        quote: t.testimonials.quotes[2],
        author: 'Nabodhi van der Lind',
        company: 'Cozy Design',
        logo: '/testimonials/CozyDesign.jpg',
    },
    {
        quote: t.testimonials.quotes[3],
        author: 'Nick Siep',
        company: 'Voordelig Inslaan',
        logo: '/testimonials/VoordeligInslaan.jpg',
    },
];

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbLabel, localizeHref('/referenties', locale)],
    ]),
    {
        '@type': 'Article',
        headline: `${p.articleHeadlinePrefix} ${story.company}`,
        description: story.metric,
        about: {
            '@type': 'Organization',
            name: story.company,
            url: 'https://schoongedaan.nl',
        },
        author: {
            '@type': 'Organization',
            name: 'ShopLinkr',
            url: 'https://shoplinkr.com',
        },
        publisher: {
            '@type': 'Organization',
            name: 'ShopLinkr',
            logo: {
                '@type': 'ImageObject',
                url: 'https://shoplinkr.com/logo/logo-charcoal.svg',
            },
        },
        image: `https://shoplinkr.com${story.logo}`,
    },
];
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="customerStories"
    jsonLd={jsonLd}
>
    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="max-w-2xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.featuredEyebrow}</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                    {p.featuredHeading}
                </h2>
            </div>

            <article class="max-w-4xl bg-paper dark:bg-charcoal rounded-3xl ring-1 ring-chalk-dark dark:ring-flint shadow-[0_3px_10px_rgba(0,0,0,0.05)] overflow-hidden">
                <header class="px-8 md:px-14 pt-10 md:pt-14 pb-8 md:pb-10 text-center border-b border-chalk-dark dark:border-flint">
                    <div class="inline-flex items-center justify-center h-16 w-16 rounded-2xl bg-paper dark:bg-charcoal ring-1 ring-chalk-dark dark:ring-flint mb-6 overflow-hidden">
                        <img
                            src={story.logo}
                            alt={story.company}
                            class="h-full w-full object-contain p-2"
                            loading="lazy"
                        />
                    </div>
                    <h3 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight">
                        {story.company}
                    </h3>
                </header>

                <div class="px-8 md:px-14 pt-8 md:pt-10">
                    <div class="aspect-video w-full overflow-hidden rounded-2xl ring-1 ring-chalk-dark dark:ring-flint bg-charcoal">
                        <iframe
                            class="h-full w-full"
                            src="https://www.youtube-nocookie.com/embed/PZq1V6Unp_U"
                            title={p.videoTitle}
                            loading="lazy"
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            referrerpolicy="strict-origin-when-cross-origin"
                            allowfullscreen
                        ></iframe>
                    </div>
                </div>

                <div class="px-8 md:px-14 py-10 md:py-14 space-y-10">
                    <div>
                        <p class="eyebrow mb-3">{p.aboutLabel}</p>
                        <p class="text-charcoal dark:text-paper leading-relaxed text-[1.0625rem]">
                            {story.intro}
                        </p>
                    </div>

                    <div>
                        <p class="eyebrow mb-3">{p.challengeLabel}</p>
                        <p class="text-steel dark:text-gravel leading-relaxed text-[1.0625rem]">
                            {story.challenge}
                        </p>
                    </div>

                    <div>
                        <p class="eyebrow mb-3">{p.solutionLabel}</p>
                        <p class="text-steel dark:text-gravel leading-relaxed text-[1.0625rem]">
                            {story.solution}
                        </p>
                    </div>

                    <div class="bg-sunstone-mist/50 dark:bg-sunstone/10 ring-1 ring-sunstone-soft/50 dark:ring-sunstone/30 rounded-2xl px-7 py-7 md:px-9 md:py-8">
                        <p class="eyebrow mb-3">{p.resultLabel}</p>
                        <p class="text-charcoal dark:text-paper leading-snug text-lg md:text-xl font-semibold tracking-tight">
                            {story.metric}
                        </p>
                    </div>
                </div>
            </article>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
        <div class="container-prose">
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-16">
                <div class="max-w-2xl">
                    <p class="eyebrow mb-4">{p.voicesEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.voicesHeading}
                    </h2>
                </div>

                <div class="flex items-center gap-3 text-sm">
                    <span class="inline-flex items-center gap-0.5 text-sunstone-deep">
                        {Array.from({ length: 5 }).map(() => (
                            <i class="fa-solid fa-star text-[0.95rem]" aria-hidden="true"></i>
                        ))}
                    </span>
                    <span class="font-semibold text-charcoal dark:text-paper">{p.rating}</span>
                    <span class="text-gravel">{p.ratingSuffix}</span>
                </div>
            </div>

            <div class="grid md:grid-cols-2 gap-5 md:gap-6">
                {
                    voices.map((voice) => (
                        <article class="bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint hover:ring-chalk-darker dark:hover:ring-steel transition-colors p-8 md:p-10 flex flex-col">
                            <p class="text-charcoal dark:text-paper leading-relaxed text-[1.0625rem] mb-8 flex-1">
                                {voice.quote}
                            </p>

                            <div class="flex items-center gap-4">
                                <div class="h-10 w-10 rounded-lg bg-paper dark:bg-charcoal ring-1 ring-chalk-dark dark:ring-flint flex items-center justify-center overflow-hidden flex-shrink-0">
                                    <img
                                        src={voice.logo}
                                        alt={voice.company}
                                        class="h-full w-full object-contain p-1.5"
                                        loading="lazy"
                                    />
                                </div>
                                <div class="min-w-0">
                                    <p class="font-semibold text-charcoal dark:text-paper text-sm">{voice.author}</p>
                                    <p class="text-xs text-gravel mt-0.5">{voice.company}</p>
                                </div>
                            </div>
                        </article>
                    ))
                }
            </div>

            <div class="mt-12 flex justify-center">
                <a
                    href="https://nl.trustpilot.com/review/shoplinkr.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm text-steel dark:text-gravel hover:text-charcoal dark:hover:text-paper transition-colors inline-flex items-center gap-1.5"
                >
                    {p.allReviews}
                    <i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true"></i>
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="max-w-2xl mx-auto text-center">
                <p class="eyebrow mb-4">{p.ctaEyebrow}</p>
                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal dark:text-paper tracking-tight">
                    {p.ctaHeading}
                </h2>
                <div class="mt-7 flex flex-col sm:flex-row gap-3 justify-center">
                    <a
                        href={externalLinks.register}
                        class="btn btn-sunstone text-base"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t.common.register}
                        <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                    </a>
                    <a
                        href={externalLinks.demoBooking}
                        class="btn btn-secondary text-base"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t.common.demo}
                    </a>
                </div>
            </div>
        </div>
    </section>
</PageLayout>
