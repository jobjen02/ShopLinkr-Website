---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import FaqList from '../template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPageFor } from '../../i18n/localeData';
import { localizeHref, type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.featureInventory;

// Sub-feature cards: icons/structure are locale-invariant, copy comes from the
// dict and is merged by index.
const subIcons = [
    'fa-duotone fa-solid fa-chart-line',
    'fa-duotone fa-solid fa-magnifying-glass-chart',
    'fa-duotone fa-solid fa-eye-slash',
    'fa-duotone fa-solid fa-shuffle',
];
const subFeatures = p.subFeatures.map((feature, i) => ({ ...feature, icon: subIcons[i] }));

const stockTypes = p.stockTypes;

const faqs = faqsByPageFor(locale).voorraad;

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbParent, localizeHref('/functionaliteiten', locale)],
        [p.breadcrumbLeaf, localizeHref('/functionaliteiten/voorraad', locale)],
    ]),
    {
        '@type': 'WebPage',
        name: p.webpageName,
        description: p.webpageDescription,
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="features.inventory"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.register}
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.demo}
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper dark:bg-charcoal">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper dark:from-sunstone/5 dark:via-charcoal dark:to-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                    <div>
                        <p class="eyebrow mb-3">{p.syncEyebrow}</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.05]">
                            {p.syncHeading1}
                            <span class="block">{p.syncHeading2}</span>
                        </h2>
                    </div>

                    <div class="bg-paper dark:bg-charcoal rounded-xl ring-1 ring-chalk-dark dark:ring-flint p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-5">
                            <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">{p.syncTimeline}</p>
                            <div class="flex items-center gap-2">
                                <span class="relative flex h-2 w-2">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sunstone-deep opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-sunstone-deep"></span>
                                </span>
                                <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep">live</span>
                            </div>
                        </div>

                        <ol class="space-y-0">
                            <li class="grid grid-cols-[auto_1fr] gap-x-4">
                                <p class="text-[11px] font-mono tabular-nums text-gravel pt-1 text-right">14:32:18</p>
                                <div class="border-l-2 border-chalk-dark dark:border-flint pl-5 pb-5 relative">
                                    <span class="absolute -left-[3px] top-0 h-2 w-1.5 bg-paper dark:bg-charcoal" aria-hidden="true"></span>
                                    <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full bg-chalk-darker dark:bg-flint ring-2 ring-paper dark:ring-charcoal"></span>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#0000A4] text-paper">Bol</span>
                                        <p class="text-sm font-semibold text-charcoal dark:text-paper">{p.syncRow1Action}</p>
                                    </div>
                                    <p class="text-[11px] text-gravel">{p.syncRow1Note}</p>
                                </div>
                            </li>

                            <li class="grid grid-cols-[auto_1fr] gap-x-4">
                                <p class="text-[11px] font-mono tabular-nums text-gravel pt-1 text-right">14:32:24</p>
                                <div class="border-l-2 border-chalk-dark dark:border-flint pl-5 pb-5 relative">
                                    <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full bg-chalk-darker dark:bg-flint ring-2 ring-paper dark:ring-charcoal"></span>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-charcoal dark:bg-graphite text-paper">ShopLinkr</span>
                                        <p class="text-sm font-semibold text-charcoal dark:text-paper">{p.syncRow2Action}</p>
                                    </div>
                                    <p class="text-[11px] text-gravel">{p.syncRow2Note}</p>
                                </div>
                            </li>

                            <li class="grid grid-cols-[auto_1fr] gap-x-4">
                                <p class="text-[11px] font-mono tabular-nums text-sunstone-deep font-semibold pt-1 text-right">14:32:31</p>
                                <div class="pl-5 relative">
                                    <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full bg-sunstone-deep ring-2 ring-paper dark:ring-charcoal"></span>
                                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#5A8A1F] text-paper">Shopify</span>
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#674399] text-paper">WooCommerce</span>
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#E10915] text-paper">Kaufland</span>
                                        <p class="text-sm font-semibold text-charcoal dark:text-paper">{p.syncRow3Action}</p>
                                    </div>
                                    <p class="text-[11px] text-gravel">{p.syncRow3Note}</p>
                                </div>
                            </li>
                        </ol>

                        <div class="mt-5 flex items-center justify-center gap-2 px-3 py-3 rounded-md bg-sunstone-mist/60 dark:bg-sunstone/10 ring-1 ring-sunstone-soft/60 dark:ring-sunstone/30">
                            <i class="fa-solid fa-bolt text-sunstone-deep text-xs" aria-hidden="true"></i>
                            <span class="text-[11px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep">{p.syncTotal}</span>
                            <span class="text-base font-semibold text-sunstone-deep tabular-nums">{p.syncTotalValue}</span>
                        </div>
                    </div>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper dark:bg-graphite rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel dark:text-gravel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">{p.fictionalEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.fictionalHeading1}
                        <span class="block text-sunstone-deep">{p.fictionalHeading2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.fictionalBody}
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel mb-3">
                        {p.fictionalExample}
                    </p>
                    <ul class="space-y-2.5">
                        <li class="grid grid-cols-1 sm:grid-cols-[1fr_auto_1fr] items-center gap-3 px-4 py-3 rounded-xl bg-chalk-light dark:bg-graphite ring-1 ring-chalk-dark dark:ring-flint">
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">{p.fictionalActual}</p>
                                <p class="text-xl font-semibold text-charcoal dark:text-paper tabular-nums">850</p>
                            </div>
                            <i class="fa-solid fa-arrow-right text-gravel text-sm rotate-90 sm:rotate-0" aria-hidden="true"></i>
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">{p.fictionalChannels}</p>
                                <p class="text-xl font-semibold text-charcoal dark:text-paper tabular-nums">400</p>
                            </div>
                        </li>
                        <li class="grid grid-cols-1 sm:grid-cols-[1fr_auto_1fr] items-center gap-3 px-4 py-3 rounded-xl bg-chalk-light dark:bg-graphite ring-1 ring-chalk-dark dark:ring-flint">
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">{p.fictionalActual}</p>
                                <p class="text-xl font-semibold text-charcoal dark:text-paper tabular-nums">350</p>
                            </div>
                            <i class="fa-solid fa-arrow-right text-gravel text-sm rotate-90 sm:rotate-0" aria-hidden="true"></i>
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">{p.fictionalChannels}</p>
                                <p class="text-xl font-semibold text-charcoal dark:text-paper tabular-nums">400</p>
                            </div>
                        </li>
                        <li class="grid grid-cols-1 sm:grid-cols-[1fr_auto_1fr] items-center gap-3 px-4 py-3 rounded-xl bg-sunstone-mist/60 dark:bg-sunstone/10 ring-1 ring-sunstone-soft/60 dark:ring-sunstone/30">
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep mb-1">{p.fictionalActual}</p>
                                <p class="text-xl font-semibold text-sunstone-deep tabular-nums">15</p>
                            </div>
                            <i class="fa-solid fa-arrow-right text-sunstone-deep text-sm rotate-90 sm:rotate-0" aria-hidden="true"></i>
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep mb-1">{p.fictionalChannels}</p>
                                <p class="text-xl font-semibold text-sunstone-deep tabular-nums">15</p>
                            </div>
                        </li>
                    </ul>
                    <p class="text-[11px] text-gravel mt-3 leading-relaxed">
                        {p.fictionalNote}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">{p.stockTypesEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.stockTypesHeading1}
                        <span class="block text-sunstone-deep">{p.stockTypesHeading2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.stockTypesBody}
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark dark:divide-flint border-y border-chalk-dark dark:border-flint">
                        {
                            stockTypes.map((type) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 mt-0.5">
                                        <i class="fa-solid fa-boxes-stacked text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{type.title}</h3>
                                        <p class="mt-2 text-steel dark:text-gravel leading-relaxed text-[0.975rem]">{type.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">{p.faqEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.faqHeading1}
                        <span class="block text-sunstone-deep">{p.faqHeading2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.faqBody}
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal dark:text-paper font-semibold text-sm">
                        {p.faqCta}
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
