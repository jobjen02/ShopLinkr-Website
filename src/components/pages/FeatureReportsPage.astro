---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import FaqList from '../template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';
import { faqsByPageEn } from '../../data/faqs-en';
import { type Locale, localizeHref } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.featureReports;

// Icons are locale-invariant; merge them with the per-locale sub-feature copy by index.
const subFeatureIcons = [
    'fa-duotone fa-solid fa-trophy',
    'fa-duotone fa-solid fa-chart-pie-simple',
    'fa-duotone fa-solid fa-coins',
    'fa-duotone fa-solid fa-box-archive',
];
const subFeatures = p.subFeatures.map((feature, i) => ({ ...feature, icon: subFeatureIcons[i] }));

const workflowSteps = p.workflowSteps;

const faqs = locale === 'en' ? faqsByPageEn.rapporten : faqsByPage.rapporten;

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbParent, localizeHref('/functionaliteiten', locale)],
        [p.breadcrumbLeaf, localizeHref('/functionaliteiten/rapporten', locale)],
    ]),
    {
        '@type': 'WebPage',
        name: p.title,
        description: p.description,
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="features.reports"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.register}
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.demo}
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper dark:bg-charcoal">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper dark:from-sunstone/5 dark:via-charcoal dark:to-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                    <div>
                        <p class="eyebrow mb-3">{p.mockupEyebrow}</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.05]">
                            {p.mockupHeadingLine1}
                            <span class="block">{p.mockupHeadingLine2}</span>
                        </h2>
                    </div>

                    <div class="bg-paper dark:bg-graphite rounded-xl ring-1 ring-chalk-dark dark:ring-flint p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <div class="flex items-center gap-2.5">
                                <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                    <i class="fa-solid fa-trophy text-[0.7rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-sm font-semibold text-charcoal dark:text-paper">{p.mockupReportLabel}</span>
                            </div>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">{p.mockupTopBadge}</span>
                        </div>

                        <div class="grid grid-cols-[1fr_auto_auto_auto] gap-x-4 gap-y-2 text-xs items-center">
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">{p.mockupColProduct}</span>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel text-right">{p.mockupColRevenue}</span>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel text-right">{p.mockupColProfit}</span>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel text-right">{p.mockupColMargin}</span>

                            <div class="col-span-4 h-px bg-chalk-dark dark:bg-flint"></div>

                            <span class="text-charcoal dark:text-paper font-medium truncate">{p.mockupRow1Name}</span>
                            <span class="text-charcoal dark:text-paper tabular-nums text-right">&euro;3.420</span>
                            <span class="text-charcoal dark:text-paper font-semibold tabular-nums text-right">&euro;1.180</span>
                            <span class="inline-flex items-center justify-end gap-1.5">
                                <span class="inline-block h-1.5 w-10 rounded-full bg-chalk-dark dark:bg-flint overflow-hidden">
                                    <span class="block h-full w-[80%] bg-sunstone-deep rounded-full"></span>
                                </span>
                                <span class="text-charcoal dark:text-paper font-semibold tabular-nums">34%</span>
                            </span>

                            <span class="text-charcoal dark:text-paper font-medium truncate">{p.mockupRow2Name}</span>
                            <span class="text-charcoal dark:text-paper tabular-nums text-right">&euro;2.180</span>
                            <span class="text-charcoal dark:text-paper font-semibold tabular-nums text-right">&euro;720</span>
                            <span class="inline-flex items-center justify-end gap-1.5">
                                <span class="inline-block h-1.5 w-10 rounded-full bg-chalk-dark dark:bg-flint overflow-hidden">
                                    <span class="block h-full w-[78%] bg-sunstone-soft rounded-full"></span>
                                </span>
                                <span class="text-charcoal dark:text-paper font-semibold tabular-nums">33%</span>
                            </span>

                            <span class="text-steel dark:text-gravel truncate">{p.mockupRow3Name}</span>
                            <span class="text-steel dark:text-gravel tabular-nums text-right">&euro;1.640</span>
                            <span class="text-steel dark:text-gravel font-semibold tabular-nums text-right">&euro;248</span>
                            <span class="inline-flex items-center justify-end gap-1.5">
                                <span class="inline-block h-1.5 w-10 rounded-full bg-chalk-dark dark:bg-flint overflow-hidden">
                                    <span class="block h-full w-[35%] bg-chalk-darker dark:bg-flint rounded-full"></span>
                                </span>
                                <span class="text-steel dark:text-gravel font-semibold tabular-nums">15%</span>
                            </span>
                        </div>

                        <div class="flex flex-wrap items-center justify-between gap-2 mt-5 pt-4 border-t border-chalk-dark dark:border-flint">
                            <div class="flex items-center gap-2 text-[11px] text-gravel">
                                <i class="fa-solid fa-calendar-days text-[0.65rem]" aria-hidden="true"></i>
                                <span>{p.mockupPeriod}</span>
                            </div>
                            <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-charcoal dark:text-paper px-2.5 py-1 rounded-md bg-chalk-light dark:bg-flint ring-1 ring-chalk-dark dark:ring-flint">
                                <i class="fa-solid fa-file-excel text-[0.65rem]" aria-hidden="true"></i>
                                {p.mockupExport}
                            </span>
                        </div>
                    </div>

                    <ul class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm font-medium text-charcoal dark:text-paper">
                        <li class="flex items-center gap-2">
                            <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                            {p.bullet1}
                        </li>
                        <li class="flex items-center gap-2">
                            <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                            {p.bullet2}
                        </li>
                        <li class="flex items-center gap-2">
                            <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                            {p.bullet3}
                        </li>
                        <li class="flex items-center gap-2">
                            <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                            {p.bullet4}
                        </li>
                    </ul>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel dark:text-gravel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">{p.workflowEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.workflowHeadingLine1}
                        <span class="block text-sunstone-deep">{p.workflowHeadingLine2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.workflowIntro}
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ol class="divide-y divide-chalk-dark dark:divide-flint border-y border-chalk-dark dark:border-flint">
                        {
                            workflowSteps.map((step, index) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 mt-0.5 text-sm font-semibold">
                                        {index + 1}
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{step.title}</h3>
                                        <p class="mt-2 text-steel dark:text-gravel leading-relaxed text-[0.975rem]">{step.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">{p.faqEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.faqHeadingLine1}
                        <span class="block text-sunstone-deep">{p.faqHeadingLine2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.faqIntro}
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal dark:text-paper font-semibold text-sm">
                        {p.faqCta}
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
