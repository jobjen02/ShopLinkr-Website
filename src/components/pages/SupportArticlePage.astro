---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SupportHero from '../support/SupportHero.astro';
import { type Locale, localizedPath, supportCategoriesBase } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

type BreadcrumbItem = { href: string; label: string };
type RelatedArticle = {
    title: string;
    summary: string;
    href: string;
    subcategoryLabel: string | null;
};
type CategoryInfo = { slug: string; label: string };

interface Props {
    article: CollectionEntry<'supportArticles'> | CollectionEntry<'supportArticlesEn'>;
    categoryInfo: CategoryInfo | undefined;
    breadcrumbItems: BreadcrumbItem[];
    relatedArticles: RelatedArticle[];
    lastUpdatedFormatted: string;
    jsonLd: unknown;
    alternates: Record<string, string> | undefined;
}

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.supportArticle;

const {
    article,
    categoryInfo,
    breadcrumbItems,
    relatedArticles,
    lastUpdatedFormatted,
    jsonLd,
    alternates,
} = Astro.props;

const { Content } = await render(article);

const contactHref = localizedPath('contact', locale);
const categoriesBase = supportCategoriesBase(locale);
---

<BaseLayout
    title={`${article.data.title} | ShopLinkr Support`}
    description={article.data.summary}
    jsonLd={jsonLd}
    alternates={alternates}
>
    <SupportHero
        title={article.data.title}
        subtitle={article.data.summary}
        showCtas={false}
    />

    <section class="bg-paper dark:bg-charcoal">
        <div class="container-prose py-12 md:py-16">
            <div class="max-w-3xl">
                <nav aria-label="Breadcrumb" class="mb-10">
                    <ol class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[14px] text-gravel">
                        {breadcrumbItems.map((b) => (
                            <>
                                <li>
                                    <a href={b.href} class="hover:text-charcoal dark:hover:text-paper transition-colors">
                                        {b.label}
                                    </a>
                                </li>
                                <li aria-hidden="true">
                                    <i class="fa-solid fa-chevron-right text-[10px]" aria-hidden="true"></i>
                                </li>
                            </>
                        ))}
                        <li aria-current="page" class="text-charcoal dark:text-paper line-clamp-1 max-w-[28ch] md:max-w-none">
                            {article.data.title}
                        </li>
                    </ol>
                </nav>

                <article class="prose-shoplinkr">
                    <Content />
                </article>

                <p class="mt-12 text-[13px] text-gravel">
                    {p.lastUpdated} <time datetime={article.data.lastUpdated.toISOString().slice(0, 10)}>{lastUpdatedFormatted}</time>
                </p>

                <div class="mt-12 rounded-[18px] bg-chalk-light dark:bg-graphite px-7 md:px-9 py-8 md:py-9 border border-chalk-dark/60 dark:border-flint">
                    <div class="flex items-start gap-4">
                        <div class="flex-none w-10 h-10 rounded-full bg-sunstone-mist dark:bg-sunstone/10 flex items-center justify-center">
                            <i class="fa-solid fa-headset text-sunstone-deep" aria-hidden="true"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h2 class="text-[19px] md:text-[20px] font-semibold text-charcoal dark:text-paper tracking-tight mb-1.5">
                                {p.helpTitle}
                            </h2>
                            <p class="text-[14.5px] text-steel dark:text-gravel leading-relaxed mb-4">
                                {p.helpBody}
                            </p>
                            <div class="flex flex-wrap gap-3">
                                <a
                                    href={contactHref}
                                    class="inline-flex items-center gap-2 min-h-[44px] px-4 py-2 rounded-[10px] bg-paper dark:bg-charcoal border border-chalk-dark dark:border-flint text-[14px] font-semibold text-charcoal dark:text-paper hover:bg-sunstone-mist/60 dark:hover:bg-sunstone/10 hover:border-sunstone-soft hover:text-sunstone-deep transition-colors"
                                >
                                    <i class="fa-solid fa-envelope text-[13px]" aria-hidden="true"></i>
                                    {p.contactCta}
                                </a>
                                {categoryInfo && (
                                    <a
                                        href={`${categoriesBase}/${categoryInfo.slug}`}
                                        class="inline-flex items-center gap-2 min-h-[44px] px-4 py-2 rounded-[10px] text-[14px] font-semibold text-charcoal dark:text-paper hover:text-sunstone-deep transition-colors"
                                    >
                                        {p.backToPrefix} {categoryInfo.label}
                                        <i class="fa-solid fa-arrow-right text-[12px]" aria-hidden="true"></i>
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {relatedArticles.length > 0 && (
                <div class="max-w-3xl mt-16 md:mt-20">
                    <h2 class="text-[22px] md:text-[26px] font-semibold text-charcoal dark:text-paper tracking-tight mb-6">
                        {p.relatedTitle}
                    </h2>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {relatedArticles.map((r) => (
                            <li>
                                <a
                                    href={r.href}
                                    class="group block bg-paper dark:bg-graphite rounded-[14px] border border-chalk-dark/70 dark:border-flint hover:border-chalk-dark dark:hover:border-steel hover:shadow-[0_8px_24px_-12px_rgba(25,25,25,0.10)] transition-all duration-200 px-5 py-4 h-full"
                                >
                                    {r.subcategoryLabel && (
                                        <p class="text-[0.6875rem] text-sunstone-deep font-semibold uppercase tracking-wider mb-1.5">
                                            {r.subcategoryLabel}
                                        </p>
                                    )}
                                    <h3 class="text-[15px] font-semibold text-charcoal dark:text-paper tracking-tight group-hover:text-sunstone-deep transition-colors line-clamp-2">
                                        {r.title}
                                    </h3>
                                    <p class="mt-1 text-[13px] text-steel dark:text-gravel leading-relaxed line-clamp-2">
                                        {r.summary}
                                    </p>
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            )}
        </div>
    </section>
</BaseLayout>

<style is:global>
    .prose-shoplinkr {
        color: var(--color-flint);
        font-size: 1.0625rem;
        line-height: 1.75;
    }

    .prose-shoplinkr > * + * {
        margin-top: 1.25em;
    }

    .prose-shoplinkr h2 {
        color: var(--color-charcoal);
        font-size: 1.625rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.25;
        margin-top: 2em;
        margin-bottom: 0.5em;
    }

    .prose-shoplinkr h3 {
        color: var(--color-charcoal);
        font-size: 1.375rem;
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.35;
        margin-top: 2em;
        margin-bottom: 0.6em;
    }

    .prose-shoplinkr h4 {
        color: var(--color-charcoal);
        font-size: 1.0625rem;
        font-weight: 600;
        margin-top: 1.5em;
        margin-bottom: 0.4em;
    }

    .prose-shoplinkr p {
        margin: 1em 0;
    }

    .prose-shoplinkr a {
        color: var(--color-sunstone-deep);
        text-decoration: none;
        transition: color 0.15s ease;
    }

    .prose-shoplinkr a:hover {
        color: var(--color-sunstone);
        text-decoration: underline;
        text-decoration-color: var(--color-sunstone-soft);
        text-underline-offset: 3px;
    }

    .prose-shoplinkr strong {
        color: var(--color-charcoal);
        font-weight: 600;
    }

    .prose-shoplinkr ul,
    .prose-shoplinkr ol {
        margin: 1.25em 0;
        padding-left: 1.5em;
    }

    .prose-shoplinkr ul > li {
        list-style-type: disc;
        margin: 0.4em 0;
        padding-left: 0.25em;
    }

    .prose-shoplinkr ul > li::marker {
        color: var(--color-sunstone-deep);
    }

    .prose-shoplinkr {
        counter-reset: shoplinkr-step;
    }

    .prose-shoplinkr h2,
    .prose-shoplinkr h3,
    .prose-shoplinkr h4 {
        counter-reset: shoplinkr-step;
    }

    .prose-shoplinkr ol {
        list-style: none;
        padding-left: 2.25em;
    }

    .prose-shoplinkr ol > li {
        position: relative;
        counter-increment: shoplinkr-step;
        margin: 0.4em 0;
        padding-left: 0.25em;
    }

    .prose-shoplinkr ol > li::before {
        content: counter(shoplinkr-step) ".";
        position: absolute;
        left: -1.75em;
        top: 0;
        color: var(--color-gravel);
        font-weight: 600;
        font-variant-numeric: tabular-nums;
        min-width: 1.5em;
    }

    .prose-shoplinkr blockquote {
        border-left: 3px solid var(--color-sunstone);
        margin: 1.75em 0;
        padding: 0.25em 0 0.25em 1.5em;
        color: var(--color-charcoal);
        font-style: italic;
    }

    .prose-shoplinkr code {
        background-color: var(--color-chalk);
        color: var(--color-charcoal);
        padding: 0.15em 0.4em;
        border-radius: 0.375rem;
        font-family: var(--font-mono);
        font-size: 0.9em;
    }

    .prose-shoplinkr pre {
        background-color: var(--color-charcoal);
        color: var(--color-chalk);
        padding: 1.25em;
        border-radius: 0.75rem;
        overflow-x: auto;
        margin: 1.5em 0;
        font-family: var(--font-mono);
        font-size: 0.875rem;
        line-height: 1.6;
    }

    .prose-shoplinkr pre code {
        background-color: transparent;
        color: inherit;
        padding: 0;
    }

    .prose-shoplinkr img {
        margin: 1.75em 0;
        border-radius: 1rem;
        max-width: 100%;
        height: auto;
    }

    .prose-shoplinkr figure {
        margin: 1.75em 0;
    }

    .prose-shoplinkr figure img {
        margin: 0;
    }

    .prose-shoplinkr table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.75em 0;
        font-size: 0.95em;
    }

    .prose-shoplinkr th,
    .prose-shoplinkr td {
        border-bottom: 1px solid var(--color-chalk-dark);
        padding: 0.65em 0.85em;
        text-align: left;
    }

    .prose-shoplinkr th {
        background-color: var(--color-chalk-light);
        color: var(--color-charcoal);
        font-weight: 600;
    }

    .prose-shoplinkr hr {
        border: 0;
        border-top: 1px solid var(--color-chalk-dark);
        margin: 2.5em 0;
    }

    /* Dark mode overrides (markdown body). */
    .dark .prose-shoplinkr {
        color: var(--color-gravel);
    }

    .dark .prose-shoplinkr h2,
    .dark .prose-shoplinkr h3,
    .dark .prose-shoplinkr h4,
    .dark .prose-shoplinkr strong,
    .dark .prose-shoplinkr blockquote {
        color: var(--color-paper);
    }

    .dark .prose-shoplinkr code {
        background-color: var(--color-flint);
        color: var(--color-paper);
    }

    .dark .prose-shoplinkr pre {
        background-color: var(--color-graphite);
        color: var(--color-chalk);
    }

    .dark .prose-shoplinkr th,
    .dark .prose-shoplinkr td {
        border-bottom-color: var(--color-flint);
    }

    .dark .prose-shoplinkr th {
        background-color: var(--color-graphite);
        color: var(--color-paper);
    }

    .dark .prose-shoplinkr hr {
        border-top-color: var(--color-flint);
    }
</style>
