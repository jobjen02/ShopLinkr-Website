---
import PageLayout from '../../layouts/PageLayout.astro';
import PricingCalculator from '../../components/pricing/PricingCalculator.vue';
import CtaBanner from '../sections/CtaBanner.astro';
import FaqList from '../template/FaqList.astro';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';
import { faqsByPageEn } from '../../data/faqs-en';
import { localizeHref, type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.pricing;

const pricingExamples = p.pricingExamples;

// Icons are locale-invariant; merge them with the per-locale card copy by index.
const inclusionIcons = [
    'fa-duotone fa-solid fa-grid-2',
    'fa-duotone fa-solid fa-users',
    'fa-duotone fa-solid fa-comments',
    'fa-duotone fa-solid fa-arrow-right-arrow-left',
    'fa-duotone fa-solid fa-arrows-rotate',
    'fa-duotone fa-solid fa-calendar-check',
    'fa-duotone fa-solid fa-circle-play',
    'fa-duotone fa-solid fa-shield-check',
];
const inclusions = p.inclusions.map((item, i) => ({ ...item, icon: inclusionIcons[i] }));

const faqs = locale === 'en' ? faqsByPageEn.prijzen : faqsByPage.prijzen;

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbLeaf, localizeHref('/prijzen', locale)],
    ]),
    {
        '@type': 'Product',
        name: 'ShopLinkr',
        description: p.productDescription,
        brand: {
            '@type': 'Brand',
            name: 'ShopLinkr',
        },
        offers: {
            '@type': 'Offer',
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
            url: locale === 'en' ? 'https://shoplinkr.com/en/pricing' : 'https://shoplinkr.com/prijzen',
            priceSpecification: {
                '@type': 'UnitPriceSpecification',
                priceCurrency: 'EUR',
                unitText: 'MONTH',
            },
        },
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="pricing"
    jsonLd={jsonLd}
>
    <PricingCalculator client:visible locale={locale} />

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">{p.howEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        {p.howHeadingLine1}
                        <span class="block text-sunstone-deep">{p.howHeadingLine2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        {p.howIntro}
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                <i class="fa-duotone fa-solid fa-plug text-[1.15rem]" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-2">{p.channelEyebrow}</p>
                            <p class="text-2xl md:text-[1.625rem] font-semibold text-charcoal tracking-tight leading-snug">
                                {p.channelTitle}
                            </p>
                            <p class="mt-4 text-sm text-steel leading-relaxed">
                                {p.channelBody}
                            </p>
                        </article>

                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                <i class="fa-duotone fa-solid fa-layer-group text-[1.15rem]" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-2">{p.orderEyebrow}</p>
                            <p class="text-2xl md:text-[1.625rem] font-semibold text-charcoal tracking-tight leading-snug">
                                {p.orderTitle}
                            </p>
                            <p class="mt-4 text-sm text-steel leading-relaxed">
                                {p.orderBody}
                            </p>
                        </article>
                    </div>

                    <div class="mt-6 rounded-2xl bg-chalk-light ring-1 ring-chalk-dark p-6 md:p-7">
                        <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-5">
                            {p.examplesLabel}
                        </p>
                        <ul class="divide-y divide-chalk-dark">
                            {
                                pricingExamples.map((example) => (
                                    <li class="py-3 first:pt-0 last:pb-0 flex items-baseline justify-between gap-4">
                                        <div>
                                            <p class="text-sm font-semibold text-charcoal">{example.label}</p>
                                            <p class="text-xs text-gravel mt-0.5">{example.sub}</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-base font-semibold text-charcoal tabular-nums whitespace-nowrap">{example.amount}</p>
                                            <p class="text-xs text-gravel tabular-nums whitespace-nowrap mt-0.5">{example.breakdown}</p>
                                        </div>
                                    </li>
                                ))
                            }
                        </ul>
                        <p class="mt-5 text-xs text-gravel leading-relaxed">
                            {p.examplesFootnote}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-2xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.includedEyebrow}</p>
                <h2 class="text-4xl md:text-5xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    {p.includedHeading}
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    {p.includedIntro}
                </p>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
                {
                    inclusions.map((item) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 transition duration-300 ease-out hover:ring-chalk-darker hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-6">
                                <i class={`${item.icon} text-[1.15rem]`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <h3 class="text-base md:text-[1.05rem] font-semibold text-charcoal mb-2 tracking-tight leading-snug">
                                {item.title}
                            </h3>
                            <p class="text-sm text-steel leading-relaxed">
                                {item.body}
                            </p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">{p.faqEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        {p.faqHeadingLine1}
                        <span class="block text-sunstone-deep">{p.faqHeadingLine2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        {p.faqIntro}
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        {p.faqCta}
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
