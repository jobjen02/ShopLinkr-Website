---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { type Locale, localizeHref } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.featuresIndex;

interface Pillar {
    eyebrow: string;
    heading: string;
    body: string;
    accent: 'paper' | 'chalk';
    features: Array<{
        title: string;
        href: string;
        icon: string;
    }>;
}

const pillars: Array<Pillar> = [
    {
        eyebrow: p.pillar1Eyebrow,
        heading: p.pillar1Heading,
        body: p.pillar1Body,
        accent: 'paper',
        features: [
            {
                title: p.pillar1Features[0],
                href: localizeHref('/functionaliteiten/bestellingen', locale),
                icon: 'fa-solid fa-receipt',
            },
            {
                title: p.pillar1Features[1],
                href: localizeHref('/functionaliteiten/picklijsten', locale),
                icon: 'fa-solid fa-clipboard-list',
            },
            {
                title: p.pillar1Features[2],
                href: localizeHref('/functionaliteiten/vervoerders', locale),
                icon: 'fa-solid fa-truck',
            },
            {
                title: p.pillar1Features[3],
                href: localizeHref('/functionaliteiten/retouren', locale),
                icon: 'fa-solid fa-arrow-rotate-left',
            },
        ],
    },
    {
        eyebrow: p.pillar2Eyebrow,
        heading: p.pillar2Heading,
        body: p.pillar2Body,
        accent: 'chalk',
        features: [
            {
                title: p.pillar2Features[0],
                href: localizeHref('/functionaliteiten/voorraad', locale),
                icon: 'fa-solid fa-boxes-stacked',
            },
            {
                title: p.pillar2Features[1],
                href: localizeHref('/functionaliteiten/producten', locale),
                icon: 'fa-solid fa-tag',
            },
            {
                title: p.pillar2Features[2],
                href: localizeHref('/functionaliteiten/locatiebeheer', locale),
                icon: 'fa-solid fa-location-dot',
            },
            {
                title: p.pillar2Features[3],
                href: localizeHref('/functionaliteiten/inkoopadvies', locale),
                icon: 'fa-solid fa-lightbulb',
            },
            {
                title: p.pillar2Features[4],
                href: localizeHref('/functionaliteiten/leveringen', locale),
                icon: 'fa-solid fa-truck-ramp-box',
            },
        ],
    },
    {
        eyebrow: p.pillar3Eyebrow,
        heading: p.pillar3Heading,
        body: p.pillar3Body,
        accent: 'paper',
        features: [
            {
                title: p.pillar3Features[0],
                href: localizeHref('/functionaliteiten/regels', locale),
                icon: 'fa-solid fa-bolt',
            },
            {
                title: p.pillar3Features[1],
                href: localizeHref('/functionaliteiten/rapporten', locale),
                icon: 'fa-solid fa-chart-line',
            },
            {
                title: p.pillar3Features[2],
                href: localizeHref('/functionaliteiten/klanten', locale),
                icon: 'fa-solid fa-users',
            },
            {
                title: p.pillar3Features[3],
                href: localizeHref('/functionaliteiten/gebruikers', locale),
                icon: 'fa-solid fa-user-plus',
            },
        ],
    },
];

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbParent, localizeHref('/functionaliteiten', locale)],
    ]),
    {
        '@type': 'WebPage',
        name: p.jsonLdName,
        description: p.jsonLdDescription,
    },
];
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="features"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.register}
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.demo}
                </a>
            </div>
        </div>
    </section>

    {
        pillars.map((pillar) => (
            <section class={`py-24 md:py-32 ${pillar.accent === 'chalk' ? 'bg-chalk-light dark:bg-graphite' : 'bg-paper dark:bg-charcoal'}`}>
                <div class="container-prose">
                    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                        <div class="lg:col-span-5">
                            <p class="eyebrow mb-4">{pillar.eyebrow}</p>
                            <h2 class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                                {pillar.heading}
                            </h2>
                            <p class="mt-6 text-base md:text-lg text-steel dark:text-gravel leading-relaxed">
                                {pillar.body}
                            </p>
                        </div>

                        <div class="lg:col-span-7">
                            <ul class="grid sm:grid-cols-2 gap-3">
                                {pillar.features.map((feature) => (
                                    <li>
                                        <a
                                            href={feature.href}
                                            class="group flex items-center gap-4 bg-paper dark:bg-charcoal rounded-xl ring-1 ring-chalk-dark dark:ring-flint hover:ring-sunstone-soft dark:hover:ring-sunstone/30 hover:bg-sunstone-mist/30 dark:hover:bg-sunstone/10 px-5 py-4 transition-all duration-200"
                                        >
                                            <span class="flex-shrink-0 inline-flex items-center justify-center h-10 w-10 rounded-lg bg-chalk-light dark:bg-flint text-gravel group-hover:bg-sunstone-mist dark:group-hover:bg-sunstone/10 group-hover:text-sunstone-deep transition-colors">
                                                <i class={`${feature.icon} text-sm`} aria-hidden="true"></i>
                                            </span>
                                            <span class="flex-1 text-[15px] font-medium text-charcoal dark:text-paper group-hover:text-sunstone-deep transition-colors">
                                                {feature.title}
                                            </span>
                                            <i class="fa-solid fa-arrow-right text-xs text-gravel group-hover:text-sunstone-deep group-hover:translate-x-0.5 transition-all" aria-hidden="true"></i>
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                </div>
            </section>
        ))
    }

    <CtaBanner />
</PageLayout>
