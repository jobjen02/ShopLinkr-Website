---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../template/BlogCard.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import { type Locale, localizeHref } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.blogIndex;

const blogs = await getCollection(locale === 'en' ? 'blogsEn' : 'blogs');
const sorted = blogs
    .filter((b) => b.data.isVisible && b.data.isBlog)
    .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const [featured, ...rest] = sorted;

const featuredDate = featured
    ? new Intl.DateTimeFormat(locale === 'en' ? 'en-US' : 'nl-NL', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
    }).format(featured.data.publishedAt)
    : null;

const blogBase = locale === 'en' ? '/en/blog' : '/blogs';

const jsonLd = {
    '@type': 'Blog',
    name: 'ShopLinkr Blog',
    description: p.jsonLdDescription,
    url: `https://shoplinkr.com${localizeHref('/blogs', locale)}`,
    inLanguage: locale === 'en' ? 'en-US' : 'nl-NL',
    publisher: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        logo: {
            '@type': 'ImageObject',
            url: 'https://shoplinkr.com/logo/logo-charcoal.svg',
        },
    },
    blogPost: sorted.slice(0, 10).map((post) => ({
        '@type': 'BlogPosting',
        headline: post.data.title,
        url: `https://shoplinkr.com${blogBase}/${post.id}`,
        datePublished: post.data.publishedAt.toISOString(),
    })),
};
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="blog"
    jsonLd={jsonLd}
>
    {featured && (
        <section class="pb-12 md:pb-16 bg-paper">
            <div class="container-prose">
                <a
                    href={`${blogBase}/${featured.id}`}
                    class="group grid gap-8 lg:grid-cols-12 lg:gap-12 items-center"
                >
                    <div class="order-2 lg:order-1 lg:col-span-7 overflow-hidden rounded-2xl bg-chalk-light ring-1 ring-chalk-dark aspect-video lg:aspect-[16/10]">
                        {featured.data.image ? (
                            <img
                                src={featured.data.image}
                                alt={featured.data.imageAlt ?? featured.data.title}
                                class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
                                loading="eager"
                            />
                        ) : (
                            <div class="h-full w-full flex items-center justify-center bg-gradient-to-br from-chalk-light to-sunstone-mist/40">
                                <i class="fa-solid fa-newspaper text-5xl text-sunstone-deep/40" aria-hidden="true"></i>
                            </div>
                        )}
                    </div>

                    <div class="order-1 lg:order-2 lg:col-span-5">
                        <div class="flex items-center gap-2.5 text-xs">
                            {featured.data.category && (
                                <>
                                    <span class="eyebrow !text-sunstone-deep">{featured.data.category}</span>
                                    <span class="text-chalk-darker" aria-hidden="true">·</span>
                                </>
                            )}
                            <time
                                datetime={featured.data.publishedAt.toISOString()}
                                class="text-gravel font-medium"
                            >
                                {featuredDate}
                            </time>
                        </div>

                        <h2 class="mt-4 text-2xl md:text-3xl lg:text-4xl font-semibold text-charcoal tracking-tight leading-[1.15] group-hover:text-sunstone-deep transition-colors">
                            {featured.data.title}
                        </h2>

                        <p class="mt-6 text-base md:text-lg text-steel leading-relaxed">
                            {featured.data.excerpt}
                        </p>

                        <span class="mt-7 inline-flex items-center gap-1.5 text-sm font-semibold text-sunstone-deep group-hover:gap-2.5 transition-all">
                            {p.readMore}
                            <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
                        </span>
                    </div>
                </a>
            </div>
        </section>
    )}

    {rest.length > 0 && (
        <section class="pb-24 md:pb-32 bg-paper">
            <div class="container-prose">
                <div class="border-t border-chalk-dark pt-12 md:pt-16">
                    <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight mb-10">
                        {p.moreArticles}
                    </h2>
                    <div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
                        {rest.map((blog) => (
                            <BlogCard
                                title={blog.data.title}
                                excerpt={blog.data.excerpt}
                                publishedAt={blog.data.publishedAt}
                                image={blog.data.image}
                                imageAlt={blog.data.imageAlt}
                                slug={blog.id}
                                category={blog.data.category}
                            />
                        ))}
                    </div>
                </div>
            </div>
        </section>
    )}

    <CtaBanner />
</PageLayout>
