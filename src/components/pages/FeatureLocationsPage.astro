---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import FaqList from '../template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';
import { faqsByPageEn } from '../../data/faqs-en';
import { localizeHref, type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.featureLocations;

// Icons are locale-invariant; merge them with the per-locale card copy by index.
const subFeatureIcons = [
    'fa-duotone fa-solid fa-hand-pointer',
    'fa-duotone fa-solid fa-list-check',
    'fa-duotone fa-solid fa-arrow-right-arrow-left',
    'fa-duotone fa-solid fa-layer-group',
];
const subFeatures = p.subFeatures.map((feature, i) => ({ ...feature, icon: subFeatureIcons[i] }));

const locationTypes = p.locationTypes;

const faqs = locale === 'en' ? faqsByPageEn.locatiebeheer : faqsByPage.locatiebeheer;

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbParent, localizeHref('/functionaliteiten', locale)],
        [p.breadcrumbLeaf, localizeHref('/functionaliteiten/locatiebeheer', locale)],
    ]),
    {
        '@type': 'WebPage',
        name: p.title,
        description: p.description,
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="features.locations"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.register}
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.demo}
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper dark:bg-charcoal">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper dark:from-sunstone/5 dark:via-charcoal dark:to-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                    <div>
                        <p class="eyebrow mb-3">{p.mockupEyebrow}</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.05]">
                            {p.mockupHeadingLine1}
                            <span class="block">{p.mockupHeadingLine2}</span>
                        </h2>
                    </div>

                    <div class="bg-paper dark:bg-charcoal rounded-xl ring-1 ring-chalk-dark dark:ring-flint p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-5">
                            <div class="flex items-center gap-2.5">
                                <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                    <i class="fa-solid fa-warehouse text-[0.7rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-sm font-semibold text-charcoal dark:text-paper">{p.mockupWarehouseName}</span>
                            </div>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">{p.mockupWarehouseTag}</span>
                        </div>

                        <ul class="space-y-1.5 text-sm">
                            <li class="flex items-center gap-2 pl-1">
                                <i class="fa-solid fa-folder-open text-gravel text-[0.7rem]" aria-hidden="true"></i>
                                <span class="text-charcoal dark:text-paper font-medium">{p.mockupAisle}</span>
                            </li>
                            <li class="flex items-center gap-2 pl-6">
                                <span class="text-chalk-dark dark:text-flint font-mono text-xs">└─</span>
                                <i class="fa-solid fa-folder-open text-gravel text-[0.7rem]" aria-hidden="true"></i>
                                <span class="text-charcoal dark:text-paper font-medium">{p.mockupRack}</span>
                            </li>
                            <li class="flex items-center gap-2 pl-12">
                                <span class="text-chalk-dark dark:text-flint font-mono text-xs">└─</span>
                                <i class="fa-solid fa-folder-open text-gravel text-[0.7rem]" aria-hidden="true"></i>
                                <span class="text-charcoal dark:text-paper font-medium">{p.mockupShelf}</span>
                            </li>
                            <li class="flex flex-wrap items-center gap-2 pl-12 sm:pl-[4.5rem]">
                                <span class="text-chalk-dark dark:text-flint font-mono text-xs">└─</span>
                                <span class="inline-flex items-center gap-2 px-2.5 py-1 rounded-md bg-sunstone-mist/60 dark:bg-sunstone/10 ring-1 ring-sunstone-soft/60 dark:ring-sunstone/30">
                                    <i class="fa-solid fa-box text-sunstone-deep text-[0.7rem]" aria-hidden="true"></i>
                                    <span class="text-charcoal dark:text-paper font-semibold">{p.mockupBin}</span>
                                    <span class="text-sunstone-deep font-mono text-[11px] font-semibold">A.1.3.2</span>
                                </span>
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-chalk-light dark:bg-flint ring-1 ring-chalk-dark dark:ring-flint text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">
                                    <i class="fa-solid fa-hand-pointer text-[0.6rem]" aria-hidden="true"></i>
                                    {p.mockupPickTag}
                                </span>
                            </li>
                        </ul>

                        <div class="mt-4 pt-4 border-t border-chalk-dark dark:border-flint">
                            <div class="flex items-center justify-between gap-3">
                                <div class="flex items-center gap-2.5 min-w-0">
                                    <span class="inline-flex items-center justify-center h-8 w-8 rounded-md bg-chalk-light dark:bg-flint ring-1 ring-chalk-dark dark:ring-flint flex-shrink-0">
                                        <i class="fa-solid fa-headphones text-charcoal dark:text-paper text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-charcoal dark:text-paper truncate">{p.mockupProductName}</p>
                                        <p class="text-[11px] text-gravel">{p.mockupProductStock}</p>
                                    </div>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel flex-shrink-0">{p.mockupLinkedTag}</span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-paper/70 dark:bg-charcoal/70 rounded-xl ring-1 ring-chalk-dark dark:ring-flint px-4 py-3 flex items-center justify-between gap-3">
                        <div class="flex items-center gap-2 text-[11px]">
                            <i class="fa-solid fa-pallet text-gravel text-xs" aria-hidden="true"></i>
                            <span class="font-mono text-charcoal dark:text-paper font-semibold">B.4.1.1</span>
                            <span class="text-gravel">{p.mockupBulkStock}</span>
                        </div>
                        <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">{p.mockupBulkTag}</span>
                    </div>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper dark:bg-graphite rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel dark:text-gravel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">{p.typesEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.typesHeadingLine1}
                        <span class="block text-sunstone-deep">{p.typesHeadingLine2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.typesIntro}
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark dark:divide-flint border-y border-chalk-dark dark:border-flint">
                        {
                            locationTypes.map((type) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 mt-0.5">
                                        <i class="fa-solid fa-warehouse text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{type.title}</h3>
                                        <p class="mt-2 text-steel dark:text-gravel leading-relaxed text-[0.975rem]">{type.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">{p.faqEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.faqHeadingLine1}
                        <span class="block text-sunstone-deep">{p.faqHeadingLine2}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.faqIntro}
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal dark:text-paper font-semibold text-sm">
                        {p.faqCta}
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
