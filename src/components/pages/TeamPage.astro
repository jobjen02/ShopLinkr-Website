---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { localizeHref, type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.team;

// Photos and FA icons are locale-invariant; merge them with the per-locale copy
// by index. The 4th member is the "join us" placeholder card.
const photos = [
    '/images/team/rIjDTHDh7F1ucNVPvkRg3dHT2ZQ.png',
    '/images/team/92PrDnKBY75TXrhH11Ti9A1jU.png',
    '/images/team/rzPqzsMXycKbFfV8gkOWIaFcJ8.png',
    '/images/team/GoWNvgKZvVTzmZQKHoh2Ccnk4E.png',
];
const emojis = ['fa-code', 'fa-headset', 'fa-pen-ruler', 'fa-sparkles'];

const team = p.members.map((member, i) => ({
    name: member.name,
    role: member.role,
    photo: photos[i],
    bio: member.bio,
    focus: member.focus,
    emoji: emojis[i],
}));

const realTeam = team.slice(0, 3);

// Stat values: '1M+' and '2022' are locale-invariant; the "1e"/"1st" and
// "4,9"/"4.9" values differ per locale, so they come from the dict.
const orderedStats = [
    { value: '1M+', label: p.statLabels[0] },
    { value: '2022', label: p.statLabels[1] },
    { value: p.statFirstValue, label: p.statLabels[2] },
    { value: p.statRatingValue, label: p.statLabels[3] },
];

const icons = ['fa-handshake', 'fa-gauge-high', 'fa-heart'];
const values = p.values.map((value, i) => ({
    icon: icons[i],
    title: value.title,
    body: value.body,
}));

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        ['Team', localizeHref('/team', locale)],
    ]),
    {
        '@type': 'AboutPage',
        name: p.title,
        description: p.description,
        mainEntity: {
            '@type': 'Organization',
            name: 'ShopLinkr',
            url: 'https://shoplinkr.com',
            foundingDate: '2022',
            founder: {
                '@type': 'Person',
                name: 'Job',
            },
            employee: realTeam.map((member) => ({
                '@type': 'Person',
                name: member.name,
                jobTitle: member.role,
                description: member.bio,
                ...(member.photo && {
                    image: `https://shoplinkr.com${member.photo}`,
                }),
                worksFor: {
                    '@type': 'Organization',
                    name: 'ShopLinkr',
                },
            })),
        },
    },
];

export const prerender = false;
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="team"
    jsonLd={jsonLd}
>
    <section class="py-12 md:py-16">
        <div class="container-prose">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
                {
                    orderedStats.map((stat) => (
                        <div class="bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7 text-center md:text-left transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                            <p class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-none">
                                {stat.value}
                            </p>
                            <p class="mt-2 text-sm text-gravel">
                                {stat.label}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-2 lg:sticky lg:top-24">
                    <p class="eyebrow mb-4">{p.originEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.originHeading}
                    </h2>
                </div>
                <div class="lg:col-span-3 space-y-6 text-base md:text-lg text-steel dark:text-gravel leading-relaxed">
                    <p>
                        {p.originPara1}
                    </p>
                    <p>
                        {p.originPara2}
                    </p>
                    <p class="text-charcoal dark:text-paper font-medium">
                        {p.originPara3}
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
        <div class="container-prose">
            <div class="max-w-2xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.teamEyebrow}</p>
                <h2 class="text-4xl md:text-5xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.05]">
                    {p.teamHeading}
                </h2>
                <p class="mt-6 text-lg text-steel dark:text-gravel leading-relaxed">
                    {p.teamIntro}
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-6 gap-4 md:gap-5">
                <article class="md:col-span-3 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper dark:from-sunstone/5 dark:via-charcoal dark:to-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint overflow-hidden flex flex-col transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                    <div class="aspect-[4/3] md:aspect-auto md:flex-1 bg-paper/40 dark:bg-charcoal/40 overflow-hidden">
                        <img
                            src={team[0].photo}
                            alt={team[0].name}
                            class="h-full w-full object-contain"
                            loading="lazy"
                        />
                    </div>
                    <div class="p-8 md:p-10 border-t border-chalk-dark/60 dark:border-flint bg-paper/70 dark:bg-charcoal/70 backdrop-blur-sm">
                        <div class="flex items-start justify-between gap-4 mb-3">
                            <div>
                                <h3 class="text-2xl md:text-3xl font-semibold text-charcoal dark:text-paper tracking-tight leading-tight">
                                    {team[0].name}
                                </h3>
                                <p class="mt-1 text-sm font-medium text-sunstone-deep">
                                    {team[0].role}
                                </p>
                            </div>
                            <span class="inline-flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 shrink-0">
                                <i class={`fa-duotone fa-solid ${team[0].emoji} text-lg`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </span>
                        </div>
                        <p class="text-steel dark:text-gravel leading-relaxed text-base">
                            {team[0].bio}
                        </p>
                        <p class="mt-4 text-xs uppercase tracking-[0.18em] font-semibold text-gravel">
                            {team[0].focus}
                        </p>
                    </div>
                </article>

                <article class="md:col-span-3 bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint overflow-hidden flex flex-col sm:flex-row transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                    <div class="sm:w-2/5 aspect-square sm:aspect-auto bg-chalk-light dark:bg-graphite overflow-hidden shrink-0">
                        <img
                            src={team[1].photo}
                            alt={team[1].name}
                            class="h-full w-full object-contain"
                            loading="lazy"
                        />
                    </div>
                    <div class="p-6 md:p-7 flex-1 flex flex-col">
                        <div class="flex items-start justify-between gap-3 mb-2">
                            <div>
                                <h3 class="text-xl md:text-2xl font-semibold text-charcoal dark:text-paper tracking-tight leading-tight">
                                    {team[1].name}
                                </h3>
                                <p class="mt-1 text-sm font-medium text-sunstone-deep">
                                    {team[1].role}
                                </p>
                            </div>
                            <span class="inline-flex items-center justify-center h-9 w-9 rounded-lg bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 shrink-0">
                                <i class={`fa-duotone fa-solid ${team[1].emoji} text-base`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </span>
                        </div>
                        <p class="text-steel dark:text-gravel leading-relaxed text-sm md:text-base">
                            {team[1].bio}
                        </p>
                        <p class="mt-4 text-xs uppercase tracking-[0.18em] font-semibold text-gravel">
                            {team[1].focus}
                        </p>
                    </div>
                </article>

                <article class="md:col-span-3 bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint overflow-hidden flex flex-col sm:flex-row transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                    <div class="sm:w-2/5 aspect-square sm:aspect-auto bg-chalk-light dark:bg-graphite overflow-hidden shrink-0 order-1 sm:order-2">
                        <img
                            src={team[2].photo}
                            alt={team[2].name}
                            class="h-full w-full object-contain"
                            loading="lazy"
                        />
                    </div>
                    <div class="p-6 md:p-7 flex-1 flex flex-col order-2 sm:order-1">
                        <div class="flex items-start justify-between gap-3 mb-2">
                            <div>
                                <h3 class="text-xl md:text-2xl font-semibold text-charcoal dark:text-paper tracking-tight leading-tight">
                                    {team[2].name}
                                </h3>
                                <p class="mt-1 text-sm font-medium text-sunstone-deep">
                                    {team[2].role}
                                </p>
                            </div>
                            <span class="inline-flex items-center justify-center h-9 w-9 rounded-lg bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 shrink-0">
                                <i class={`fa-duotone fa-solid ${team[2].emoji} text-base`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </span>
                        </div>
                        <p class="text-steel dark:text-gravel leading-relaxed text-sm md:text-base">
                            {team[2].bio}
                        </p>
                        <p class="mt-4 text-xs uppercase tracking-[0.18em] font-semibold text-gravel">
                            {team[2].focus}
                        </p>
                    </div>
                </article>

                <article class="md:col-span-6 bg-charcoal dark:bg-charcoal text-paper rounded-2xl ring-1 ring-charcoal dark:ring-flint overflow-hidden flex flex-col md:flex-row items-stretch transition duration-300 ease-out hover:bg-charcoal/95">
                    <div class="md:w-1/3 aspect-square md:aspect-auto bg-charcoal/60 dark:bg-charcoal/60 overflow-hidden shrink-0 relative">
                        <img
                            src={team[3].photo}
                            alt={team[3].name}
                            class="h-full w-full object-contain opacity-90"
                            loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-tr from-charcoal/60 via-transparent to-transparent pointer-events-none"></div>
                    </div>
                    <div class="p-8 md:p-10 flex-1 flex flex-col justify-center">
                        <div class="flex items-center gap-3 mb-3">
                            <span class="inline-flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist/15 dark:bg-sunstone/10 text-sunstone-soft ring-1 ring-sunstone-soft/30 shrink-0">
                                <i class={`fa-duotone fa-solid ${team[3].emoji} text-lg`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </span>
                            <p class="text-[11px] uppercase tracking-[0.18em] font-semibold text-paper/60">
                                {p.joinKicker}
                            </p>
                        </div>
                        <h3 class="text-2xl md:text-3xl font-semibold tracking-tight leading-tight text-paper">
                            {p.joinHeading}
                        </h3>
                        <p class="mt-3 text-paper/70 text-base md:text-lg leading-relaxed max-w-xl">
                            {p.joinBody}
                        </p>
                        <div class="mt-6">
                            <a
                                href={p.joinMailto}
                                class="btn btn-sunstone text-sm whitespace-nowrap"
                            >
                                {p.joinCta}
                                <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="max-w-2xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.valuesEyebrow}</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                    {p.valuesHeading}
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
                {
                    values.map((value) => (
                        <article class="bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-8 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                <i class={`fa-duotone fa-solid ${value.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <h3 class="text-xl md:text-2xl font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">
                                    {value.title}
                                </h3>
                                <p class="mt-2 text-base text-steel dark:text-gravel leading-relaxed">
                                    {value.body}
                                </p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
        <div class="container-prose">
            <div class="max-w-3xl mx-auto">
                <div class="bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-8 md:p-12">
                    <i class="fa-solid fa-quote-left text-sunstone-deep text-2xl mb-5" aria-hidden="true"></i>
                    <p class="text-charcoal dark:text-paper text-xl md:text-2xl font-medium leading-relaxed">
                        {p.quote}
                    </p>
                    <div class="mt-6">
                        <p class="text-sm font-semibold text-charcoal dark:text-paper">
                            Job
                        </p>
                        <p class="text-xs text-gravel mt-0.5">
                            Founder ShopLinkr
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <article class="bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-8 md:p-10 flex flex-col md:flex-row items-start md:items-center gap-6 md:gap-10">
                <div class="flex-1">
                    <p class="eyebrow mb-3">{p.demoEyebrow}</p>
                    <h2 class="text-2xl md:text-3xl font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">
                        {p.demoHeading}
                    </h2>
                    <p class="mt-3 text-base text-steel dark:text-gravel leading-relaxed max-w-xl">
                        {p.demoBody}
                    </p>
                </div>
                <div class="flex flex-col sm:flex-row gap-3 shrink-0">
                    <a
                        href={externalLinks.demoBooking}
                        class="btn btn-sunstone text-base whitespace-nowrap"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t.common.demo}
                        <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
                    </a>
                    <a
                        href={externalLinks.register}
                        class="btn btn-secondary text-base whitespace-nowrap"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        {t.common.register}
                    </a>
                </div>
            </article>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
