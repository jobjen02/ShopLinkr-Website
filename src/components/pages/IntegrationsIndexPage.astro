---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import IntegrationCard from '../template/IntegrationCard.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import { breadcrumbs } from '../../utils/seo';
import { type Locale, localizeHref } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.integrationsIndex;

const all = await getCollection(locale === 'en' ? 'integrationsEn' : 'integrations');

const webshops = all
    .filter((i) => i.data.category === 'webshop')
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const marketplaces = all
    .filter((i) => i.data.category === 'marketplace')
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const carriers = all
    .filter((i) => i.data.category === 'carrier')
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const totalCount = webshops.length + marketplaces.length + carriers.length;

const popularCombinations = [
    {
        href: localizeHref('/integraties/shopify-koppelen-aan-bol-com', locale),
        from: 'Shopify',
        fromLogo: '/assets/webshops/Shopify.jpg',
        to: 'bol',
        toLogo: '/assets/marketplaces/bol.jpeg',
        body: p.combos[0],
    },
    {
        href: localizeHref('/integraties/woocommerce-koppelen-aan-bol-com', locale),
        from: 'WooCommerce',
        fromLogo: '/assets/webshops/WooCommerce.png',
        to: 'bol',
        toLogo: '/assets/marketplaces/bol.jpeg',
        body: p.combos[1],
    },
    {
        href: localizeHref('/integraties/woocommerce-koppelen-aan-shopify', locale),
        from: 'WooCommerce',
        fromLogo: '/assets/webshops/WooCommerce.png',
        to: 'Shopify',
        toLogo: '/assets/webshops/Shopify.jpg',
        body: p.combos[2],
    },
];

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbParent, localizeHref('/integraties', locale)],
    ]),
    {
        '@type': 'WebPage',
        name: p.jsonLdName,
        description: p.jsonLdDescription,
    },
];
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="integrations"
    jsonLd={jsonLd}
>
    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-baseline sm:justify-between mb-12">
                <p class="text-sm text-gravel" aria-live="polite" data-result-count>
                    {totalCount} {p.resultsSuffix}
                </p>
                <div>
                <div
                    class="flex flex-col gap-1 w-full rounded-2xl bg-chalk-light dark:bg-graphite ring-1 ring-chalk-dark dark:ring-flint p-1 text-sm sm:inline-flex sm:flex-row sm:w-max sm:rounded-full"
                    role="group"
                    aria-label={p.filterGroupLabel}
                >
                    <button
                        type="button"
                        class="filter-tab is-active px-4 py-2 min-h-11 w-full sm:w-auto inline-flex items-center justify-center rounded-full font-medium text-charcoal dark:text-paper transition-colors"
                        data-filter="all"
                        aria-pressed="true"
                    >
                        {p.filterAll}
                    </button>
                    <button
                        type="button"
                        class="filter-tab px-4 py-2 min-h-11 w-full sm:w-auto inline-flex items-center justify-center rounded-full font-medium text-gravel transition-colors"
                        data-filter="webshop"
                        aria-pressed="false"
                    >
                        {p.filterWebshops}
                    </button>
                    <button
                        type="button"
                        class="filter-tab px-4 py-2 min-h-11 w-full sm:w-auto inline-flex items-center justify-center rounded-full font-medium text-gravel transition-colors"
                        data-filter="marketplace"
                        aria-pressed="false"
                    >
                        {p.filterMarketplaces}
                    </button>
                    <button
                        type="button"
                        class="filter-tab px-4 py-2 min-h-11 w-full sm:w-auto inline-flex items-center justify-center rounded-full font-medium text-gravel transition-colors"
                        data-filter="carrier"
                        aria-pressed="false"
                    >
                        {p.filterCarriers}
                    </button>
                </div>
                </div>
            </div>

            {webshops.length > 0 && (
                <div class="integration-group mb-16" data-group="webshop">
                    <div class="flex items-baseline justify-between mb-6">
                        <h2 class="eyebrow">{p.groupWebshops}</h2>
                        <span class="text-xs text-gravel">
                            {webshops.length} {webshops.length === 1 ? p.webshopSingular : p.webshopPlural}
                        </span>
                    </div>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                        {webshops.map((i) => (
                            <IntegrationCard
                                {...i.data}
                                href={localizeHref(`/integraties/${i.data.slug}`, locale)}
                                locale={locale}
                            />
                        ))}
                    </div>
                </div>
            )}

            {marketplaces.length > 0 && (
                <div class="integration-group mb-16" data-group="marketplace">
                    <div class="flex items-baseline justify-between mb-6">
                        <h2 class="eyebrow">{p.groupMarketplaces}</h2>
                        <span class="text-xs text-gravel">
                            {marketplaces.length} {marketplaces.length === 1 ? p.marketplaceSingular : p.marketplacePlural}
                        </span>
                    </div>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                        {marketplaces.map((i) => (
                            <IntegrationCard
                                {...i.data}
                                href={localizeHref(`/integraties/${i.data.slug}`, locale)}
                                locale={locale}
                            />
                        ))}
                    </div>
                </div>
            )}

            {carriers.length > 0 && (
                <div class="integration-group" data-group="carrier">
                    <div class="flex items-baseline justify-between mb-6">
                        <h2 class="eyebrow">{p.groupCarriers}</h2>
                        <span class="text-xs text-gravel">
                            {carriers.length} {p.carrierPlural}
                        </span>
                    </div>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                        {carriers.map((i) => (
                            <IntegrationCard
                                {...i.data}
                                href={localizeHref(`/integraties/${i.data.slug}`, locale)}
                                locale={locale}
                            />
                        ))}
                    </div>
                </div>
            )}
        </div>
    </section>

    <section class="pb-12 md:pb-16">
        <div class="container-prose">
            <div class="mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.combosEyebrow}</p>
                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal dark:text-paper tracking-tight">
                    {p.combosHeading}
                </h2>
                <p class="mt-6 text-steel dark:text-gravel leading-relaxed max-w-2xl">
                    {p.combosBody}
                </p>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                {popularCombinations.map((combo) => (
                    <a
                        href={combo.href}
                        class="group relative block bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]"
                    >
                        <div class="flex items-center gap-2 mb-4">
                            <div class="h-10 w-10 rounded-lg bg-paper dark:bg-flint ring-1 ring-chalk-dark dark:ring-flint flex items-center justify-center overflow-hidden flex-shrink-0">
                                <img
                                    src={combo.fromLogo}
                                    alt=""
                                    class="h-full w-full object-contain p-1.5"
                                    loading="lazy"
                                />
                            </div>
                            <i class="fa-solid fa-arrow-right-arrow-left text-xs text-gravel" aria-hidden="true"></i>
                            <div class="h-10 w-10 rounded-lg bg-paper dark:bg-flint ring-1 ring-chalk-dark dark:ring-flint flex items-center justify-center overflow-hidden flex-shrink-0">
                                <img
                                    src={combo.toLogo}
                                    alt=""
                                    class="h-full w-full object-contain p-1.5"
                                    loading="lazy"
                                />
                            </div>
                        </div>
                        <p class="eyebrow !text-gravel mb-1">{p.comboLabel}</p>
                        <h3 class="text-base font-semibold text-charcoal dark:text-paper tracking-tight">
                            {combo.from} {p.comboAnd} {combo.to}
                        </h3>
                        <p class="mt-3 text-sm text-steel dark:text-gravel leading-relaxed">
                            {combo.body}
                        </p>
                        <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-charcoal dark:text-paper group-hover:text-sunstone-deep transition-colors">
                            {p.comboCta}
                            <i class="fa-solid fa-arrow-right text-[10px] transition-transform group-hover:translate-x-0.5" aria-hidden="true"></i>
                        </span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <section class="pb-20 md:pb-28">
        <div class="container-prose">
            <div class="max-w-2xl mx-auto text-center rounded-2xl ring-1 ring-chalk-dark dark:ring-flint bg-chalk-light dark:bg-graphite p-8 md:p-12">
                <p class="eyebrow mb-4">{p.missingEyebrow}</p>
                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal dark:text-paper tracking-tight">
                    {p.missingHeading}
                </h2>
                <p class="mt-4 text-steel dark:text-gravel leading-relaxed">
                    {p.missingBody}
                </p>
                <div class="mt-7 flex flex-col sm:flex-row gap-3 justify-center">
                    <a
                        href={p.missingMailto}
                        class="btn btn-secondary text-sm"
                    >
                        <i class="fa-solid fa-envelope text-xs" aria-hidden="true"></i>
                        {p.missingMailLabel}
                    </a>
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>

<style>
    .filter-tab {
        cursor: pointer;
        border: 0;
        background: transparent;
    }

    .filter-tab.is-active {
        background-color: var(--color-paper, #fff);
        color: var(--color-charcoal);
        box-shadow: 0 1px 2px rgba(25, 25, 25, 0.08);
    }

    :global(.dark) .filter-tab.is-active {
        background-color: var(--color-flint);
        color: var(--color-paper);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
    }

    .filter-tab:not(.is-active):hover {
        color: var(--color-charcoal);
    }

    :global(.dark) .filter-tab:not(.is-active):hover {
        color: var(--color-paper);
    }

    .integration-group.is-hidden {
        display: none;
    }
</style>

<script define:vars={{ labels: p.scriptLabels }}>
    const tabs = document.querySelectorAll('.filter-tab');
    const groups = document.querySelectorAll('.integration-group');
    const resultCount = document.querySelector('[data-result-count]');

    const totalByGroup = {};
    groups.forEach((group) => {
        const key = group.dataset.group ?? '';
        const cards = group.querySelectorAll('[data-integration]').length;
        totalByGroup[key] = cards;
    });
    const grandTotal = Object.values(totalByGroup).reduce((acc, n) => acc + n, 0);

    const labelFor = (filter, count) => {
        if (filter === 'webshop') {
            return `${count} ${count === 1 ? labels.webshopSingular : labels.webshopPlural} ${labels.available}`;
        }
        if (filter === 'marketplace') {
            return `${count} ${count === 1 ? labels.marketplaceSingular : labels.marketplacePlural} ${labels.available}`;
        }
        if (filter === 'carrier') {
            return `${count} ${count === 1 ? labels.carrierSingular : labels.carrierPlural} ${labels.available}`;
        }
        return `${count} ${labels.integrations} ${labels.available}`;
    };

    const applyFilter = (tab) => {
        const filter = tab.dataset.filter ?? 'all';

        tabs.forEach((t) => {
            const active = t === tab;
            t.classList.toggle('is-active', active);
            t.setAttribute('aria-pressed', active ? 'true' : 'false');
            t.classList.toggle('text-charcoal', active);
            t.classList.toggle('text-gravel', !active);
        });

        groups.forEach((group) => {
            if (filter === 'all') {
                group.classList.remove('is-hidden');
                return;
            }
            const matches = group.dataset.group === filter;
            group.classList.toggle('is-hidden', !matches);
        });

        if (resultCount) {
            const count = filter === 'all'
                ? grandTotal
                : (totalByGroup[filter] ?? 0);
            resultCount.textContent = labelFor(filter, count);
        }
    };

    tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => applyFilter(tab));

        tab.addEventListener('keydown', (event) => {
            if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') {
                return;
            }
            event.preventDefault();
            const direction = event.key === 'ArrowRight' ? 1 : -1;
            const next = tabs[(index + direction + tabs.length) % tabs.length];
            next.focus();
            applyFilter(next);
        });
    });
</script>
