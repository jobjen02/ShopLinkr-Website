---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SupportHero from '../support/SupportHero.astro';
import SupportSearch from '../support/SupportSearch.vue';
import { supportCategories } from '../../data/supportCategories';
import { supportCategoriesEn } from '../../data/supportCategories-en';
import { type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.supportIndex;

const categories = locale === 'en' ? supportCategoriesEn : supportCategories;
const supportBase = locale === 'en' ? '/en/support' : '/support';
const categoriesBase = locale === 'en' ? '/en/support/categories' : '/support/categorieen';

const articles = await getCollection(locale === 'en' ? 'supportArticlesEn' : 'supportArticles');

const searchData = articles
    .map((a) => {
        const slug = a.id.split('/').pop() ?? a.id;
        return {
            title: a.data.title,
            summary: a.data.summary,
            category: a.data.category,
            categoryLabel: a.data.categoryLabel,
            subcategory: a.data.subcategory ?? null,
            subcategoryLabel: a.data.subcategoryLabel ?? null,
            href: `${supportBase}/${slug}`,
        };
    })
    .sort((a, b) => a.title.localeCompare(b.title));

const jsonLd = {
    '@type': 'CollectionPage',
    name: p.jsonLdName,
    description: p.metaDescription,
    url: `https://shoplinkr.com${supportBase}`,
    ...(locale === 'en' ? { inLanguage: 'en-US' } : {}),
    mainEntity: {
        '@type': 'ItemList',
        numberOfItems: categories.length,
        itemListElement: categories.map((category, index) => ({
            '@type': 'ListItem',
            position: index + 1,
            url: `https://shoplinkr.com${categoriesBase}/${category.slug}`,
            name: category.label,
        })),
    },
};

export const prerender = false;
---

<BaseLayout
    title={p.title}
    description={p.metaDescription}
    routeKey="support"
    jsonLd={jsonLd}
>
    <SupportHero
        title={p.heroTitle}
        subtitle={p.heroSubtitle}
    />

    <section class="bg-paper">
        <div class="container-prose py-12 md:py-16">
            <div class="max-w-3xl mx-auto mb-12 md:mb-16">
                <SupportSearch articles={searchData} locale={locale} client:visible />
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 md:gap-6">
                {categories.map((c) => (
                    <article class="group relative flex flex-col bg-paper rounded-[20px] border border-chalk-dark/60 shadow-[0_2px_8px_rgba(25,25,25,0.03)] hover:shadow-[0_16px_40px_-16px_rgba(232,182,121,0.30)] hover:border-sunstone-soft/60 transition-all duration-300 p-7 md:p-8 overflow-hidden">
                        <div class="absolute -top-12 -right-12 w-32 h-32 rounded-full bg-sunstone-mist/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

                        <header class="relative flex items-start gap-5 pb-6 mb-6 border-b border-chalk-dark/60">
                            <div class="flex-none">
                                <i class={`${c.icon} text-[36px] text-sunstone-deep`} style="--fa-primary-color: var(--color-sunstone-deep); --fa-secondary-color: var(--color-sunstone); --fa-secondary-opacity: 0.45;" aria-hidden="true"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <h2 class="text-[22px] md:text-[24px] font-semibold text-charcoal leading-[1.15] tracking-tight">
                                    <a href={`${categoriesBase}/${c.slug}`} class="after:absolute after:inset-0 hover:text-sunstone-deep transition-colors">
                                        {c.label}
                                    </a>
                                </h2>
                                <p class="mt-2 text-[14px] text-steel leading-relaxed">
                                    {c.summary}
                                </p>
                            </div>
                        </header>

                        <ul class="relative grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                            {c.subcategories.map((s) => (
                                <li>
                                    <a
                                        href={`${categoriesBase}/${c.slug}/${s.slug}`}
                                        class="relative z-10 flex items-center justify-between gap-3 bg-chalk-light hover:bg-sunstone-mist/60 rounded-[10px] px-4 py-3 text-[13.5px] font-medium text-charcoal hover:text-sunstone-deep transition-colors"
                                    >
                                        <span>{s.label}</span>
                                        <i class="fa-solid fa-chevron-right text-[10px] text-gravel" aria-hidden="true"></i>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </article>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>
