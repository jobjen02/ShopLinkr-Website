---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import FaqList from '../template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPageFor } from '../../i18n/localeData';
import { type Locale, localizeHref } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.featureCustomers;

// Icons are locale-invariant; merge them with the per-locale card copy by index.
const subFeatureIcons = [
    'fa-duotone fa-solid fa-location-dot',
    'fa-duotone fa-solid fa-copy',
    'fa-duotone fa-solid fa-shield-halved',
    'fa-duotone fa-solid fa-lock',
];
const subFeatures = p.subFeatures.map((feature, i) => ({ ...feature, icon: subFeatureIcons[i] }));

const fieldGroups = p.fieldGroups;

const faqs = faqsByPageFor(locale).klanten;

const jsonLd = [
    breadcrumbs([
        ['Home', localizeHref('/', locale)],
        [p.breadcrumbParent, localizeHref('/functionaliteiten', locale)],
        [p.breadcrumbLeaf, localizeHref('/functionaliteiten/klanten', locale)],
    ]),
    {
        '@type': 'WebPage',
        name: p.title,
        description: p.description,
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="features.customers"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.register}
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.demo}
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper dark:bg-charcoal">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper dark:from-sunstone/5 dark:via-charcoal dark:to-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                    <div>
                        <p class="eyebrow mb-3">{p.heroEyebrow}</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.05]">
                            {p.heroHeading}
                            <span class="block">{p.heroHeadingLine}</span>
                        </h2>
                    </div>

                    <div class="bg-paper dark:bg-charcoal rounded-xl ring-1 ring-chalk-dark dark:ring-flint p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <span class="text-sm font-semibold text-charcoal dark:text-paper">{p.mockupOrder}</span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">
                                <i class="fa-solid fa-lock text-[0.65rem] text-sunstone-deep" aria-hidden="true"></i>
                                {p.mockupEncrypted}
                            </span>
                        </div>

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div class="rounded-md bg-chalk-light dark:bg-flint ring-1 ring-chalk-dark dark:ring-flint p-3">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="inline-flex items-center justify-center h-5 w-5 rounded bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                        <i class="fa-solid fa-truck text-[0.6rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">{p.mockupShippingLabel}</span>
                                </div>
                                <p class="text-sm font-medium text-charcoal dark:text-paper leading-snug">Lotte de Vries</p>
                                <p class="text-xs text-steel dark:text-gravel leading-snug mt-0.5">Kerkstraat 18</p>
                                <p class="text-xs text-steel dark:text-gravel leading-snug">3811 CV, Amersfoort</p>
                                <p class="text-xs text-gravel leading-snug mt-1.5 tabular-nums">+31 6 12 34 56 78</p>
                            </div>
                            <div class="rounded-md bg-chalk-light dark:bg-flint ring-1 ring-chalk-dark dark:ring-flint p-3">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="inline-flex items-center justify-center h-5 w-5 rounded bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                        <i class="fa-solid fa-file-invoice text-[0.6rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">{p.mockupBillingLabel}</span>
                                </div>
                                <p class="text-sm font-medium text-charcoal dark:text-paper leading-snug">De Vries Studio B.V.</p>
                                <p class="text-xs text-steel dark:text-gravel leading-snug mt-0.5">Wilhelminapark 4</p>
                                <p class="text-xs text-steel dark:text-gravel leading-snug">3581 NE, Utrecht</p>
                                <p class="text-xs text-gravel leading-snug mt-1.5 tabular-nums">{p.mockupBillingVat}</p>
                            </div>
                        </div>

                        <div class="flex flex-wrap items-center gap-2 mt-4 pt-4 border-t border-chalk-dark dark:border-flint">
                            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-charcoal dark:text-paper">
                                <i class="fa-solid fa-pen-to-square text-sunstone-deep text-[0.7rem]" aria-hidden="true"></i>
                                {p.mockupAdjustAddress}
                            </span>
                            <span class="text-gravel font-mono text-xs">→</span>
                            <span class="inline-flex items-center gap-1.5 text-[11px] font-medium text-sunstone-deep">
                                <span class="relative inline-flex h-1.5 w-1.5">
                                    <span class="absolute inline-flex h-full w-full rounded-full bg-sunstone-deep opacity-60 animate-ping"></span>
                                    <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-sunstone-deep"></span>
                                </span>
                                {p.mockupDeliveryRefetched}
                            </span>
                        </div>
                    </div>

                    <p class="text-steel dark:text-gravel leading-relaxed text-sm md:text-[0.95rem]">
                        {p.heroBody}
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper dark:bg-graphite rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker dark:hover:ring-steel">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel dark:text-gravel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">{p.fieldsEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.fieldsHeading}
                        <span class="block text-sunstone-deep">{p.fieldsHeadingLine}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.fieldsBody}
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark dark:divide-flint border-y border-chalk-dark dark:border-flint">
                        {
                            fieldGroups.map((group) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep ring-1 ring-sunstone-soft/40 dark:ring-sunstone/30 mt-0.5">
                                        <i class="fa-solid fa-id-card text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal dark:text-paper tracking-tight leading-snug">{group.title}</h3>
                                        <p class="mt-2 text-steel dark:text-gravel leading-relaxed text-[0.975rem]">{group.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper dark:bg-charcoal">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">{p.faqEyebrow}</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal dark:text-paper tracking-tight leading-[1.1]">
                        {p.faqHeading}
                        <span class="block text-sunstone-deep">{p.faqHeadingLine}</span>
                    </h2>
                    <p class="mt-6 text-base text-steel dark:text-gravel leading-relaxed">
                        {p.faqBody}
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal dark:text-paper font-semibold text-sm">
                        {p.faqCta}
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
