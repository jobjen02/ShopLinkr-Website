---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';
import { type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
const p = t.pages.webwinkelVakdagen;

// Icons are locale-invariant; merge them with the per-locale copy by index.
const eventInfoIcons = [
    'fa-solid fa-calendar-days',
    'fa-solid fa-location-dot',
    'fa-solid fa-arrow-right',
];
const eventInfo = p.eventInfo.map((info, i) => ({ ...info, icon: eventInfoIcons[i] }));

const reasonsIcons = [
    'fa-solid fa-comments',
    'fa-solid fa-display',
    'fa-solid fa-bolt',
];
const reasons = p.reasons.map((reason, i) => ({ ...reason, icon: reasonsIcons[i] }));

const jsonLd = {
    '@type': 'WebPage',
    name: p.title,
    description: p.description,
    ...(locale !== 'nl' ? { inLanguage: 'en-US' } : {}),
};
---

<PageLayout
    title={p.title}
    description={p.description}
    eyebrow={p.eyebrow}
    heading={p.heading}
    subheading={p.subheading}
    routeKey="webwinkelVakdagen"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.demo}
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.register}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    {t.common.register}
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-4xl">
                <p class="eyebrow mb-4">{p.lookbackEyebrow}</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1] mb-10">
                    {p.lookbackHeading}
                </h2>

                <div class="grid md:grid-cols-3 gap-6">
                    {
                        eventInfo.map((info) => (
                            <div class="bg-paper rounded-2xl p-7 ring-1 ring-chalk-dark">
                                <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                    <i class={`${info.icon} text-base`} aria-hidden="true" />
                                </div>
                                <p class="eyebrow mb-2">{info.label}</p>
                                <p class="text-lg font-semibold text-charcoal tracking-tight leading-snug">
                                    {info.value}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">{p.missedEyebrow}</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    {p.missedHeading}
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    {p.missedIntro}
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    reasons.map((reason) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${reason.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{reason.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{reason.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{reason.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{reason.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {reason.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>

            <div class="mt-16 max-w-3xl">
                <p class="text-base text-steel leading-relaxed">
                    {p.closing}
                </p>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
