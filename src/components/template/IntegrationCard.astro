---
interface Props {
    name: string;
    slug: string;
    category: string;
    logo: string;
    summary: string;
    status?: 'live' | 'coming-soon';
    href?: string;
    locale?: 'nl' | 'en';
}

const {
    name,
    slug,
    category,
    logo,
    summary,
    status = 'live',
    href,
    locale = 'nl',
} = Astro.props;

const categoryLabelsByLocale: Record<'nl' | 'en', Record<string, string>> = {
    nl: {
        webshop: 'Webshop',
        marketplace: 'Marketplace',
        carrier: 'Vervoerder',
        other: 'Overig',
    },
    en: {
        webshop: 'Webshop',
        marketplace: 'Marketplace',
        carrier: 'Carrier',
        other: 'Other',
    },
};

const categoryLabels = categoryLabelsByLocale[locale];
const categoryLabel = categoryLabels[category] ?? category;
const isComingSoon = status === 'coming-soon';
const Tag = href ? 'a' : 'article';
const linkProps = href
    ? {
        href,
    }
    : {};
---

<Tag
    {...linkProps}
    class={`group relative block bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint p-6 md:p-7 transition duration-300 ease-out ${href ? 'hover:ring-chalk-darker dark:hover:ring-steel hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]' : ''}`}
    data-integration={slug}
>
    <div class="flex items-start gap-4">
        <div class="h-12 w-12 rounded-lg bg-paper ring-1 ring-chalk-dark flex items-center justify-center overflow-hidden flex-shrink-0">
            <img
                src={logo}
                alt={`${name} logo`}
                class="h-full w-full object-contain p-1.5"
                loading="lazy"
            />
        </div>
        <div class="min-w-0 flex-1">
            <div class="flex items-center gap-2 flex-wrap">
                <p class="eyebrow !text-gravel">{categoryLabel}</p>
                {isComingSoon && (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-sunstone-mist dark:bg-sunstone/10 text-sunstone-deep text-[10px] font-semibold uppercase tracking-wider">
                        {locale === 'en' ? 'Coming soon' : 'Binnenkort'}
                    </span>
                )}
            </div>
            <h3 class="mt-1.5 text-base font-semibold text-charcoal dark:text-paper tracking-tight">
                {name}
            </h3>
        </div>
    </div>

    <p class="mt-4 text-sm text-steel dark:text-gravel leading-relaxed">
        {summary}
    </p>
</Tag>
