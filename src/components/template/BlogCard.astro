---
interface Props {
    title: string;
    excerpt: string;
    publishedAt: Date;
    image?: string;
    imageAlt?: string;
    slug: string;
    category?: string;
}

const {
    title,
    excerpt,
    publishedAt,
    image,
    imageAlt,
    slug,
    category,
} = Astro.props;

const formatter = new Intl.DateTimeFormat('nl-NL', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
});
const formattedDate = formatter.format(publishedAt);
const href = `/blogs/${slug}`;
---

<article class="group relative flex flex-col">
    <div class="overflow-hidden rounded-xl bg-chalk-light ring-1 ring-chalk-dark aspect-video">
        {image ? (
            <img
                src={image}
                alt={imageAlt ?? ''}
                class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.02]"
                loading="lazy"
            />
        ) : (
            <div class="h-full w-full flex items-center justify-center bg-gradient-to-br from-chalk-light to-sunstone-mist/30">
                <i class="fa-solid fa-newspaper text-3xl text-sunstone-deep/40" aria-hidden="true"></i>
            </div>
        )}
    </div>

    <div class="mt-5 flex items-center gap-2.5 text-xs">
        {category && (
            <>
                <span class="eyebrow !text-sunstone-deep">{category}</span>
                <span class="text-chalk-darker" aria-hidden="true">·</span>
            </>
        )}
        <time datetime={publishedAt.toISOString()} class="text-gravel font-medium">
            {formattedDate}
        </time>
    </div>

    <h3 class="mt-3 text-xl font-semibold text-charcoal tracking-tight leading-snug">
        <a
            href={href}
            class="hover:text-sunstone-deep transition-colors after:absolute after:inset-0 after:content-['']"
        >
            {title}
        </a>
    </h3>

    <p class="mt-3 text-sm text-steel leading-relaxed line-clamp-3">
        {excerpt}
    </p>

    <span
        class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-sunstone-deep group-hover:gap-2.5 transition-all"
        aria-hidden="true"
    >
        Lees verder
        <i class="fa-solid fa-arrow-right text-xs"></i>
    </span>
</article>

<style>
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
