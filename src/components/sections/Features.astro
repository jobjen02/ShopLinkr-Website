---
const channels = [
    {
        name: 'Bol',
        src: '/assets/marketplaces/bol.jpeg',
    },
    {
        name: 'Shopify',
        src: '/assets/webshops/Shopify.jpg',
    },
    {
        name: 'WooCommerce',
        src: '/assets/webshops/WooCommerce.png',
    },
    {
        name: 'Kaufland',
        src: '/assets/marketplaces/kaufland.jpg',
    },
];

const carriers = [
    {
        name: 'PostNL',
        src: '/assets/carriers/PostNL.jpg',
    },
    {
        name: 'DPD',
        src: '/assets/carriers/dpd.jpeg',
    },
    {
        name: 'GLS',
        src: '/assets/carriers/GLS.png',
    },
    {
        name: 'MyParcel',
        src: '/assets/carriers/MyParcel.jpg',
    },
    {
        name: 'Sendcloud',
        src: '/assets/carriers/Sendcloud.png',
    },
];

const cardLinkClass = 'no-underline text-charcoal hover:text-charcoal';
---

<section class="py-24 md:py-32">
    <div class="container-prose">
        <div class="max-w-2xl mb-14 md:mb-16">
            <p class="eyebrow mb-4">Wat je krijgt</p>
            <h2 class="text-4xl md:text-5xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                Eén platform voor je hele magazijnoperatie.
            </h2>
            <p class="mt-6 text-lg text-steel leading-relaxed">
                Geen losse tools die elkaar niet kennen. ShopLinkr brengt voorraad, orders, picken, labelen en verzenden samen in één systeem.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
            <a href="/functionaliteiten/voorraad" class:list={[cardLinkClass, 'md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col justify-between gap-8 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div>
                    <p class="eyebrow mb-3">Voorraadsynchronisatie</p>
                    <h3 class="text-3xl md:text-[2.5rem] font-semibold text-charcoal tracking-tight leading-[1.05] mb-5">
                        Eén voorraad, alle kanalen.
                    </h3>
                    <p class="text-steel leading-relaxed text-base md:text-lg max-w-md">
                        ShopLinkr houdt je voorraad altijd actueel. Verkocht op Bol? Shopify, WooCommerce en Kaufland zien het binnen seconden.
                    </p>
                </div>
                <ul class="grid grid-cols-2 gap-x-4 gap-y-3 text-sm font-medium text-charcoal">
                    <li class="flex items-center gap-2">
                        <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                        Geen nee-verkoop
                    </li>
                    <li class="flex items-center gap-2">
                        <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                        Geen handwerk
                    </li>
                    <li class="flex items-center gap-2">
                        <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                        Realtime updates
                    </li>
                    <li class="flex items-center gap-2">
                        <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                        Onbeperkt kanalen
                    </li>
                </ul>
            </a>

            <a href="/integraties" class:list={[cardLinkClass, 'md:col-span-2 bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <p class="eyebrow">Verkoopkanalen</p>
                <div class="flex items-center gap-3 flex-wrap">
                    {
                        channels.map((channel) => (
                            <div class="flex items-center justify-center h-12 w-12 md:h-14 md:w-14 rounded-xl bg-chalk-light ring-1 ring-chalk-dark overflow-hidden">
                                <img
                                    src={channel.src}
                                    alt={channel.name}
                                    width="56"
                                    height="56"
                                    loading="lazy"
                                    class="h-full w-full object-contain p-1.5"
                                />
                            </div>
                        ))
                    }
                </div>
                <p class="text-sm text-steel mt-auto">Beheer al je orders en voorraad vanuit één omgeving.</p>
            </a>

            <a href="/functionaliteiten/gebruikers" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-users text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Onbeperkt gebruikers.</p>
                    <p class="text-sm text-steel mt-1.5">Voeg je hele team toe, zonder extra kosten per gebruiker.</p>
                </div>
            </a>

            <a href="/team" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-store text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Gemaakt door bol-verkopers.</p>
                    <p class="text-sm text-steel mt-1.5">Ontstaan uit onze eigen webshop, dagelijks getoetst aan de praktijk.</p>
                </div>
            </a>

            <a href="/functionaliteiten/regels" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-wand-magic-sparkles text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Slimme regels.</p>
                    <p class="text-sm text-steel mt-1.5">Wijs vervoerders, labels en flows automatisch toe op basis van je eigen logica.</p>
                </div>
            </a>

            <a href="/functionaliteiten/locatiebeheer" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-location-dot text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Magazijnlocaties.</p>
                    <p class="text-sm text-steel mt-1.5">Per product zie je direct waar het ligt. Picken zonder zoeken.</p>
                </div>
            </a>

            <a href="/functionaliteiten/vervoerders" class:list={[cardLinkClass, 'md:col-span-2 bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <p class="eyebrow">Vervoerders</p>
                <div class="flex items-center gap-3 flex-wrap">
                    {
                        carriers.map((carrier) => (
                            <div class="flex items-center justify-center h-12 w-12 md:h-14 md:w-14 rounded-xl bg-chalk-light ring-1 ring-chalk-dark overflow-hidden">
                                <img
                                    src={carrier.src}
                                    alt={carrier.name}
                                    width="56"
                                    height="56"
                                    loading="lazy"
                                    class="h-full w-full object-contain p-1.5"
                                />
                            </div>
                        ))
                    }
                </div>
                <p class="text-sm text-steel mt-auto">Print labels van elke vervoerder, de track en trace gaat automatisch naar je verkoopkanaal.</p>
            </a>

            <a href="/functionaliteiten/picklijsten" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-route text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Picklijst met looproute.</p>
                    <p class="text-sm text-steel mt-1.5">Werkt op je telefoon, tablet en scanner.</p>
                </div>
            </a>

            <a href="/functionaliteiten/rapporten" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-chart-line text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Winst per order.</p>
                    <p class="text-sm text-steel mt-1.5">Inkoopprijzen erin, marges per order en kanaal eruit.</p>
                </div>
            </a>

            <a href="/functionaliteiten/picklijsten" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-barcode-read text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Barcodescanner.</p>
                    <p class="text-sm text-steel mt-1.5">Scan elk product en pick zonder fouten.</p>
                </div>
            </a>

            <a href="/functionaliteiten/picklijsten" class:list={[cardLinkClass, 'bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col justify-between gap-4 transition duration-300 ease-out hover:ring-chalk-darker']}>
                <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                    <i class="fa-duotone fa-solid fa-print text-xl" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">Autoprint.</p>
                    <p class="text-sm text-steel mt-1.5">Verzendlabels worden automatisch geprint.</p>
                </div>
            </a>

            <article class="md:col-span-4 bg-charcoal text-paper rounded-2xl p-6 md:p-8 transition duration-300 ease-out hover:bg-charcoal/95">
                <div class="flex flex-col md:flex-row items-start md:items-center md:justify-between gap-5">
                    <div class="flex-1">
                        <p class="text-[11px] uppercase tracking-[0.18em] font-semibold text-paper/50 mb-2">Hoe wij rekenen</p>
                        <h3 class="text-2xl md:text-3xl font-semibold tracking-tight leading-snug">
                            Geen vaste maandprijs.
                        </h3>
                        <p class="text-paper/70 mt-2 text-[0.975rem] max-w-2xl">
                            Je betaalt voor de kanalen en orders die je echt gebruikt. Klein beginnen kan, meegroeien ook.
                        </p>
                    </div>
                    <a
                        href="/prijzen"
                        class="btn btn-sunstone text-sm whitespace-nowrap"
                    >
                        Bekijk prijzen
                        <i class="fa-solid fa-arrow-right text-xs" aria-hidden="true"></i>
                    </a>
                </div>
            </article>
        </div>
    </div>
</section>
