---
const features = [
    {
        icon: 'fa-duotone fa-solid fa-route',
        title: 'Slimme looproute',
        body: 'ShopLinkr berekent de kortste route door je magazijn op basis van locaties.',
    },
    {
        icon: 'fa-duotone fa-solid fa-layer-group',
        title: 'Single of batch',
        body: 'Pak één order tegelijk, of bundel meerdere bestellingen in dezelfde ronde.',
    },
    {
        icon: 'fa-duotone fa-solid fa-mobile-screen',
        title: 'Telefoon, tablet of scanner',
        body: 'Werkt op elk apparaat dat past in je pickflow.',
    },
    {
        icon: 'fa-duotone fa-solid fa-print',
        title: 'Autoprint klaar',
        body: 'Het verzendlabel rolt automatisch uit de printer zodra een order klaar is.',
    },
];
---

<section class="py-24 md:py-32 bg-chalk-light">
    <div class="container-prose">
        <div class="max-w-2xl mb-14 md:mb-16">
            <p class="eyebrow mb-4">Magazijn op orde</p>
            <h2 class="text-4xl md:text-5xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                Picklijsten die meedenken.
            </h2>
            <p class="mt-6 text-lg text-steel leading-relaxed">
                ShopLinkr bundelt orders tot één picklijst, berekent de kortste route en print het label automatisch zodra je klaar bent. Zo verwerk je meer bestellingen in dezelfde tijd, met minder fouten.
            </p>
        </div>

        <ul class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
            {
                features.map((feature) => (
                    <li class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-7 md:p-8 transition duration-300 ease-out hover:ring-chalk-darker hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-center h-14 w-14 rounded-2xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-6">
                            <i class={`${feature.icon} text-2xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                        </div>
                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug mb-2">
                            {feature.title}
                        </h3>
                        <p class="text-sm text-steel leading-relaxed">
                            {feature.body}
                        </p>
                    </li>
                ))
            }
        </ul>

        <a href="/functionaliteiten/pick-en-pack" class="group mt-10 inline-flex items-center gap-2 text-charcoal font-semibold">
            Lees meer over pick en pack
            <i class="fa-solid fa-arrow-right text-sm transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
        </a>
    </div>
</section>
