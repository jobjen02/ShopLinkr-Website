---
import { type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);

// Quote text is translated per locale via the dictionary (t.testimonials.quotes),
// indexed to this array; author/company/logo are locale-invariant.
const testimonials = [
    {
        author: 'Jasper de Waard',
        company: 'Schoongedaan',
        logo: '/testimonials/Schoongedaan.png',
    },
    {
        author: 'Tijn Zuijdervliet',
        company: 'Cryptoken',
        logo: '/testimonials/Cryptoken.svg',
    },
    {
        author: 'Nabodhi van der Lind',
        company: 'Cozy Design',
        logo: '/testimonials/CozyDesign.jpg',
    },
    {
        author: 'Nick Siep',
        company: 'Voordelig Inslaan',
        logo: '/testimonials/VoordeligInslaan.jpg',
    },
];
---

<section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
    <div class="container-prose">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-8 mb-12 md:mb-16">
            <div class="max-w-2xl">
                <p class="eyebrow mb-3">{t.testimonials.eyebrow}</p>
                <h2 class="text-4xl md:text-5xl font-semibold text-charcoal dark:text-paper tracking-tight">
                    {t.testimonials.heading}
                    <img
                        src="/flags/nl.png"
                        alt=""
                        aria-hidden="true"
                        loading="lazy"
                        class="inline-block h-6 md:h-8 w-auto ml-3"
                    />
                </h2>
                <p class="mt-6 text-lg text-steel dark:text-gravel leading-relaxed">
                    {t.testimonials.sub}
                </p>
            </div>

            <div class="flex items-center gap-3 text-sm">
                <span class="inline-flex items-center gap-0.5 text-sunstone-deep">
                    {Array.from({ length: 5 }).map(() => (
                        <i class="fa-solid fa-star text-[0.95rem]" aria-hidden="true"></i>
                    ))}
                </span>
                <span class="font-semibold text-charcoal dark:text-paper">{t.testimonials.rating}</span>
                <span class="text-gravel">{t.testimonials.ratingSuffix}</span>
            </div>
        </div>

        <div class="grid md:grid-cols-2 gap-5 md:gap-6">
            {
                testimonials.map((testimonial, i) => (
                    <article class="bg-paper dark:bg-charcoal rounded-2xl ring-1 ring-chalk-dark dark:ring-flint hover:ring-chalk-darker dark:hover:ring-steel transition-colors p-8 md:p-10 flex flex-col">
                        <p class="text-charcoal dark:text-paper leading-relaxed text-[1.0625rem] mb-8 flex-1">
                            {t.testimonials.quotes[i]}
                        </p>

                        <div class="flex items-center gap-4">
                            <div class="h-10 w-10 rounded-lg bg-paper dark:bg-paper ring-1 ring-chalk-dark dark:ring-flint flex items-center justify-center overflow-hidden flex-shrink-0">
                                <img
                                    src={testimonial.logo}
                                    alt={testimonial.company}
                                    class="h-full w-full object-contain p-1.5"
                                    loading="lazy"
                                />
                            </div>
                            <div class="min-w-0">
                                <p class="font-semibold text-charcoal dark:text-paper text-sm">{testimonial.author}</p>
                                <p class="text-xs text-gravel mt-0.5">{testimonial.company}</p>
                            </div>
                        </div>
                    </article>
                ))
            }
        </div>

        <div class="mt-12 flex justify-center">
            <a
                href="https://nl.trustpilot.com/review/shoplinkr.com"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-steel dark:text-gravel hover:text-charcoal dark:hover:text-paper transition-colors inline-flex items-center gap-1.5 min-h-11 py-2.5"
            >
                {t.testimonials.allReviews}
                <i class="fa-solid fa-arrow-up-right-from-square text-xs" aria-hidden="true"></i>
            </a>
        </div>
    </div>
</section>
