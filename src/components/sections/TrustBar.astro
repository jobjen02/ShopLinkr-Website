---
import { getCollection } from 'astro:content';
import { type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);

const all = (await getCollection('integrations'))
    .map((entry) => entry.data)
    .sort((a, b) => a.name.localeCompare(b.name));

const marketplacesAndWebshops = all.filter(
    (item) => item.category === 'marketplace' || item.category === 'webshop',
);

const carriers = all.filter(
    (item) => item.category === 'carrier' || item.category === 'other',
);

const FRONT_CARRIERS_COUNT = 5;
const SKIP_NEAR_MARKETPLACE = new Set(['bol-com-verzendlabels']);

const frontCarriers = carriers
    .filter((item) => !SKIP_NEAR_MARKETPLACE.has(item.slug))
    .slice(0, FRONT_CARRIERS_COUNT);

const frontSlugs = new Set(frontCarriers.map((item) => item.slug));

const restCarriers = carriers.filter((item) => !frontSlugs.has(item.slug));

const integrations = [
    ...frontCarriers,
    ...marketplacesAndWebshops,
    ...restCarriers,
];
---

<section class="border-y border-chalk-dark bg-paper py-14 md:py-16">
    <div class="container-prose">
        <p class="text-[11px] uppercase tracking-[0.22em] text-gravel font-semibold text-center mb-14">
            {t.trustBar.heading}
        </p>
    </div>

    <div class="marquee-wrapper">
        <div class="marquee-track">
            {
                [...integrations, ...integrations].map((integration) => (
                    <a
                        href={`/integraties/${integration.slug}`}
                        class="marquee-item"
                        aria-label={`${integration.name} integratie`}
                    >
                        <img
                            src={integration.logo}
                            alt={integration.name}
                            class="marquee-logo"
                            loading="lazy"
                        />
                    </a>
                ))
            }
        </div>
    </div>
</section>

<style>
    .marquee-wrapper {
        overflow: hidden;
        mask-image: linear-gradient(
            to right,
            transparent,
            black 12%,
            black 88%,
            transparent
        );
        -webkit-mask-image: linear-gradient(
            to right,
            transparent,
            black 12%,
            black 88%,
            transparent
        );
    }

    .marquee-track {
        display: flex;
        align-items: center;
        gap: 4.5rem;
        width: max-content;
        animation: marquee 80s linear infinite;
        padding-block: 0.5rem;
    }

    .marquee-wrapper:hover .marquee-track {
        animation-play-state: paused;
    }

    .marquee-item {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        height: 3.5rem;
        text-decoration: none;
        color: inherit;
    }

    .marquee-logo {
        height: 2.25rem;
        width: auto;
        max-width: 9rem;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    @media (min-width: 768px) {
        .marquee-logo {
            height: 2.75rem;
            max-width: 11rem;
        }

        .marquee-track {
            gap: 5rem;
        }

        .marquee-item {
            height: 4rem;
        }
    }

    .marquee-item:hover .marquee-logo {
        transform: scale(1.05);
    }

    @keyframes marquee {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .marquee-track {
            animation: none;
        }
    }
</style>
