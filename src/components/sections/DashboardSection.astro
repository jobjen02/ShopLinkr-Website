---
import DashboardPreview from '../product/DashboardPreview.astro';
import { type Locale } from '../../i18n/routes';
import { useTranslations } from '../../i18n/ui';

const locale = (Astro.currentLocale ?? 'nl') as Locale;
const t = useTranslations(locale);
---

<section class="py-24 md:py-32 bg-chalk-light dark:bg-graphite">
    <div class="container-prose">
        <div class="max-w-3xl mb-12 md:mb-16">
            <p class="eyebrow mb-3">{t.dashboard.eyebrow}</p>
            <h2 class="text-4xl md:text-5xl font-semibold text-charcoal dark:text-paper tracking-tight">
                {t.dashboard.headingLead}
                <span class="block text-sunstone-deep">{t.dashboard.headingTail}</span>
            </h2>
            <p class="mt-6 text-lg text-steel dark:text-gravel leading-relaxed">
                {t.dashboard.intro}
            </p>
        </div>
    </div>

    <div class="dashboard-shell">
        <div class="dashboard-viewport" data-dashboard-viewport>
            <div class="dashboard-frame" data-dashboard-frame>
                <DashboardPreview />
            </div>
        </div>
    </div>
</section>

<style>
    /* Desktop (>=1100px available): the 1100px dashboard fits, centered.
       Mobile/tablet: scale the whole dashboard down to fit the screen so it stays
       fully visible in its native proportions, with no horizontal scroll. */
    .dashboard-shell {
        position: relative;
        padding-inline: 1rem;
    }

    .dashboard-viewport {
        overflow: hidden;
    }

    .dashboard-frame {
        width: 1100px;
        margin-inline: auto;
        transform-origin: top left;
    }

    @media (min-width: 768px) {
        .dashboard-shell {
            padding-inline: 2rem;
        }
    }
</style>

<script>
    function fitDashboard() {
        const frame = document.querySelector('[data-dashboard-frame]') as HTMLElement | null;
        const viewport = document.querySelector('[data-dashboard-viewport]') as HTMLElement | null;
        if (!frame || !viewport) return;
        const design = 1100;
        const avail = viewport.clientWidth;
        const scale = Math.min(1, avail / design);
        if (scale < 1) {
            frame.style.transform = `scale(${scale})`;
            // offsetHeight is the un-scaled layout height; reserve the scaled height.
            viewport.style.height = `${frame.offsetHeight * scale}px`;
        } else {
            frame.style.transform = '';
            viewport.style.height = '';
        }
    }

    fitDashboard();
    window.addEventListener('load', fitDashboard);
    window.addEventListener('resize', fitDashboard);
    const vp = document.querySelector('[data-dashboard-viewport]');
    if (vp && 'ResizeObserver' in window) {
        new ResizeObserver(fitDashboard).observe(vp);
    }
</script>
