const year = new Date().getFullYear();
---

<footer class="bg-paper border-t border-chalk-dark">
    <div class="container-prose pt-20 pb-10">
        <div class="grid grid-cols-2 md:grid-cols-12 gap-x-8 gap-y-12 mb-16">
            <div class="col-span-2 md:col-span-4 md:pr-8">
                <a href="/" class="inline-block mb-5" aria-label="ShopLinkr home">
                    <img
                        src="/logo/logo-charcoal.svg"
                        alt="ShopLinkr"
                        width="140"
                        height="32"
                        class="h-7 w-auto"
                    />
                </a>
                <p class="text-sm leading-relaxed max-w-sm text-steel mb-7">
                    De Nederlandse magazijnsoftware voor webshops die door willen groeien. Eén platform voor voorraad, orders, labels en verzending.
                </p>

                <NewsletterSignup client:visible />

                <div class="mt-6 flex items-center gap-2">
                    {
                        socials.map((social) => (
                            <a
                                href={social.href}
                                aria-label={social.label}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group h-9 w-9 inline-flex items-center justify-center rounded-md ring-1 ring-chalk-dark hover:ring-sunstone-deep/40 hover:bg-sunstone-mist/40 transition-colors"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                    class="h-4 w-4 fill-gravel group-hover:fill-sunstone-deep transition-colors"
                                >
                                    <path d={social.path} />
                                </svg>
                            </a>
                        ))
                    }
                </div>
            </div>

            {
                sections.map((section) => (
                    <div class="md:col-span-2">
                        <h3 class="text-charcoal font-semibold text-sm mb-5">
                            {section.title}
                        </h3>
                        <ul class="space-y-3 text-sm">
                            {section.links.map((link) => (
                                <li>
                                    <a
                                        href={link.href}
                                        class="text-steel hover:text-sunstone-deep transition-colors"
                                    >
                                        {link.label}
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))
            }
        </div>

        <div class="pt-8 border-t border-chalk-dark flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-sm text-gravel">
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
                <p>© {year} ShopLinkr. Alle rechten voorbehouden.</p>
                <a
                    href="/privacy"
                    class="hover:text-charcoal transition-colors"
                >
                    Privacybeleid
                </a>
                <a
                    href="/voorwaarden"
                    class="hover:text-charcoal transition-colors"
                >
                    Voorwaarden
                </a>
                <a
                    href="/cookies"
                    class="hover:text-charcoal transition-colors"
                >
                    Cookies
                </a>
            </div>
            <p class="inline-flex items-center gap-1.5">
                Gemaakt in Nederland
                <img
                    src="https://flagcdn.com/160x120/nl.png"
                    width="16"
                    height="12"
                    loading="lazy"
                    class="h-3 w-auto rounded-[1px]"
                />
            </p>
        </div>
    </div>
</footer>
