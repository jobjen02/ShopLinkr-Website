---
import BaseLayout from './BaseLayout.astro';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
    title: string;
    description: string;
    heading: string;
    eyebrow?: string;
    image?: string;
    imageAlt?: string;
    meta?: string;
    backHref?: string;
    backLabel?: string;
    locale?: Locale;
    routeKey?: RouteKey;
    alternates?: { nl?: string; en?: string };
    jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
    title,
    description,
    heading,
    eyebrow,
    image,
    imageAlt,
    meta,
    backHref,
    backLabel,
    locale,
    routeKey,
    alternates,
    jsonLd,
} = Astro.props;
---

<BaseLayout
    title={title}
    description={description}
    image={image}
    locale={locale}
    routeKey={routeKey}
    alternates={alternates}
    jsonLd={jsonLd}
>
    <article class="pt-12 md:pt-16 pb-24 md:pb-32 bg-paper">
        <div class="container-prose">
            {backHref && backLabel && (
                <a
                    href={backHref}
                    class="inline-flex items-center gap-2 text-sm text-gravel hover:text-charcoal transition-colors mb-10"
                >
                    <i class="fa-solid fa-arrow-left text-xs" aria-hidden="true"></i>
                    {backLabel}
                </a>
            )}

            <header class="max-w-3xl">
                {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
                <h1 class="text-4xl md:text-5xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    {heading}
                </h1>
                {meta && (
                    <p class="mt-6 text-sm text-gravel">
                        {meta}
                    </p>
                )}
            </header>

            {image && (
                <div class="mt-12 max-w-4xl">
                    <img
                        src={image}
                        alt={imageAlt ?? ''}
                        class="w-full aspect-video object-cover rounded-2xl ring-1 ring-chalk-dark"
                        loading="eager"
                    />
                </div>
            )}

            <div class="prose-shoplinkr mt-12 max-w-3xl">
                <slot />
            </div>
        </div>
    </article>

    <slot name="after" />
</BaseLayout>

<style is:global>
    .prose-shoplinkr {
        color: var(--color-steel);
        font-size: 1.0625rem;
        line-height: 1.75;
    }

    .prose-shoplinkr > * + * {
        margin-top: 1.25em;
    }

    .prose-shoplinkr h2 {
        color: var(--color-charcoal);
        font-size: 1.75rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        line-height: 1.25;
        margin-top: 2.25em;
        margin-bottom: 0.5em;
    }

    .prose-shoplinkr h3 {
        color: var(--color-charcoal);
        font-size: 1.25rem;
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.35;
        margin-top: 1.75em;
        margin-bottom: 0.5em;
    }

    .prose-shoplinkr h4 {
        color: var(--color-charcoal);
        font-size: 1.0625rem;
        font-weight: 600;
        margin-top: 1.5em;
        margin-bottom: 0.4em;
    }

    .prose-shoplinkr p {
        margin: 1em 0;
    }

    .prose-shoplinkr a {
        color: var(--color-sunstone-deep);
        text-decoration: underline;
        text-decoration-color: var(--color-sunstone-soft);
        text-underline-offset: 3px;
        transition: text-decoration-color 0.15s ease;
    }

    .prose-shoplinkr a:hover {
        text-decoration-color: var(--color-sunstone-deep);
    }

    .prose-shoplinkr strong {
        color: var(--color-charcoal);
        font-weight: 600;
    }

    .prose-shoplinkr ul,
    .prose-shoplinkr ol {
        margin: 1.25em 0;
        padding-left: 1.5em;
    }

    .prose-shoplinkr ul > li {
        list-style-type: disc;
        margin: 0.4em 0;
        padding-left: 0.25em;
    }

    .prose-shoplinkr ul > li::marker {
        color: var(--color-sunstone-deep);
    }

    .prose-shoplinkr ol > li {
        list-style-type: decimal;
        margin: 0.4em 0;
        padding-left: 0.25em;
    }

    .prose-shoplinkr ol > li::marker {
        color: var(--color-gravel);
        font-weight: 600;
    }

    .prose-shoplinkr blockquote {
        border-left: 3px solid var(--color-sunstone);
        margin: 1.75em 0;
        padding: 0.25em 0 0.25em 1.5em;
        color: var(--color-charcoal);
        font-style: italic;
    }

    .prose-shoplinkr code {
        background-color: var(--color-chalk);
        color: var(--color-charcoal);
        padding: 0.15em 0.4em;
        border-radius: 0.375rem;
        font-family: var(--font-mono);
        font-size: 0.9em;
    }

    .prose-shoplinkr pre {
        background-color: var(--color-charcoal);
        color: var(--color-chalk);
        padding: 1.25em;
        border-radius: 0.75rem;
        overflow-x: auto;
        margin: 1.5em 0;
        font-family: var(--font-mono);
        font-size: 0.875rem;
        line-height: 1.6;
    }

    .prose-shoplinkr pre code {
        background-color: transparent;
        color: inherit;
        padding: 0;
    }

    .prose-shoplinkr img {
        margin: 1.75em 0;
        border-radius: 1rem;
        max-width: 100%;
        height: auto;
    }

    .prose-shoplinkr hr {
        border: 0;
        border-top: 1px solid var(--color-chalk-dark);
        margin: 2.5em 0;
    }
</style>
