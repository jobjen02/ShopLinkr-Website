---
import BaseLayout from './BaseLayout.astro';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
    title: string;
    description: string;
    eyebrow?: string;
    heading: string;
    subheading?: string;
    image?: string;
    locale?: Locale;
    routeKey?: RouteKey;
    jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
    title,
    description,
    eyebrow,
    heading,
    subheading,
    image,
    locale,
    routeKey,
    jsonLd,
} = Astro.props;
---

<BaseLayout
    title={title}
    description={description}
    image={image}
    locale={locale}
    routeKey={routeKey}
    jsonLd={jsonLd}
>
    <section class="relative bg-paper overflow-hidden">
        <div class="absolute inset-x-0 top-0 -z-0 pointer-events-none h-[600px]">
            <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[90%] h-full bg-[radial-gradient(ellipse_at_top,#faedd5,transparent_65%)] opacity-60"></div>
        </div>

        <div class="container-prose pt-16 md:pt-24 pb-12 md:pb-16 relative">
            {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-semibold text-charcoal tracking-tight leading-[1.05] max-w-4xl">
                {heading}
            </h1>
            {subheading && (
                <p class="mt-6 text-lg md:text-xl text-steel leading-relaxed max-w-2xl">
                    {subheading}
                </p>
            )}
        </div>
    </section>

    <slot />
</BaseLayout>
