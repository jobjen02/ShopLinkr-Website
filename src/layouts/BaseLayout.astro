---
import '../styles/global.css';
import BaseHead from '../components/seo/BaseHead.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieBanner from '../components/islands/CookieBanner.vue';
import type { Locale, RouteKey } from '../i18n/routes';
import { useTranslations } from '../i18n/ui';

interface Props {
    title: string;
    description: string;
    image?: string;
    locale?: Locale;
    routeKey?: RouteKey;
    alternates?: { nl?: string; en?: string };
    jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
    title,
    description,
    image,
    locale: localeProp,
    routeKey,
    alternates,
    jsonLd,
} = Astro.props;

// Locale is derived from the URL (NL at root, EN under /en/) so pages don't
// have to pass it. An explicit prop still wins if a page needs to override.
const locale: Locale = localeProp ?? (Astro.currentLocale as Locale) ?? 'nl';
const t = useTranslations(locale);

const organizationSchema = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'ShopLinkr',
    url: 'https://shoplinkr.com',
    logo: 'https://shoplinkr.com/logo/logo-charcoal.svg',
    description: t.footer.description,
    email: 'contact@shoplinkr.com',
    telephone: '+31649781212',
    address: {
        '@type': 'PostalAddress',
        addressCountry: 'NL',
    },
    sameAs: [
        'https://www.linkedin.com/company/shoplinkr',
        'https://www.instagram.com/shoplinkr',
        'https://nl.trustpilot.com/review/shoplinkr.com',
    ],
};

const websiteSchema = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'ShopLinkr',
    url: 'https://shoplinkr.com',
    inLanguage: locale === 'nl' ? 'nl-NL' : 'en-US',
    potentialAction: {
        '@type': 'SearchAction',
        target: {
            '@type': 'EntryPoint',
            urlTemplate: 'https://shoplinkr.com/support?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
    },
};
---

<!doctype html>
<html lang={locale}>
    <head>
        <script is:inline>
            // Set the theme before first paint to avoid a white flash.
            // localStorage `theme` is light/dark/auto; default is LIGHT (a
            // first-time visitor always lands in light, regardless of OS).
            // `auto` is still a selectable option that follows prefers-color-scheme.
            (function () {
                try {
                    var mode = localStorage.getItem('theme') || 'light';
                    var dark = mode === 'dark'
                        || (mode === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches);
                    document.documentElement.classList.toggle('dark', dark);
                } catch (e) {}
            })();
        </script>
        <BaseHead
            title={title}
            description={description}
            image={image}
            locale={locale}
            routeKey={routeKey}
            alternates={alternates}
        />
        <JsonLd schema={organizationSchema} />
        <JsonLd schema={websiteSchema} />
        {jsonLd && <JsonLd schema={jsonLd} />}
    </head>
    <body class="min-h-screen flex flex-col">
        <a
            href="#main"
            class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[200] focus:inline-flex focus:items-center focus:gap-2 focus:px-4 focus:py-2.5 focus:rounded-lg focus:bg-charcoal focus:text-paper dark:focus:bg-paper dark:focus:text-charcoal focus:text-sm focus:font-semibold focus:shadow-[0_8px_24px_-12px_rgba(25,25,25,0.40)]"
        >
            {t.common.skipToContent}
        </a>
        <Header alternates={alternates} />
        <main id="main" class="flex-1" tabindex="-1">
            <slot />
        </main>
        <Footer />
        <CookieBanner client:idle locale={locale} />
    </body>
</html>
