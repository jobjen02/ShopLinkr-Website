---
import '../styles/global.css';
import BaseHead from '../components/seo/BaseHead.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieBanner from '../components/islands/CookieBanner.vue';
import type { Locale, RouteKey } from '../i18n/routes';

interface Props {
    title: string;
    description: string;
    image?: string;
    locale?: Locale;
    routeKey?: RouteKey;
    jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
    title,
    description,
    image,
    locale: localeProp,
    routeKey,
    jsonLd,
} = Astro.props;

// Locale is derived from the URL (NL at root, EN under /en/) so pages don't
// have to pass it. An explicit prop still wins if a page needs to override.
const locale: Locale = localeProp ?? (Astro.currentLocale as Locale) ?? 'nl';

const organizationSchema = {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'ShopLinkr',
    url: 'https://shoplinkr.com',
    logo: 'https://shoplinkr.com/logo/logo-charcoal.svg',
    description: 'De Nederlandse magazijnsoftware voor webshops die door willen groeien. Eén platform voor voorraad, orders, labels en verzending.',
    email: 'contact@shoplinkr.com',
    telephone: '+31649781212',
    address: {
        '@type': 'PostalAddress',
        addressCountry: 'NL',
    },
    sameAs: [
        'https://www.linkedin.com/company/shoplinkr',
        'https://www.instagram.com/shoplinkr',
        'https://nl.trustpilot.com/review/shoplinkr.com',
    ],
};

const websiteSchema = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'ShopLinkr',
    url: 'https://shoplinkr.com',
    inLanguage: locale === 'nl' ? 'nl-NL' : 'en-US',
    potentialAction: {
        '@type': 'SearchAction',
        target: {
            '@type': 'EntryPoint',
            urlTemplate: 'https://shoplinkr.com/support?q={search_term_string}',
        },
        'query-input': 'required name=search_term_string',
    },
};
---

<!doctype html>
<html lang={locale}>
    <head>
        <BaseHead
            title={title}
            description={description}
            image={image}
            locale={locale}
            routeKey={routeKey}
        />
        <JsonLd schema={organizationSchema} />
        <JsonLd schema={websiteSchema} />
        {jsonLd && <JsonLd schema={jsonLd} />}
    </head>
    <body class="min-h-screen flex flex-col">
        <a
            href="#main"
            class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[200] focus:inline-flex focus:items-center focus:gap-2 focus:px-4 focus:py-2.5 focus:rounded-lg focus:bg-charcoal focus:text-paper focus:text-sm focus:font-semibold focus:shadow-[0_8px_24px_-12px_rgba(25,25,25,0.40)]"
        >
            Ga naar hoofdinhoud
        </a>
        <Header />
        <main id="main" class="flex-1" tabindex="-1">
            <slot />
        </main>
        <Footer />
        <CookieBanner client:idle locale={locale} />
    </body>
</html>
