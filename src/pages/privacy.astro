---
import PageLayout from '../layouts/PageLayout.astro';

const lastUpdated = '2026-05-28';

const sections = [
    {
        heading: 'Wie zijn wij?',
        body: 'ShopLinkr is een Nederlands bedrijf gevestigd in Nederland. We bouwen software waarmee webshops hun voorraad, bestellingen en verzending centraal beheren. Voor vragen over deze verklaring kun je ons bereiken via contact@shoplinkr.com of +31 6 49 78 12 12.',
    },
    {
        heading: 'Welke gegevens verwerken wij?',
        body: 'We verwerken alleen gegevens die je zelf bij ons aanlevert of die nodig zijn om onze dienst te leveren. Denk aan je naam, e-mailadres, telefoonnummer, bedrijfsgegevens, verkoopkanaal-koppelingen en de orderdata die door je verkoopkanalen worden aangeleverd.',
    },
    {
        heading: 'Waarvoor gebruiken we je gegevens?',
        body: 'We gebruiken je gegevens om je account te beheren, je orders te verwerken, je voorraad te synchroniseren met je kanalen, support te leveren, je te informeren over wijzigingen en onze dienst verder te ontwikkelen. We verkopen je gegevens nooit aan derden.',
    },
    {
        heading: 'Met wie delen we je gegevens?',
        body: 'We delen je gegevens met partijen die nodig zijn om onze dienst te leveren: hosting, e-mail, betalingen, klantenondersteuning en verzendpartners die jij activeert. Met al deze partijen sluiten we verwerkersovereenkomsten. We delen nooit gegevens met partijen buiten de EU zonder passende waarborgen.',
    },
    {
        heading: 'Hoe lang bewaren we je gegevens?',
        body: 'We bewaren je gegevens zolang je een actief account hebt en daarna nog 7 jaar in verband met fiscale bewaarplicht. Daarna verwijderen we je gegevens of maken we ze anoniem. Je kunt op elk moment een verzoek indienen om je gegevens eerder te verwijderen.',
    },
    {
        heading: 'Wat zijn je rechten?',
        body: 'Onder de AVG heb je het recht op inzage, correctie, verwijdering, beperking, bezwaar en gegevensoverdraagbaarheid. Je kunt deze rechten uitoefenen door contact met ons op te nemen via contact@shoplinkr.com. Je hebt ook altijd het recht om een klacht in te dienen bij de Autoriteit Persoonsgegevens.',
    },
    {
        heading: 'Cookies',
        body: 'We gebruiken cookies om de site te laten werken, om te begrijpen hoe je de site gebruikt en om je relevante content te tonen. Je kiest zelf welke cookies je accepteert via onze cookiebanner. Meer details vind je in ons cookiebeleid.',
    },
    {
        heading: 'Wijzigingen in deze verklaring',
        body: 'We werken deze verklaring bij wanneer dat nodig is. De meest recente versie staat altijd op deze pagina. Bij belangrijke wijzigingen informeren we je actief, bijvoorbeeld via e-mail of een melding in het platform.',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Privacybeleid | ShopLinkr',
    description: 'Hoe ShopLinkr omgaat met jouw persoonsgegevens. Inzicht in wat we verzamelen, waarom we het verzamelen en wat je rechten zijn.',
};

export const prerender = true;
---

<PageLayout
    title="Privacybeleid | ShopLinkr"
    description="Hoe ShopLinkr omgaat met jouw persoonsgegevens. Inzicht in wat we verzamelen, waarom we het verzamelen en wat je rechten zijn."
    eyebrow="Juridisch"
    heading="Privacybeleid."
    subheading="We gaan zorgvuldig om met jouw gegevens. Hier lees je precies hoe."
    jsonLd={jsonLd}
>
    <section class="py-16 md:py-24 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl">
                <p class="text-sm text-gravel mb-12">
                    Laatst bijgewerkt: {lastUpdated}
                </p>

                <div class="space-y-12">
                    {
                        sections.map((section) => (
                            <article>
                                <h2 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight mb-4">
                                    {section.heading}
                                </h2>
                                <p class="text-steel leading-relaxed text-[15px] md:text-base">
                                    {section.body}
                                </p>
                            </article>
                        ))
                    }
                </div>

                <div class="mt-16 pt-10 border-t border-chalk-dark">
                    <p class="text-sm text-gravel italic">
                        Vragen over je gegevens of dit beleid? Mail naar <a href="mailto:contact@shoplinkr.com" class="text-charcoal font-semibold hover:text-sunstone-deep transition-colors">contact@shoplinkr.com</a>.
                    </p>
                </div>
            </div>
        </div>
    </section>
</PageLayout>
