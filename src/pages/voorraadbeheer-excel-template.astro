---
import PageLayout from '../layouts/PageLayout.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { externalLinks } from '../data/externalLinks';

const rows = [
    {
        eyebrow: 'Waarom Excel',
        heading: 'Voor een eerste structuur is Excel prima.',
        body: 'Begin je net met een webshop of heb je nog maar een handjevol producten? Dan kan een Excel-template een prima beginpunt zijn. Je houdt aantallen bij, je voegt nieuwe producten toe en je hebt zicht op wat je nog hebt liggen, zonder dat je in software hoeft te investeren.',
        icon: 'fa-solid fa-file-excel',
    },
    {
        eyebrow: 'Wat zit erin',
        heading: 'Een sjabloon dat meteen werkt.',
        body: 'Onze template is opgebouwd zodat je direct aan de slag kunt. Producten invullen, aantallen bijhouden, inkoopprijzen invoeren en zien wat je marge per product is. Vul je gegevens in en je hebt meteen overzicht, zonder dat je zelf formules hoeft te bouwen.',
        icon: 'fa-solid fa-table',
    },
    {
        eyebrow: 'Hoe gebruik je het',
        heading: 'Downloaden, openen en aan de slag.',
        body: 'Download de template, open hem in Excel of Google Sheets, vul je producten en aantallen in en je bent klaar om bij te houden. Geen onboarding nodig, geen complexe instellingen. Je werkt vanaf de eerste minuut met een opgezette structuur.',
        icon: 'fa-solid fa-download',
    },
    {
        eyebrow: 'Wanneer is het te beperkt',
        heading: 'Excel houdt geen voorraad realtime kloppend.',
        body: 'Verkoop je via meerdere kanalen? Dan ben je continu cijfers aan het overtikken. Een spreadsheet weet niet wanneer er ergens een bestelling binnenkomt, en dat is precies waar oversells beginnen. Voor multi-channel verkoop heb je echt software nodig.',
        icon: 'fa-solid fa-triangle-exclamation',
    },
    {
        eyebrow: 'De volgende stap',
        heading: 'Wanneer je toe bent aan ShopLinkr.',
        body: 'Zodra je voorraadbeheer méér wordt dan een lijstje bijwerken, schakel je naar ShopLinkr. Je kanalen koppelen, je voorraad realtime synchroon houden en je orders centraal verwerken. De Excel-template helpt je tot dat moment, ShopLinkr helpt je daarna.',
        icon: 'fa-solid fa-arrow-right-long',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Voorraadbeheer Excel template - ShopLinkr',
    description: 'Download ons gratis inkoop excel template en verbeter je voorraadbeheer. Eenvoudig in gebruik en ideaal voor webshops die net beginnen.',
};

export const prerender = false;
---

<PageLayout
    title="Voorraadbeheer Excel | Voorraad Excel Template - ShopLinkr"
    description="Download ons gratis inkoop excel template en verbeter je voorraadbeheer. Eenvoudig in gebruik en ideaal voor webshops die net beginnen."
    eyebrow="Gratis download"
    heading="Gratis voorraadbeheer Excel template."
    subheading="Download een uitgewerkte Excel-template waarmee je direct aan de slag kunt. Ideaal voor webshops die nog geen voorraadbeheer software gebruiken."
    routeKey="inventoryExcel"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href="mailto:contact@shoplinkr.com?subject=Aanvraag%20voorraadbeheer%20Excel%20template"
                    class="btn btn-sunstone text-base"
                >
                    Template aanvragen
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
            <p class="mt-4 text-sm text-gravel">
                Stuur ons een mailtje en we sturen je de Excel-template direct toe. Geen drempel, geen aanmelding nodig.
            </p>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Over de template</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Wat de template voor je doet.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Een goede Excel-template is een prima beginpunt voor je voorraadadministratie. Wij hebben er één gemaakt waarmee je direct gestructureerd kunt werken, zonder dat je zelf formules of layouts hoeft te bouwen.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
