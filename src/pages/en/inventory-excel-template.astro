---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'Why Excel',
        heading: 'For a first bit of structure, Excel is just fine.',
        body: 'Just starting a webshop, or only managing a handful of products? Then an Excel template can be a perfectly good starting point. You track quantities, add new products and keep an eye on what you still have in stock, all without investing in software.',
        icon: 'fa-solid fa-file-excel',
    },
    {
        eyebrow: 'What you get',
        heading: 'A template that works right away.',
        body: 'Our template is set up so you can get going immediately. Enter products, track quantities, fill in purchase prices and see your margin per product. Add your details and you have an overview straight away, without building any formulas yourself.',
        icon: 'fa-solid fa-table',
    },
    {
        eyebrow: 'How to use it',
        heading: 'Download, open and get going.',
        body: 'Download the template, open it in Excel or Google Sheets, fill in your products and quantities and you are ready to start tracking. No onboarding needed, no complex settings. From the very first minute you work with a ready made structure.',
        icon: 'fa-solid fa-download',
    },
    {
        eyebrow: 'When it falls short',
        heading: 'Excel does not keep stock accurate in real time.',
        body: 'Selling across multiple channels? Then you are constantly retyping numbers. A spreadsheet has no idea when an order comes in somewhere, and that is exactly where oversells begin. For multi-channel selling you really need software.',
        icon: 'fa-solid fa-triangle-exclamation',
    },
    {
        eyebrow: 'The next step',
        heading: 'When you are ready for ShopLinkr.',
        body: 'As soon as your inventory management becomes more than updating a list, you switch to ShopLinkr. Connect your channels, keep your stock synchronised in real time and process your orders centrally. The Excel template helps you up to that point, ShopLinkr helps you after it.',
        icon: 'fa-solid fa-arrow-right-long',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Inventory management Excel template - ShopLinkr',
    description: 'Download our free purchasing Excel template and improve your inventory management. Easy to use and ideal for webshops that are just getting started.',
};

export const prerender = false;
---

<PageLayout
    title="Inventory Excel | Inventory Excel Template - ShopLinkr"
    description="Download our free purchasing Excel template and improve your inventory management. Easy to use and ideal for webshops that are just getting started."
    eyebrow="Free download"
    heading="Free inventory management Excel template."
    subheading="Download a ready made Excel template you can start using right away. Ideal for webshops that do not yet use inventory management software."
    routeKey="inventoryExcel"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href="mailto:contact@shoplinkr.com?subject=Aanvraag%20voorraadbeheer%20Excel%20template"
                    class="btn btn-sunstone text-base"
                >
                    Request template
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
            <p class="mt-4 text-sm text-gravel">
                Send us a quick email and we will send you the Excel template right away. No barriers, no sign up needed.
            </p>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">About the template</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    What the template does for you.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    A good Excel template is a perfectly good starting point for your inventory administration. We built one that lets you work in a structured way straight away, without building formulas or layouts yourself.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
