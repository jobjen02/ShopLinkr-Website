---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'What is it?',
        heading: 'Inventory management software, in short.',
        body: 'Inventory management software keeps track of how many units you have in stock for each product and makes sure that number stays accurate across all your sales channels at once. Sell something on Bol and Shopify sees it too. You no longer have to update anything by hand, and you never sell what you do not have.',
        icon: 'fa-solid fa-circle-question',
    },
    {
        eyebrow: 'Real-time sync',
        heading: 'Stock updates within seconds.',
        body: 'The moment an order comes in anywhere, ShopLinkr adjusts your stock instantly across every connected channel. Your channels always match what is physically on the shelf, even on busy sales days when orders pour in by the minute.',
        icon: 'fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Multi-channel',
        heading: 'One dashboard for all your channels.',
        body: 'All your sales channels can be connected out of the box. From a single dashboard you handle your orders, stock and returns, with your product list always in view. Switching between different management environments is a thing of the past.',
        icon: 'fa-solid fa-grip',
    },
    {
        eyebrow: 'Orders',
        heading: 'From order to shipped, in one place.',
        body: 'ShopLinkr gathers your orders from every channel. You print your pick and pack list, generate carrier labels and send your track and trace back without ever leaving your management environment. One way of working, no matter where the order came from.',
        icon: 'fa-solid fa-bag-shopping',
    },
    {
        eyebrow: 'Scalable',
        heading: 'Pricing that grows with you.',
        body: 'You pay for what you sell, not for empty features you never use anyway. Starting small is fine, and as soon as you grow ShopLinkr scales right along with you. Cancel monthly, with no long contracts or vendor lock-in.',
        icon: 'fa-solid fa-chart-line',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Inventory management software - ShopLinkr',
    description: 'Are you an e-commerce entrepreneur struggling to manage your stock? Look no further. Our inventory management software is designed to make your life easier.',
};

export const prerender = false;
---

<PageLayout
    title="Inventory management software - ShopLinkr"
    description="Are you an e-commerce entrepreneur struggling to manage your stock? Look no further. Our inventory management software is designed to make your life easier."
    eyebrow="Inventory management software"
    heading="Inventory management software that gives you your time back."
    subheading="Do you struggle daily with stock that no longer matches across your channels? ShopLinkr automates your inventory management and keeps all your channels in sync in real time."
    routeKey="inventorySoftware"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Why ShopLinkr</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Software that works the way you do.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Good inventory management software does not have to be complicated. ShopLinkr connects your channels, syncs your stock and brings calm to your daily work, so you have time left over for the things you became an entrepreneur for.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
