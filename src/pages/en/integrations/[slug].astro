---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import IntegrationDetailPage from '../../../components/pages/IntegrationDetailPage.astro';

export const getStaticPaths: GetStaticPaths = async () => {
    const integrations = await getCollection('integrationsEn');
    const supportArticles = await getCollection('supportArticlesEn');
    return integrations.map((integration) => ({
        params: {
            slug: integration.data.slug,
        },
        props: {
            integration,
            allIntegrations: integrations,
            supportArticles,
        },
    }));
};

const { integration, allIntegrations, supportArticles } = Astro.props;
const { name, category, summary, supportSlug } = integration.data;

const related = allIntegrations
    .filter((i) => i.data.category === category && i.data.slug !== integration.data.slug)
    .slice(0, 3);

// Resolve the NL supportSlug to its EN support article slug via translationKey.
const enSupportSlug = supportSlug
    ? supportArticles.find((a) => a.data.translationKey === supportSlug)?.id.split('/').pop()
    : undefined;
const supportHref = enSupportSlug ? `/en/support/${enSupportSlug}` : '/en/support';

const alternates = {
    nl: `/integraties/${integration.data.slug}`,
    en: `/en/integrations/${integration.data.slug}`,
};

const integrationSchema = {
    '@type': 'WebPage',
    name: `Connect ${name} to ShopLinkr`,
    description: summary,
    url: `https://shoplinkr.com/en/integrations/${integration.data.slug}`,
    inLanguage: 'en-US',
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com/en',
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: 'Integrations',
            item: 'https://shoplinkr.com/en/integrations',
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: `Connect ${name} to ShopLinkr`,
            item: `https://shoplinkr.com/en/integrations/${integration.data.slug}`,
        },
    ],
};

const faqs = integration.data.faqs;
const faqSchema = faqs && faqs.length > 0
    ? {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.q,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.a,
            },
        })),
    }
    : null;

const jsonLd = faqSchema
    ? [integrationSchema, breadcrumbSchema, faqSchema]
    : [integrationSchema, breadcrumbSchema];

export const prerender = true;
---

<IntegrationDetailPage
    integration={integration}
    related={related}
    relatedHref={(slug) => `/en/integrations/${slug}`}
    supportHref={supportHref}
    homeHref="/en"
    integrationsHref="/en/integrations"
    title={`Connect ${name} to ShopLinkr | Integrations`}
    description={summary}
    alternates={alternates}
    jsonLd={jsonLd}
/>
</content>
