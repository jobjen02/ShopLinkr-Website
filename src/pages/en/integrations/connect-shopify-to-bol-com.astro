---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import FaqList from '../../../components/template/FaqList.astro';
import { externalLinks } from '../../../data/externalLinks';
import { localizeHref } from '../../../i18n/routes';
const locale = 'en';

const rows = [
    {
        eyebrow: 'ShopLinkr as the bridge',
        heading: 'One platform between your Shopify and bol.',
        body: 'ShopLinkr sits between your Shopify webshop and your bol selling account. You connect both, and from that moment on they talk to each other through ShopLinkr. No separate connections to maintain, no exports in between.',
        icon: 'fa-solid fa-arrows-left-right-to-line',
    },
    {
        eyebrow: 'Matching on EAN',
        heading: 'Products are recognised automatically.',
        body: 'ShopLinkr links products in Shopify to the same products on bol based on their EAN. Set it up once and the system always knows which product belongs to which channel. New products are added in just a few clicks.',
        icon: 'fa-solid fa-barcode',
    },
    {
        eyebrow: 'Stock in sync',
        heading: 'Sold on bol, instantly lower on Shopify.',
        body: 'Sell a product on bol and ShopLinkr adjusts the stock in Shopify right away. The same the other way around. That way you keep one reliable stock level, even when you are selling fast on both channels. Your stock stays accurate across every channel, and your warehouse works from a single source of truth.',
        icon: 'fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Orders in one place',
        heading: 'Every order in the same order list.',
        body: 'Orders from Shopify and from bol come together in one overview in ShopLinkr. You pick, pack and ship from the same flow, no matter where the order came from. One workflow for your warehouse, even when you sell across more channels.',
        icon: 'fa-solid fa-list-check',
    },
    {
        eyebrow: 'No oversells',
        heading: 'Never sell what you do not have.',
        body: 'Because stock moves in real time between your channels, you never accidentally sell the same last product twice. Fewer cancellations, happier customers and no selling penalties on bol.',
        icon: 'fa-solid fa-shield-check',
    },
];

const dayInLife = [
    {
        time: '08:30',
        title: 'Orders in',
        body: 'Your warehouse opens. ShopLinkr shows last night\'s orders from Shopify and your bol selling account neatly in one list, sorted by urgency.',
    },
    {
        time: '09:00',
        title: 'Picking from one list',
        body: 'You pick from a single pick list for the whole team. It does not matter whether an order came in through Shopify or bol, the route through your warehouse is the same.',
    },
    {
        time: '11:00',
        title: 'Shipments out',
        body: 'The label is printed automatically and the track and trace flows back to both Shopify and bol. Your customers see the status without you having to do a thing.',
    },
    {
        time: '15:45',
        title: 'Stock revisited',
        body: 'In the meantime you sold the same sneaker 4 times on bol. Shopify was updated long ago, without anyone adjusting anything by hand.',
    },
];

const faqs = [
    {
        question: 'Does the connection work with multiple bol selling accounts?',
        answer: 'Yes. You connect each selling account separately to ShopLinkr and decide per account which products you share. Have an NL and a BE account? You simply manage them side by side in the same environment.',
    },
    {
        question: 'How fast does stock move between Shopify and bol?',
        answer: 'A new order in your Shopify shop or on bol leads to a stock update on the other channel almost immediately. In practice that comes down to a few seconds.',
    },
    {
        question: 'What is the first step?',
        answer: 'Create a ShopLinkr account, connect your Shopify webshop in a few clicks, and then your bol selling account. We have step-by-step guides for both and you do not need a developer.',
    },
];

const jsonLd = [
    {
        '@type': 'WebPage',
        name: 'Connect Shopify to bol via ShopLinkr',
        description: 'Selling through Shopify and bol? ShopLinkr keeps your stock in sync in real time and gathers every order in one overview. One workflow, no oversells.',
        url: 'https://shoplinkr.com/en/integrations/connect-shopify-to-bol-com',
    },
    {
        '@type': 'BreadcrumbList',
        itemListElement: [
            {
                '@type': 'ListItem',
                position: 1,
                name: 'Home',
                item: 'https://shoplinkr.com',
            },
            {
                '@type': 'ListItem',
                position: 2,
                name: 'Integrations',
                item: 'https://shoplinkr.com/en/integrations',
            },
            {
                '@type': 'ListItem',
                position: 3,
                name: 'Connect Shopify to bol',
                item: 'https://shoplinkr.com/en/integrations/connect-shopify-to-bol-com',
            },
        ],
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Connect Shopify to bol via ShopLinkr | Integrations"
    description="Selling through Shopify and bol? ShopLinkr keeps your stock in sync in real time and gathers every order in one overview. One workflow, no oversells."
    eyebrow="Shopify and bol"
    heading="Connect Shopify with bol via ShopLinkr."
    subheading="Selling through Shopify and through bol? ShopLinkr keeps your stock in sync in real time and gathers every order in one place. One workflow, no oversells."
    routeKey="integrations.shopifyBol"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <nav aria-label="Breadcrumb" class="mb-8">
                <ol class="flex flex-wrap items-center gap-2 text-sm text-gravel">
                    <li>
                        <a href={localizeHref('/', locale)} class="hover:text-charcoal transition-colors">Home</a>
                    </li>
                    <li aria-hidden="true">
                        <i class="fa-solid fa-chevron-right text-[9px]"></i>
                    </li>
                    <li>
                        <a href={localizeHref('/integraties', locale)} class="hover:text-charcoal transition-colors">Integrations</a>
                    </li>
                    <li aria-hidden="true">
                        <i class="fa-solid fa-chevron-right text-[9px]"></i>
                    </li>
                    <li class="text-charcoal font-medium" aria-current="page">
                        Connect Shopify to bol
                    </li>
                </ol>
            </nav>

            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Stock synchronisation</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    One stock source for Shopify and bol.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    ShopLinkr connects your Shopify webshop with your bol selling account. Stock changes flow both ways, orders come together in one place. Below you can see how the connection works.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-chalk-light/60">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-14">
                <p class="eyebrow mb-4">A day in your warehouse</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    This is how the Shopify + bol flow feels.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    A typical day, from the moment your warehouse opens to the last pickup. Without two tabs, without duplicate pick lists.
                </p>
            </div>

            <ol class="grid sm:grid-cols-2 gap-4 md:gap-5">
                {
                    dayInLife.map((step) => (
                        <li class="relative bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7">
                            <div class="flex items-baseline gap-3 mb-3">
                                <span class="text-xs font-mono font-semibold text-sunstone-deep tracking-wider">{step.time}</span>
                                <span class="h-px flex-1 bg-chalk-dark"></span>
                            </div>
                            <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight mb-2">
                                {step.title}
                            </h3>
                            <p class="text-sm text-steel leading-relaxed">
                                {step.body}
                            </p>
                        </li>
                    ))
                }
            </ol>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl">
                <p class="eyebrow mb-4">Frequently asked questions</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1] mb-10">
                    What you still want to know.
                </h2>

                <FaqList items={faqs} />
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
