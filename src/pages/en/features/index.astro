---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../../data/externalLinks';
import { breadcrumbs } from '../../../utils/seo';
import { localizeHref } from '../../../i18n/routes';

const locale = 'en';

interface Pillar {
    eyebrow: string;
    heading: string;
    body: string;
    accent: 'paper' | 'chalk';
    features: Array<{
        title: string;
        href: string;
        icon: string;
    }>;
}

const pillars: Array<Pillar> = [
    {
        eyebrow: 'Orders & shipping',
        heading: 'From order to shipment.',
        body: 'Orders from all your sales channels land in a single overview. Pick along a smart route through your warehouse, print labels for every connected carrier and handle returns without the hassle.',
        accent: 'paper',
        features: [
            {
                title: 'Orders',
                href: localizeHref('/functionaliteiten/bestellingen', locale),
                icon: 'fa-solid fa-receipt',
            },
            {
                title: 'Pick lists',
                href: localizeHref('/functionaliteiten/picklijsten', locale),
                icon: 'fa-solid fa-clipboard-list',
            },
            {
                title: 'Carriers',
                href: localizeHref('/functionaliteiten/vervoerders', locale),
                icon: 'fa-solid fa-truck',
            },
            {
                title: 'Returns',
                href: localizeHref('/functionaliteiten/retouren', locale),
                icon: 'fa-solid fa-arrow-rotate-left',
            },
        ],
    },
    {
        eyebrow: 'Inventory & warehouse',
        heading: 'Real-time control over your products and your warehouse.',
        body: 'One central inventory for all your sales channels. Warehouse locations per product, purchase advice based on sales data, deliveries that grow your inventory instantly and bundles that keep themselves up to date.',
        accent: 'chalk',
        features: [
            {
                title: 'Inventory',
                href: localizeHref('/functionaliteiten/voorraad', locale),
                icon: 'fa-solid fa-boxes-stacked',
            },
            {
                title: 'Products',
                href: localizeHref('/functionaliteiten/producten', locale),
                icon: 'fa-solid fa-tag',
            },
            {
                title: 'Location management',
                href: localizeHref('/functionaliteiten/locatiebeheer', locale),
                icon: 'fa-solid fa-location-dot',
            },
            {
                title: 'Purchase advice',
                href: localizeHref('/functionaliteiten/inkoopadvies', locale),
                icon: 'fa-solid fa-lightbulb',
            },
            {
                title: 'Deliveries',
                href: localizeHref('/functionaliteiten/leveringen', locale),
                icon: 'fa-solid fa-truck-ramp-box',
            },
        ],
    },
    {
        eyebrow: 'Automate & manage',
        heading: 'Automation, reports and user management.',
        body: 'Set rules for recurring work, read your figures from fixed reports, manage customer data from one place and invite colleagues with the role that fits them.',
        accent: 'paper',
        features: [
            {
                title: 'Rules',
                href: localizeHref('/functionaliteiten/regels', locale),
                icon: 'fa-solid fa-bolt',
            },
            {
                title: 'Reports',
                href: localizeHref('/functionaliteiten/rapporten', locale),
                icon: 'fa-solid fa-chart-line',
            },
            {
                title: 'Customers',
                href: localizeHref('/functionaliteiten/klanten', locale),
                icon: 'fa-solid fa-users',
            },
            {
                title: 'Users',
                href: localizeHref('/functionaliteiten/gebruikers', locale),
                icon: 'fa-solid fa-user-plus',
            },
        ],
    },
];

const jsonLd = [
    breadcrumbs([
        ['Home', '/en'],
        ['Features', '/en/features'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Features | ShopLinkr',
        description: 'All ShopLinkr features at a glance. From order processing and shipping to inventory, purchasing and automation.',
    },
];

export const prerender = false;
---

<PageLayout
    title="Features | ShopLinkr"
    description="All ShopLinkr features at a glance. From order processing and shipping to inventory, purchasing and automation."
    eyebrow="The complete platform"
    heading="Everything you need, in one system."
    subheading="Process orders, sync inventory, plan purchasing and run your team. ShopLinkr brings your entire warehouse operation together in one workspace."
    routeKey="features"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    {
        pillars.map((pillar) => (
            <section class={`py-24 md:py-32 ${pillar.accent === 'chalk' ? 'bg-chalk-light' : 'bg-paper'}`}>
                <div class="container-prose">
                    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                        <div class="lg:col-span-5">
                            <p class="eyebrow mb-5">{pillar.eyebrow}</p>
                            <h2 class="text-3xl md:text-4xl lg:text-[2.75rem] font-semibold text-charcoal tracking-tight leading-[1.1]">
                                {pillar.heading}
                            </h2>
                            <p class="mt-6 text-base md:text-lg text-steel leading-relaxed">
                                {pillar.body}
                            </p>
                        </div>

                        <div class="lg:col-span-7">
                            <ul class="grid sm:grid-cols-2 gap-3">
                                {pillar.features.map((feature) => (
                                    <li>
                                        <a
                                            href={feature.href}
                                            class="group flex items-center gap-4 bg-paper rounded-xl ring-1 ring-chalk-dark hover:ring-sunstone-soft hover:bg-sunstone-mist/30 px-5 py-4 transition-all duration-200"
                                        >
                                            <span class="flex-shrink-0 inline-flex items-center justify-center h-10 w-10 rounded-lg bg-chalk-light text-gravel group-hover:bg-sunstone-mist group-hover:text-sunstone-deep transition-colors">
                                                <i class={`${feature.icon} text-sm`} aria-hidden="true"></i>
                                            </span>
                                            <span class="flex-1 text-[15px] font-medium text-charcoal group-hover:text-sunstone-deep transition-colors">
                                                {feature.title}
                                            </span>
                                            <i class="fa-solid fa-arrow-right text-xs text-gravel group-hover:text-sunstone-deep group-hover:translate-x-0.5 transition-all" aria-hidden="true"></i>
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                </div>
            </section>
        ))
    }

    <CtaBanner />
</PageLayout>
