---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import FaqList from '../../../components/template/FaqList.astro';
import { externalLinks } from '../../../data/externalLinks';
import { breadcrumbs } from '../../../utils/seo';
import { faqsByPageEn } from '../../../data/faqs-en';
import { localizeHref } from '../../../i18n/routes';

const locale = 'en';

const subFeatures = [
    {
        eyebrow: 'Conditions',
        heading: 'Decide for yourself when a rule applies.',
        body: 'Choose from dozens of conditions, such as sales channel, total weight, total amount, number of products, country, postal code, a specific product, a tag or the shipping method.',
        icon: 'fa-duotone fa-solid fa-filter',
    },
    {
        eyebrow: 'Actions',
        heading: 'Decide what happens automatically.',
        body: 'Think of setting a shipping option, adding a tag or marking an order as high priority. And much more.',
        icon: 'fa-duotone fa-solid fa-bolt',
    },
    {
        eyebrow: 'Combine',
        heading: 'Everything has to match, or one is enough.',
        body: 'Group conditions however you like. Per group you choose whether all conditions have to match, or whether one is already enough. That way you catch a specific combination, or several situations at once.',
        icon: 'fa-duotone fa-solid fa-diagram-project',
    },
    {
        eyebrow: 'Order',
        heading: 'You decide which rule comes first.',
        body: 'Rules are processed in the order you set. Per rule you choose whether the following rules are still checked, or whether it stops here as soon as this rule applies.',
        icon: 'fa-duotone fa-solid fa-list-ol',
    },
];

const ruleExamples = [
    {
        title: 'PostNL for letterbox parcels',
        condition: 'The total weight is below 2 kilos and the country is the Netherlands.',
        action: 'Set the shipping option to PostNL Brievenbus.',
    },
    {
        title: 'A gift with large orders',
        condition: 'The total amount is higher than € 75.',
        action: 'Automatically add a free sample to the order.',
    },
    {
        title: 'Orders with many products',
        condition: 'The order contains more than 10 products.',
        action: 'Keep the order out of automatic processing, so you can check it yourself first.',
    },
];

const faqs = faqsByPageEn.regels;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Features', '/en/features'],
        ['Rules', '/en/features/rules'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Setting up automatic rules with ShopLinkr',
        description: 'Automate your order processing with rules. Set conditions on sales channel, total weight or country and let ShopLinkr carry out the right actions on every new order.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Setting up rules with ShopLinkr"
    description="Automate your order processing with rules. Set conditions on sales channel, total weight or country and let ShopLinkr carry out the right actions on every new order."
    eyebrow="Automation"
    heading="Let ShopLinkr do the work."
    subheading="Build a rule with conditions and actions. On every new order ShopLinkr picks the right carrier, applies the right tag or marks the order as high priority. You set it up once and from then on it runs by itself."
    routeKey="features.rules"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Automate decisions</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            One condition, one action,
                            <span class="block">ShopLinkr handles the rest.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 flex flex-col gap-5 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center gap-3">
                            <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class="fa-solid fa-filter text-[0.7rem]" aria-hidden="true"></i>
                            </span>
                            <span class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">If</span>
                        </div>
                        <div class="flex flex-wrap items-center gap-2 text-sm">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-chalk-light ring-1 ring-chalk-dark font-medium text-charcoal">Total weight</span>
                            <span class="text-gravel font-mono text-xs">&lt;</span>
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-chalk-light ring-1 ring-chalk-dark font-medium text-charcoal tabular-nums">2 kilos</span>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">and</span>
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-chalk-light ring-1 ring-chalk-dark font-medium text-charcoal">Country</span>
                            <span class="text-gravel font-mono text-xs">=</span>
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-chalk-light ring-1 ring-chalk-dark font-medium text-charcoal">Netherlands</span>
                        </div>

                        <div class="flex justify-center py-1">
                            <i class="fa-solid fa-arrow-down text-gravel text-sm" aria-hidden="true"></i>
                        </div>

                        <div class="flex items-center gap-3">
                            <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class="fa-solid fa-bolt text-[0.7rem]" aria-hidden="true"></i>
                            </span>
                            <span class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">Then</span>
                        </div>
                        <div class="flex flex-wrap items-center gap-2 text-sm">
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-charcoal text-paper font-medium">Shipping option</span>
                            <span class="text-gravel font-mono text-xs">→</span>
                            <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-charcoal text-paper font-medium">PostNL Brievenbus</span>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Set it up once. From then on it runs on every new order.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Frequently used rules</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Three examples
                        <span class="block text-sunstone-deep">to start with.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        A rule consists of a condition and an action. Here are three examples you can get going with right after you start.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            ruleExamples.map((example) => (
                                <li class="py-7 flex flex-col gap-4">
                                    <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{example.title}</h3>
                                    <div class="grid sm:grid-cols-[auto_1fr] gap-x-4 gap-y-3 text-[0.975rem]">
                                        <span class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel pt-1">
                                            <i class="fa-solid fa-filter text-sunstone-deep text-xs" aria-hidden="true"></i>
                                            If
                                        </span>
                                        <p class="text-steel leading-relaxed">{example.condition}</p>
                                        <span class="inline-flex items-center gap-2 text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel pt-1">
                                            <i class="fa-solid fa-bolt text-sunstone-deep text-xs" aria-hidden="true"></i>
                                            Then
                                        </span>
                                        <p class="text-steel leading-relaxed">{example.action}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Questions that come up often,
                        <span class="block text-sunstone-deep">answered clearly.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Missing a question? Schedule a call or send a message. We're happy to think along about your situation.
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Ask your question
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
