---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import FaqList from '../../../components/template/FaqList.astro';
import { externalLinks } from '../../../data/externalLinks';
import { breadcrumbs } from '../../../utils/seo';
import { faqsByPageEn } from '../../../data/faqs-en';
import { localizeHref } from '../../../i18n/routes';

const locale = 'en';

const subFeatures = [
    {
        eyebrow: 'Spot the differences',
        heading: 'See straight away where the packing slip is off.',
        body: 'While you receive a delivery, the expected and the actual quantities sit side by side. If less comes in than you ordered, you notice it right away and can get in touch with your supplier.',
        icon: 'fa-duotone fa-solid fa-scale-balanced',
    },
    {
        eyebrow: 'Location per line',
        heading: 'Decide per line where the stock goes.',
        body: 'Not everything from a single delivery goes to the same spot in your warehouse. While receiving, you assign each line its own warehouse location or zone, so the stock lands in the right places straight away.',
        icon: 'fa-duotone fa-solid fa-warehouse',
    },
    {
        eyebrow: 'Releasing backorders',
        heading: 'Backorders are released on their own.',
        body: 'Are there backorders open for products in the delivery? As soon as you receive them, those orders jump back to Open and you can simply pick and ship them.',
        icon: 'fa-duotone fa-solid fa-clock-rotate-left',
    },
    {
        eyebrow: 'From purchasing advice',
        heading: 'From advice to delivery in one click.',
        body: 'Working with purchasing advice? Turn it into deliveries per supplier in one go. They are ready as a draft to order from your supplier.',
        icon: 'fa-duotone fa-solid fa-wand-magic-sparkles',
    },
];

const workflowSteps = [
    {
        title: 'Create a delivery',
        body: 'Pick the supplier, fill in a reference and expected delivery date and add the products you expect. Or turn a purchasing advice into deliveries per supplier in one click.',
    },
    {
        title: 'Mark as purchased',
        body: 'Ordered from your supplier? Set the delivery to Purchased. From that moment it is ready to be received.',
    },
    {
        title: 'Receive products',
        body: 'Per line you indicate what has come in and to which location it goes. Want to scan? With a barcode scanner ShopLinkr recognises the product by its EAN code and counts it automatically. Your stock is updated right away across all your sales channels.',
    },
    {
        title: 'Complete the delivery',
        body: 'Done receiving? Mark the delivery as Processed. Products that did not come in stay visible under Not received, so you can look back later at what was missing.',
    },
];

const faqs = faqsByPageEn.leveringen;

const jsonLd = [
    breadcrumbs([
        ['Home', '/en'],
        ['Features', '/en/features'],
        ['Deliveries', '/en/features/deliveries'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Track deliveries with ShopLinkr',
        description: 'Manage incoming deliveries in ShopLinkr. Register what you expect, check quantities on receipt and watch your stock update right away across all your sales channels.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Track deliveries with ShopLinkr"
    description="Manage incoming deliveries in ShopLinkr. Register what you expect, check quantities on receipt and watch your stock update right away across all your sales channels."
    eyebrow="Incoming deliveries"
    heading="From packing slip to stock without counting."
    subheading="Record what arrives from your supplier, receive it line by line and your stock moves straight on to all your sales channels."
    routeKey="features.deliveries"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Control on receipt</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Expected and received,
                            <span class="block">side by side in view.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <div class="flex items-center gap-2.5">
                                <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-truck-ramp-box text-[0.7rem]" aria-hidden="true"></i>
                                </span>
                                <div class="flex flex-col">
                                    <span class="text-sm font-semibold text-charcoal">L-2026-148</span>
                                    <span class="text-[11px] text-gravel">Noorderlicht Goederen</span>
                                </div>
                            </div>
                            <span class="inline-flex items-center gap-1.5 px-2 py-1 rounded-md bg-sunstone-mist text-sunstone-deep text-[10px] uppercase tracking-[0.12em] font-semibold ring-1 ring-sunstone-soft/40">
                                <span class="h-1.5 w-1.5 rounded-full bg-sunstone-deep"></span>
                                Processing
                            </span>
                        </div>

                        <ul class="space-y-2 mb-4">
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex flex-col min-w-0">
                                    <span class="text-sm text-charcoal font-medium truncate">T-shirt Classic White M</span>
                                    <span class="text-[11px] text-gravel">B.4</span>
                                </div>
                                <div class="flex items-center gap-2 flex-shrink-0">
                                    <span class="text-xs text-gravel tabular-nums">100</span>
                                    <i class="fa-solid fa-arrow-right text-gravel text-[10px]" aria-hidden="true"></i>
                                    <span class="text-xs text-charcoal font-semibold tabular-nums">100</span>
                                    <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                                </div>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                                <div class="flex flex-col min-w-0">
                                    <span class="text-sm text-charcoal font-medium truncate">Bluetooth earbuds Onyx</span>
                                    <span class="text-[11px] text-gravel">A.2</span>
                                </div>
                                <div class="flex items-center gap-2 flex-shrink-0">
                                    <span class="text-xs text-gravel tabular-nums">50</span>
                                    <i class="fa-solid fa-arrow-right text-gravel text-[10px]" aria-hidden="true"></i>
                                    <span class="text-xs text-sunstone-deep font-semibold tabular-nums">45</span>
                                    <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-sunstone-deep">5 to go</span>
                                </div>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex flex-col min-w-0">
                                    <span class="text-sm text-charcoal font-medium truncate">Set of wheel covers 16 inch</span>
                                    <span class="text-[11px] text-gravel">C.1</span>
                                </div>
                                <div class="flex items-center gap-2 flex-shrink-0">
                                    <span class="text-xs text-gravel tabular-nums">20</span>
                                    <i class="fa-solid fa-arrow-right text-gravel text-[10px]" aria-hidden="true"></i>
                                    <span class="text-xs text-charcoal font-semibold tabular-nums">20</span>
                                    <i class="fa-solid fa-check text-sunstone-deep text-xs" aria-hidden="true"></i>
                                </div>
                            </li>
                        </ul>

                        <div class="flex items-center gap-2.5 pt-3 border-t border-chalk-darker">
                            <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                <i class="fa-solid fa-clock-rotate-left text-[0.65rem]" aria-hidden="true"></i>
                            </span>
                            <p class="text-[12px] text-charcoal leading-snug">
                                <span class="font-semibold">14 backorders</span> <span class="text-steel">released, stock is on all channels right away.</span>
                            </p>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Whatever has not come in stays under Expected, ready for the next receipt.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">How a delivery flows</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        From order with your supplier
                        <span class="block text-sunstone-deep">to stock on the shelf.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Every incoming delivery runs through the same four steps in ShopLinkr. Clear for your warehouse and easy to hand over to your team.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ol class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            workflowSteps.map((step, index) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5 text-sm font-semibold">
                                        {index + 1}
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{step.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{step.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Questions that come up often,
                        <span class="block text-sunstone-deep">answered clearly.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Missing a question? Book a call or send us a message. We are happy to think along with your situation.
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Ask your question
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
