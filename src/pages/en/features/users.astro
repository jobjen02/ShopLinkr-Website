---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import FaqList from '../../../components/template/FaqList.astro';
import { externalLinks } from '../../../data/externalLinks';
import { breadcrumbs } from '../../../utils/seo';
import { faqsByPageEn } from '../../../data/faqs-en';
import { localizeHref } from '../../../i18n/routes';
const locale = 'en';

const subFeatures = [
    {
        eyebrow: 'Roles and permissions',
        heading: 'Everyone sees exactly what their job involves.',
        body: 'Five standard roles for management, warehouse, administration, customer service and purchasing. On top of that you can create your own roles and decide, per section, who may view, create, edit or delete.',
        icon: 'fa-duotone fa-solid fa-user-shield',
    },
    {
        eyebrow: 'Invite by email',
        heading: 'A colleague joins in a few clicks.',
        body: 'Enter the email address, pick a role and click invite. Your colleague gets an email, chooses their own password and logs straight into the same workspace.',
        icon: 'fa-duotone fa-solid fa-envelope-open-text',
    },
    {
        eyebrow: 'QR login for the warehouse',
        heading: 'Log in fast at a shared packing station.',
        body: 'Warehouse staff scan their personal QR code and type in a four digit pincode. Ideal for packing stations where several people work behind the same computer.',
        icon: 'fa-duotone fa-solid fa-qrcode',
    },
    {
        eyebrow: 'Two factor authentication',
        heading: 'An extra lock on your accounts.',
        body: 'Enable 2FA per user with Google Authenticator, Microsoft Authenticator, Authy or 1Password. Combine it with QR login and you enter your code after the scan for extra peace of mind.',
        icon: 'fa-duotone fa-solid fa-shield-halved',
    },
];

const permissionTypes = [
    {
        title: 'View',
        body: 'The user may look at data but not change anything. Handy for roles that only need to follow along, such as an intern or an external bookkeeper.',
    },
    {
        title: 'Create',
        body: 'The user may add new items within a section. Think of creating a new order, adding a product or recording a supplier.',
    },
    {
        title: 'Edit',
        body: 'The user may change existing data. Think of correcting an address on an order, updating an order or making a stock correction.',
    },
    {
        title: 'Delete',
        body: 'The user may remove items from ShopLinkr for good. You usually grant this right only to roles that need full control.',
    },
];

const faqs = faqsByPageEn.gebruikers;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Features', '/en/features'],
        ['Users', '/en/features/users'],
    ]),
    {
        '@type': 'WebPage',
        name: 'User management, roles and permissions with ShopLinkr',
        description: 'Work together with your whole team in ShopLinkr. Invite colleagues, give them a role and decide per section who may do what. Add as many users as you like, with no extra cost per user.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Users, roles and permissions with ShopLinkr"
    description="Work together with your whole team in ShopLinkr. Invite colleagues, give them a role and decide per section who may do what. Add as many users as you like, with no extra cost per user."
    eyebrow="Team & access"
    heading="Work together with your whole team."
    subheading="Invite colleagues and give them the right role, then everyone works in the same workspace. That way every team member sees and does exactly what their job involves."
    routeKey="features.users"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Who can do what?</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Everyone on board,
                            <span class="block">each with their own rights.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)] overflow-x-auto">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">
                                Permissions per role
                            </p>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">Example</span>
                        </div>

                        <div class="grid grid-cols-[1fr_auto_auto_auto_auto] items-center gap-x-2 sm:gap-x-3 gap-y-2 text-sm min-w-[300px]">
                            <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-gravel"></span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">View</span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">Create</span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">Edit</span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">Delete</span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-user-shield text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Administrator</span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="View allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Create allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Edit allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Delete allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-chalk-light text-steel ring-1 ring-chalk-dark">
                                    <i class="fa-solid fa-boxes-packing text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Warehouse</span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="View allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Create allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Edit allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Delete not allowed">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-chalk-light text-steel ring-1 ring-chalk-dark">
                                    <i class="fa-solid fa-headset text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Customer service</span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="View allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Create allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Edit allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Delete not allowed">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-sunstone-mist/60 text-sunstone-deep ring-1 ring-sunstone-soft/60">
                                    <i class="fa-solid fa-user-plus text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Intern <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-sunstone-deep ml-1">custom role</span></span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="View allowed">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Create not allowed">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Edit not allowed">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Delete not allowed">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>
                        </div>

                        <div class="flex items-center justify-between gap-3 pt-4 mt-4 border-t border-chalk-darker">
                            <span class="text-sm font-semibold text-charcoal">Users</span>
                            <span class="inline-flex items-baseline gap-1.5">
                                <i class="fa-solid fa-infinity text-sunstone-deep text-base" aria-hidden="true"></i>
                                <span class="text-sm font-semibold text-sunstone-deep">no cost per user</span>
                            </span>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Start with five standard roles and create your own roles for anyone who needs something a little different.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Permissions per section</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Four kinds of permissions,
                        <span class="block text-sunstone-deep">exactly the right access.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        For each section of ShopLinkr, such as orders, products, stock and settings, you decide what a role may do. Combine the permissions into a role that fits your team member's responsibility.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            permissionTypes.map((type) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-key text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{type.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{type.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        The questions that keep coming up,
                        <span class="block text-sunstone-deep">clearly answered.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Is your question missing? Schedule a call or send us a message. We are happy to think along about your situation.
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Ask your question
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
