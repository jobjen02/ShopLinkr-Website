---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import FaqList from '../../../components/template/FaqList.astro';
import { externalLinks } from '../../../data/externalLinks';
import { breadcrumbs } from '../../../utils/seo';
import { faqsByPageEn } from '../../../data/faqs-en';
import { localizeHref } from '../../../i18n/routes';
const locale = 'en';

const subFeatures = [
    {
        eyebrow: 'Bulk processing',
        heading: 'Many orders at once.',
        body: 'Select multiple orders, process them in bulk and download the pick and pack list plus shipping labels in one go.',
        icon: 'fa-duotone fa-solid fa-layer-group',
    },
    {
        eyebrow: 'Merge orders',
        heading: 'One parcel for the same customer.',
        body: 'Has a customer placed several orders, possibly across different channels? Merge them into a single shipment. The same track and trace goes back to every channel involved.',
        icon: 'fa-duotone fa-solid fa-code-merge',
    },
    {
        eyebrow: 'Backorders',
        heading: 'Released the moment stock arrives.',
        body: 'Not enough stock? The order gets the Backorder status. As soon as you book in the stock, the order jumps back to Open automatically. No need to keep an eye on it.',
        icon: 'fa-duotone fa-solid fa-clock-rotate-left',
    },
    {
        eyebrow: 'Manual shipments',
        heading: 'Orders without a sales channel too.',
        body: 'Phone orders or B2B shipments. Fill in the customer details and the delivery address, pick a carrier and ShopLinkr generates the shipping label.',
        icon: 'fa-duotone fa-solid fa-pen-to-square',
    },
];

const workflowSteps = [
    {
        title: 'An order comes in',
        body: 'An order from one of your sales channels appears straight away in your central overview, with the product details and stock locations already lined up.',
    },
    {
        title: 'Pick and pack',
        body: 'Pick interactively with a handheld scanner or process multiple orders in bulk. For every product you instantly see where it sits in your warehouse, so you work faster and with fewer mistakes.',
    },
    {
        title: 'Label and ship',
        body: 'The right shipping method is already set, so you print the label right away. ShopLinkr syncs the status and track and trace back to the right sales channel automatically.',
    },
];

const faqs = faqsByPageEn.bestellingen;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Features', '/en/features'],
        ['Orders', '/en/features/orders'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Processing orders with ShopLinkr',
        description: 'Process orders from all your sales channels in one place. Create shipping labels with your favourite carrier, work in batches or handle individual orders in between.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Processing orders with ShopLinkr"
    description="Process orders from all your sales channels in one place. Create shipping labels with your favourite carrier, work in batches or handle individual orders in between."
    eyebrow="Orders"
    heading="Process everything in one place."
    subheading="Orders from all your sales channels come together in a single overview. Process them individually or in large batches, print labels from any carrier and the status is synced back automatically."
    routeKey="features.orders"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">One central overview</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            All your sales channels
                            <span class="block">in one workspace.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">Open orders</p>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel tabular-nums">4 orders</span>
                        </div>

                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#0000A4] text-paper">Bol</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">Bluetooth earbuds</p>
                                    <p class="text-[11px] text-gravel tabular-nums">#12384</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-gravel">Open</span>
                            </li>
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#95BF47] text-paper">Shopify</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">Wheel cap set</p>
                                    <p class="text-[11px] text-sunstone-deep font-semibold tabular-nums">#12385 + #12388 merged</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-sunstone-deep">Picking</span>
                            </li>
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#7F54B3] text-paper">WooComm</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">Wooden table lamp</p>
                                    <p class="text-[11px] text-gravel tabular-nums">#12386</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-gravel">Processing</span>
                            </li>
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#E10915] text-paper">Kaufland</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">A5 notebook</p>
                                    <p class="text-[11px] text-gravel tabular-nums">#12387</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-charcoal">Completed</span>
                            </li>
                        </ul>

                        <div class="flex items-center justify-between gap-3 pt-4 mt-4 border-t border-chalk-darker">
                            <span class="text-sm font-semibold text-charcoal">Select and process</span>
                            <span class="inline-flex items-center gap-1.5 text-xs text-sunstone-deep font-semibold">
                                <i class="fa-solid fa-layer-group text-[0.65rem]" aria-hidden="true"></i>
                                In one batch
                            </span>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        No separate exports, no switching between tabs. Filter by channel, status or carrier and process everything from the same screen.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">How an order flows</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Three steps,
                        <span class="block text-sunstone-deep">nothing left behind.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Every order follows the same fixed route in ShopLinkr. Predictable for you, delivered fast for your customer.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ol class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            workflowSteps.map((step, index) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5 text-sm font-semibold">
                                        {index + 1}
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{step.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{step.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        The questions that come up often,
                        <span class="block text-sunstone-deep">clearly answered.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Missing a question? Schedule a call or send us a message. We are happy to think along about your situation.
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Ask your question
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
