---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import FaqList from '../../../components/template/FaqList.astro';
import { externalLinks } from '../../../data/externalLinks';
import { breadcrumbs } from '../../../utils/seo';
import { faqsByPageEn } from '../../../data/faqs-en';
import { localizeHref } from '../../../i18n/routes';

const locale = 'en';

const subFeatures = [
    {
        eyebrow: 'Return status per item',
        heading: 'Assess every item on its own.',
        body: 'A return sometimes holds several products, and you do not handle every product the same way. You give each one its own return status, with exactly the options your sales channel offers.',
        icon: 'fa-duotone fa-solid fa-list-check',
    },
    {
        eyebrow: 'Photos as proof',
        heading: 'Capture what comes back in.',
        body: 'Add multiple photos per return item. Handy for damaged or incomplete returns, as proof toward the customer or to record internally what you received.',
        icon: 'fa-duotone fa-solid fa-camera',
    },
    {
        eyebrow: 'Restock',
        heading: 'Back in stock, or not.',
        body: 'Decide per item whether it goes back into stock and pick the warehouse location. For bundles you set a location per subproduct.',
        icon: 'fa-duotone fa-solid fa-boxes-stacked',
    },
    {
        eyebrow: 'T&T scanning',
        heading: 'One scan, the right return.',
        body: 'Grab the return parcel, scan the track and trace code and the matching return opens right in front of you. No searching through lists, just process it.',
        icon: 'fa-duotone fa-solid fa-barcode-read',
    },
];

const workflowSteps = [
    {
        title: 'Open the return',
        body: 'Open the return from your overview or scan the T&T code on the parcel. You immediately see the details, the customer and the products coming back.',
    },
    {
        title: 'Assess the items',
        body: 'Choose the return status per item, fill in the number of units received and add photos of the condition the product arrived in if needed.',
    },
    {
        title: 'Put it back in stock',
        body: 'Decide per item whether it can be sold again and pick the warehouse location.',
    },
    {
        title: 'Finish the return',
        body: 'You handle the return in one go. ShopLinkr sets the return to Handled and automatically syncs the processing back to your sales channel.',
    },
];

const faqs = faqsByPageEn.retouren;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Features', '/en/features'],
        ['Returns', '/en/features/returns'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Processing returns with ShopLinkr',
        description: 'Process returns in a structured way in ShopLinkr. Assess per item, add photos as proof and book items back to the right warehouse location. Your stock and channels stay automatically in sync.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    routeKey="features.returns"
    title="Processing returns with ShopLinkr"
    description="Process returns in a structured way in ShopLinkr. Assess per item, add photos as proof and book items back to the right warehouse location. Your stock and channels stay automatically in sync."
    eyebrow="Return management"
    heading="Handle returns, in a steady rhythm."
    subheading="Returns are part of the job, processing them does not have to be a hassle. Assess per item, record it with photos and book it back into stock. On to the next."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Returns under control</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Process returns
                            <span class="block">in a structured way.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <div class="flex items-center gap-2.5">
                                <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-rotate-left text-[0.7rem]" aria-hidden="true"></i>
                                </span>
                                <div class="flex flex-col">
                                    <span class="text-sm font-semibold text-charcoal">Return #R-48217</span>
                                    <span class="text-[11px] text-gravel">Webshop · 2 items</span>
                                </div>
                            </div>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">Processing</span>
                        </div>

                        <ul class="space-y-3 mb-4">
                            <li class="px-3 py-3 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center justify-between gap-3 mb-2.5">
                                    <span class="text-sm font-medium text-charcoal">Linen cushion cover, beige</span>
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 text-[11px] font-semibold">
                                        <i class="fa-solid fa-check text-[9px]" aria-hidden="true"></i>
                                        Valid
                                    </span>
                                </div>
                                <div class="flex items-center justify-between gap-3 text-xs">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center h-4 w-7 rounded-full bg-sunstone-deep relative">
                                            <span class="absolute right-0.5 h-3 w-3 rounded-full bg-paper"></span>
                                        </span>
                                        <span class="text-charcoal font-medium">Add to stock</span>
                                    </div>
                                    <span class="text-gravel tabular-nums">A.3</span>
                                </div>
                            </li>
                            <li class="px-3 py-3 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center justify-between gap-3 mb-2.5">
                                    <span class="text-sm font-medium text-charcoal">Ceramic teapot, 1L</span>
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-chalk-dark text-charcoal ring-1 ring-chalk-darker text-[11px] font-semibold">
                                        <i class="fa-solid fa-triangle-exclamation text-[9px]" aria-hidden="true"></i>
                                        Damaged
                                    </span>
                                </div>
                                <div class="flex items-center justify-between gap-3 text-xs">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center h-4 w-7 rounded-full bg-chalk-dark relative">
                                            <span class="absolute left-0.5 h-3 w-3 rounded-full bg-paper"></span>
                                        </span>
                                        <span class="text-charcoal font-medium">Add to stock</span>
                                    </div>
                                    <span class="text-gravel">Written off</span>
                                </div>
                            </li>
                        </ul>

                        <div class="flex items-center justify-between gap-3 pt-3 border-t border-chalk-darker">
                            <span class="text-sm font-semibold text-charcoal">Status to channel</span>
                            <span class="inline-flex items-center gap-1.5 text-sunstone-deep font-semibold text-sm">
                                Synced back
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                        </div>
                        <p class="text-[11px] text-gravel mt-2 leading-relaxed">
                            Each item gets its own assessment and your stock is updated right away.
                        </p>
                    </div>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">How you process a return</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Four steps,
                        <span class="block text-sunstone-deep">from arrival to handled.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Every return follows the same route in ShopLinkr. Predictable for you and quick to explain to new colleagues.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ol class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            workflowSteps.map((step, index) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5 text-sm font-semibold">
                                        {index + 1}
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{step.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{step.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Questions that come up often,
                        <span class="block text-sunstone-deep">clearly answered.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Not seeing your question? Schedule a call or send us a message. We are happy to think along with your situation.
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Ask your question
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
