---
import PageLayout from '../../../layouts/PageLayout.astro';
import CtaBanner from '../../../components/sections/CtaBanner.astro';
import FaqList from '../../../components/template/FaqList.astro';
import { externalLinks } from '../../../data/externalLinks';
import { breadcrumbs } from '../../../utils/seo';
import { faqsByPageEn } from '../../../data/faqs-en';
import { localizeHref } from '../../../i18n/routes';
const locale = 'en';

const subFeatures = [
    {
        eyebrow: 'Edit addresses',
        heading: 'Fix a typo in seconds.',
        body: 'Adjust a shipping or billing address right inside ShopLinkr. The new details flow straight onto the shipping label and the delivery options are fetched again immediately.',
        icon: 'fa-duotone fa-solid fa-location-dot',
    },
    {
        eyebrow: 'Shipping and billing apart',
        heading: 'Two addresses per order.',
        body: 'Every order has its own shipping and billing profile. When the billing address differs from the delivery address, you keep them separate. Handy for gift shipments and business orders.',
        icon: 'fa-duotone fa-solid fa-copy',
    },
    {
        eyebrow: 'Keep your changes',
        heading: 'Your correction stays put.',
        body: 'Edit a field by hand and ShopLinkr keeps it that way. A later sync from your sales channel does not overwrite your change.',
        icon: 'fa-duotone fa-solid fa-shield-halved',
    },
    {
        eyebrow: 'Stored encrypted',
        heading: 'Personal data well protected.',
        body: 'Name, contact details, company details and address are stored encrypted. You decide who gets to see the data yourself, with roles and permissions per user.',
        icon: 'fa-duotone fa-solid fa-lock',
    },
];

const fieldGroups = [
    {
        title: 'Personal and contact details',
        body: 'Salutation, first name, infix, last name, email address and phone number. Enough to reach the customer quickly when something comes up with an order or return.',
    },
    {
        title: 'Company details',
        body: 'Company name, VAT number and Chamber of Commerce number. Handy for business orders and for invoices that land correctly in your bookkeeping.',
    },
    {
        title: 'Shipping and billing address',
        body: 'Street, house number with addition, an extra address line, postcode, city and country. Shipping and billing address are kept separate, so you adjust them individually.',
    },
];

const faqs = faqsByPageEn.klanten;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Features', '/en/features'],
        ['Customers', '/en/features/customers'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Manage customers with ShopLinkr',
        description: 'Manage customer details and addresses directly in ShopLinkr. Edit shipping and billing profiles from the order and keep personal data safe behind encryption.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Manage customers with ShopLinkr"
    description="Manage customer details and addresses directly in ShopLinkr. Edit shipping and billing profiles from the order and keep personal data safe behind encryption."
    eyebrow="Customer management"
    heading="Customer details under control."
    subheading="Edit shipping and billing profiles from the order, merge orders with the same delivery address into a single shipment and keep personal data safe behind encryption."
    routeKey="features.customers"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Editing from the order</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Adjust an address
                            <span class="block">without the hassle.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <span class="text-sm font-semibold text-charcoal">Order #4821</span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">
                                <i class="fa-solid fa-lock text-[0.65rem] text-sunstone-deep" aria-hidden="true"></i>
                                Encrypted
                            </span>
                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div class="rounded-md bg-chalk-light ring-1 ring-chalk-dark p-3">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="inline-flex items-center justify-center h-5 w-5 rounded bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                        <i class="fa-solid fa-truck text-[0.6rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">Shipping address</span>
                                </div>
                                <p class="text-sm font-medium text-charcoal leading-snug">Lotte de Vries</p>
                                <p class="text-xs text-steel leading-snug mt-0.5">Kerkstraat 18</p>
                                <p class="text-xs text-steel leading-snug">3811 CV, Amersfoort</p>
                                <p class="text-xs text-gravel leading-snug mt-1.5 tabular-nums">+31 6 12 34 56 78</p>
                            </div>
                            <div class="rounded-md bg-chalk-light ring-1 ring-chalk-dark p-3">
                                <div class="flex items-center gap-2 mb-2">
                                    <span class="inline-flex items-center justify-center h-5 w-5 rounded bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                        <i class="fa-solid fa-file-invoice text-[0.6rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">Billing address</span>
                                </div>
                                <p class="text-sm font-medium text-charcoal leading-snug">De Vries Studio B.V.</p>
                                <p class="text-xs text-steel leading-snug mt-0.5">Wilhelminapark 4</p>
                                <p class="text-xs text-steel leading-snug">3581 NE, Utrecht</p>
                                <p class="text-xs text-gravel leading-snug mt-1.5 tabular-nums">VAT NL862514730B01</p>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 mt-4 pt-4 border-t border-chalk-dark">
                            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-charcoal">
                                <i class="fa-solid fa-pen-to-square text-sunstone-deep text-[0.7rem]" aria-hidden="true"></i>
                                Adjust address
                            </span>
                            <span class="text-gravel font-mono text-xs">→</span>
                            <span class="inline-flex items-center gap-1.5 text-[11px] font-medium text-sunstone-deep">
                                <span class="relative inline-flex h-1.5 w-1.5">
                                    <span class="absolute inline-flex h-full w-full rounded-full bg-sunstone-deep opacity-60 animate-ping"></span>
                                    <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-sunstone-deep"></span>
                                </span>
                                Delivery options fetched again
                            </span>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Adjust a field and the label and delivery options follow along right away. No clicking back and forth to the sales channel.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Details per order</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        All customer details
                        <span class="block text-sunstone-deep">in one place.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Every order comes with a complete shipping and billing profile. Enough to help the customer properly, create a correct label and get a clean invoice into your bookkeeping.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            fieldGroups.map((group) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-id-card text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{group.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{group.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Questions that keep coming up,
                        <span class="block text-sunstone-deep">clearly answered.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Missing a question? Book a call or send us a message. We are happy to think along with how you work.
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Ask your question
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
