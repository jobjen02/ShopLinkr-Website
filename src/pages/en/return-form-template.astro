---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'What it is',
        heading: 'A return form in a single Word file.',
        body: 'A return form is the slip you include with your shipment, so your customer knows exactly what to do when they want to return something. We have put together a Word template you can fill in straight away with your own branding, company details and return conditions.',
        icon: 'fa-solid fa-file-word',
    },
    {
        eyebrow: 'For your customer',
        heading: 'Clear returns mean happier customers.',
        body: 'A good return form prevents confusion. Your customer knows which information is needed, why they are returning something and how to send the parcel back. That means fewer questions for your customer service and more trust on a first order.',
        icon: 'fa-solid fa-face-smile',
    },
    {
        eyebrow: 'For you',
        heading: 'Fewer mistakes in your returns processing.',
        body: 'When a return comes in without clear details, you waste time figuring out who it is from and which order it belongs to. With a properly completed form you know straight away what you are holding, and you can process the return quickly and neatly.',
        icon: 'fa-solid fa-square-check',
    },
    {
        eyebrow: 'Customisable',
        heading: 'Make it match your brand.',
        body: 'The template is a Word file, so it is fully customisable. Add your logo, adjust the text, change the colours to your branding and export it as a PDF. Within ten minutes you have a professional return form you can include with every shipment.',
        icon: 'fa-solid fa-pen-to-square',
    },
    {
        eyebrow: 'The next step',
        heading: 'Process returns smartly with ShopLinkr.',
        body: 'A return form helps your customer, but it is just one step. In ShopLinkr you process returns straight into your stock, put products back on the shelf or reject them, and keep an overview of all your return flows. A great addition to that form.',
        icon: 'fa-solid fa-arrow-rotate-left',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Return form template - ShopLinkr',
    description: 'Download our free return form template and improve your returns processing. Easy to use and customisable to match your own branding.',
};

export const prerender = false;
---

<PageLayout
    title="Return form template - ShopLinkr"
    description="Download our free return form template in Word and improve your returns processing. Easy to use and customisable to match your own branding."
    eyebrow="Free download"
    heading="Return form template, ready to use."
    subheading="A ready made return form in Word, free to download. Adjust it to match your branding and include it with every shipment."
    routeKey="returnFormTemplate"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href="mailto:contact@shoplinkr.com?subject=Request%20return%20form%20template"
                    class="btn btn-sunstone text-base"
                >
                    Request template
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
            <p class="mt-4 text-sm text-gravel">
                Send us a quick email and we will send you the Word document right away. No strings attached.
            </p>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">About the template</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Why a return form makes the difference.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    A good return form is a small document with a big impact: fewer questions, faster processing and a more professional impression. We have done the groundwork for you, so you can put it to use straight away.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
