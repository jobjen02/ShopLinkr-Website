---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'One click',
        heading: 'Inventory sync sorted in a single step.',
        body: 'Connect your sales channels and ShopLinkr takes over. The moment an order comes in, your stock adjusts automatically across all your other channels. You never have to copy or update numbers by hand again.',
        icon: 'fa-solid fa-bolt',
    },
    {
        eyebrow: 'No hassle',
        heading: 'Automation that works for you.',
        body: 'No complex settings, no long learning curve. ShopLinkr works for you from day one instead of the other way around. You set it up, you let it run, and your stock stays accurate, even when you are not behind your laptop.',
        icon: 'fa-solid fa-wand-magic-sparkles',
    },
    {
        eyebrow: 'Time saved',
        heading: 'Win back hours every week.',
        body: 'You are no longer busy updating stock, fixing oversells or disappointing customers. You put that time into what made you an entrepreneur in the first place: new products, marketing or simply free time.',
        icon: 'fa-solid fa-clock',
    },
    {
        eyebrow: 'Error free',
        heading: 'Fewer human mistakes.',
        body: 'Working by hand means making mistakes. A typo, a wrong quantity, a forgotten update. Automate it and you remove the entire source of errors. Your stock stays accurate around the clock because a human is no longer in the loop.',
        icon: 'fa-solid fa-shield-check',
    },
    {
        eyebrow: 'For everyone',
        heading: 'Built for people, not for experts.',
        body: 'ShopLinkr is made for webshop owners who want simple inventory management, not for IT specialists. The interface speaks for itself and you do not need to plough through a hundred-page manual to get started.',
        icon: 'fa-solid fa-user-check',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Simple inventory management - ShopLinkr',
    description: 'Looking for an efficient way to manage your stock without the hassle? Discover ShopLinkr, the ultimate solution for simple inventory management.',
};

export const prerender = false;
---

<PageLayout
    routeKey="simpleInventory"
    title="Simple inventory management - ShopLinkr"
    description="Looking for an efficient way to manage your stock without the hassle? Discover ShopLinkr, the ultimate solution for simple inventory management."
    eyebrow="Simple inventory management"
    heading="Simple inventory management, truly without the hassle."
    subheading="Looking for an efficient way to manage your stock without the hassle? ShopLinkr makes inventory management as simple as it should be."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Why ShopLinkr</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    The benefits of simple inventory management.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Inventory management does not have to be complicated. ShopLinkr takes the manual work off your hands and keeps your stock accurate in real time across all your sales channels, so you can focus on growing again.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
