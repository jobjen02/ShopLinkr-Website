---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'Why a system',
        heading: 'Excel hits its limits faster than you expect.',
        body: 'A spreadsheet works fine until your second or third channel comes along. From that point on you are always playing catch up: your stock no longer matches, oversells pile up and your picker grabs the wrong quantities. An inventory management system takes that manual work out of your day.',
        icon: 'fa-solid fa-triangle-exclamation',
    },
    {
        eyebrow: 'One workspace',
        heading: 'Every channel together on a single screen.',
        body: 'ShopLinkr connects all your sales channels in one environment. From now on you manage your stock, orders and returns from a central place, with your product list always in view and without constantly switching between tabs.',
        icon: 'fa-solid fa-grip',
    },
    {
        eyebrow: 'Realtime sync',
        heading: 'Live updates, no delay.',
        body: 'Sell something on Bol and ShopLinkr instantly adjusts your stock across your other channels. No oversells, no cancelled orders and no excuses to customers. Your stock stays in step with what is actually sitting in your warehouse.',
        icon: 'fa-solid fa-bolt',
    },
    {
        eyebrow: 'Fast and accurate',
        heading: 'Process orders in minutes, not hours.',
        body: 'Orders come in automatically, you print pick and pack lists, generate shipping labels in bulk and send track and trace back. What used to take an entire morning now fits in between your coffee and your lunch.',
        icon: 'fa-solid fa-bag-shopping',
    },
    {
        eyebrow: 'Insight',
        heading: 'See where your stock is and what it is doing.',
        body: 'For each product you see physical stock, reserved quantities and what is still available to sell. Combine that with warehouse locations and purchase advice and you stay in control of what happens in your warehouse at all times.',
        icon: 'fa-solid fa-magnifying-glass-chart',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Inventory management system - ShopLinkr',
    description: 'An inventory management system that brings your sales channels together and keeps your stock synced in real time. Everything you need in one place.',
    inLanguage: 'en-US',
};

export const prerender = false;
---

<PageLayout
    title="Inventory management system - ShopLinkr"
    description="An inventory management system that brings your sales channels together and keeps your stock synced in real time. Everything you need in one place."
    eyebrow="Inventory management system"
    heading="The right inventory management system for your business."
    subheading="A solid system is essential when you are serious about growing. ShopLinkr brings all your sales channels, stock and orders together in one central workspace."
    routeKey="inventorySystem"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Why an inventory management system</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    A system that thinks along with you.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Without a solid system you lose a lot of time on manual work that gets you nowhere. ShopLinkr automates your stock, your orders and your shipping, so you can put your time into growth instead of admin.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
