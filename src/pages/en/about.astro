---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { localizeHref } from '../../i18n/routes';
const locale = 'en';

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['About', '/en/about'],
    ]),
    {
        '@type': 'AboutPage',
        name: 'About ShopLinkr',
        description: 'ShopLinkr was founded in 2022 by Job, out of his own webshop. Today we process more than 1 million orders for Dutch webshops, with a pay as you go model that stays affordable for any business.',
        mainEntity: {
            '@type': 'Organization',
            name: 'ShopLinkr',
            foundingDate: '2022',
            founder: {
                '@type': 'Person',
                name: 'Job',
            },
        },
    },
];

export const prerender = false;
---

<PageLayout
    title="About ShopLinkr | ShopLinkr"
    description="ShopLinkr was founded in 2022 by Job, out of his own webshop. Today we process more than 1 million orders for Dutch webshops, with a pay as you go model that stays affordable for any business."
    eyebrow="About ShopLinkr"
    heading="Warehouse software built from real experience."
    subheading="No pitch deck, no investor. Just one Dutch webshop that built its own tool and shared it with other webshops."
    routeKey="about"
    jsonLd={jsonLd}
>
    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="max-w-3xl mx-auto space-y-6 text-charcoal leading-relaxed text-[1.0625rem]">
                <p>
                    ShopLinkr started in 2022 out of a need of our own. Founder Job ran a webshop and sold across multiple channels, including Bol and Amazon. Without a big budget, but with the need to keep track of inventory and orders, he built his own solution as a software developer. Before long, other webshops were asking whether they could use that tool too. That is how ShopLinkr was born.
                </p>
                <p>
                    We believe that an order and inventory management system should be within reach for every webshop, whatever the budget. That is why we were the first in the Netherlands to introduce a pay as you go model. You only pay for what you use, so the software scales neatly with your warehouse.
                </p>
                <p>
                    Today we work on ShopLinkr with a dedicated team and we have processed more than 1 million orders for Dutch webshops. What drives us is still the same: practical software for webshops that take their warehouse seriously.
                </p>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-3xl mx-auto text-center">
                <p class="eyebrow mb-4">Want to see more?</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight">
                    Meet the team or read a customer story.
                </h2>
                <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
                    <a
                        href={localizeHref('/team', locale)}
                        class="btn btn-secondary text-base"
                    >
                        Meet the team
                    </a>
                    <a
                        href={localizeHref('/referenties', locale)}
                        class="btn btn-secondary text-base"
                    >
                        Read customer stories
                    </a>
                    <a
                        href={externalLinks.demoBooking}
                        class="btn btn-sunstone text-base"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        Schedule a demo
                    </a>
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
