---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const eventInfo = [
    {
        label: 'Edition',
        value: '20 and 21 January 2026',
        icon: 'fa-solid fa-calendar-days',
    },
    {
        label: 'Location',
        value: 'Jaarbeurs Utrecht',
        icon: 'fa-solid fa-location-dot',
    },
    {
        label: 'Next edition',
        value: 'Book a demo in the meantime',
        icon: 'fa-solid fa-arrow-right',
    },
];

const reasons = [
    {
        eyebrow: 'Personal conversation',
        heading: 'Talk to our team in the same spirit.',
        body: 'What we enjoyed most at the Webwinkel Vakdagen is exactly what we do every week in an online demo. A conversation about your workflow, your channels and what ShopLinkr can mean for your situation. No sales pitch, just thinking along with you.',
        icon: 'fa-solid fa-comments',
    },
    {
        eyebrow: 'Live demo',
        heading: 'See ShopLinkr in action.',
        body: 'We show you live how a sale on Bol instantly updates your stock in Shopify or WooCommerce, how you generate pick lists with locations and how you print shipping labels in bulk. No story, just seeing how it works.',
        icon: 'fa-solid fa-display',
    },
    {
        eyebrow: 'Start with no strings attached',
        heading: 'Try it free for 14 days.',
        body: 'Did you miss us at the fair or simply want to get going quickly? Create an account and run 14 days of your own orders through ShopLinkr. No credit card required, cancellable monthly.',
        icon: 'fa-solid fa-bolt',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Webwinkel Vakdagen 2026 - ShopLinkr',
    description: 'We were present at the Webwinkel Vakdagen 2026 at Jaarbeurs Utrecht. Book a demo for a personal conversation about your inventory management.',
};

export const prerender = false;
---

<PageLayout
    title="Webwinkel Vakdagen 2026 - ShopLinkr"
    description="We were present at the Webwinkel Vakdagen 2026 at Jaarbeurs Utrecht. Book a demo for a personal conversation about your inventory management."
    eyebrow="Webwinkel Vakdagen 2026"
    heading="We were there at the Webwinkel Vakdagen 2026."
    subheading="What a great edition. Thank you for all the good conversations at Jaarbeurs Utrecht. Still want to get to know us? Book an online demo and we will catch you up at your own pace."
    routeKey="webwinkelVakdagen"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.register}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-4xl">
                <p class="eyebrow mb-4">Looking back</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1] mb-10">
                    Thanks for a wonderful edition.
                </h2>

                <div class="grid md:grid-cols-3 gap-6">
                    {
                        eventInfo.map((info) => (
                            <div class="bg-paper rounded-2xl p-7 ring-1 ring-chalk-dark">
                                <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                    <i class={`${info.icon} text-base`} aria-hidden="true" />
                                </div>
                                <p class="eyebrow mb-2">{info.label}</p>
                                <p class="text-lg font-semibold text-charcoal tracking-tight leading-snug">
                                    {info.value}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Missed the fair?</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    No problem, we are happy to catch you up.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    The Webwinkel Vakdagen 2026 is over, but the conversations we had there are ones we have all year round. Book an online demo and together we will look at what ShopLinkr can do for your workflow.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    reasons.map((reason) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${reason.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{reason.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{reason.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{reason.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{reason.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {reason.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>

            <div class="mt-16 max-w-3xl">
                <p class="text-base text-steel leading-relaxed">
                    Prefer to get started right away? Create an account and start your free 14 day trial. No credit card needed, and you can cancel any month you like.
                </p>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
