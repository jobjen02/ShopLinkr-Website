---
import PageLayout from '../../layouts/PageLayout.astro';
import FaqList from '../../components/template/FaqList.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { faqsByPageEn, faqCategories } from '../../data/faqs-en';
import { breadcrumbs } from '../../utils/seo';
import { localizeHref } from '../../i18n/routes';

const locale = 'en';

const allFaqs = faqCategories.flatMap((cat) =>
    cat.pages.flatMap((page) => faqsByPageEn[page] ?? []),
);

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['FAQ', '/en/faq'],
    ]),
    {
        '@type': 'FAQPage',
        mainEntity: allFaqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Frequently asked questions about ShopLinkr"
    description="Answers to the most common questions about ShopLinkr: stock management, order processing, shipping, integrations, pricing and more."
    eyebrow="Frequently asked questions"
    heading="Everything about ShopLinkr in one place."
    subheading="The questions we get most often, bundled and answered clearly. Missing something? Feel free to get in touch, we're happy to help."
    routeKey="faq"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose space-y-14 md:space-y-20">
            {
                faqCategories.map((cat) => {
                    const items = cat.pages.flatMap(
                        (page) => faqsByPageEn[page] ?? [],
                    );
                    return (
                        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                            <div class="lg:col-span-4 lg:sticky lg:top-28">
                                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                                    {cat.title}
                                </h2>
                                <p class="mt-4 text-base text-steel leading-relaxed">
                                    {cat.intro}
                                </p>
                            </div>
                            <div class="lg:col-span-8">
                                <FaqList items={items} />
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </section>

    <CtaBanner />
</PageLayout>
