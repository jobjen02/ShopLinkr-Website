---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'Multi-channel',
        heading: 'Connect all your sales channels at once.',
        body: 'Selling across several channels at the same time? ShopLinkr ties your channels together and builds a single inventory overview around them. From now on you work from one screen instead of constantly switching between platforms.',
        icon: 'fa-solid fa-plug',
    },
    {
        eyebrow: 'Always accurate',
        heading: 'Inventory that is always right.',
        body: 'Sell a product on Bol and ShopLinkr instantly deducts the stock on Shopify and WooCommerce. No more oversells, no more cancelled orders. For each product you see how much you physically have in stock, how much is reserved and how much you can actually still sell.',
        icon: 'fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Lightning-fast picking',
        heading: 'Pick lists that speed up your warehouse.',
        body: 'The pick list shows the location for every product. Your picker walks the most efficient route and grabs everything for several orders in one go. That saves you minutes per order and keeps the pace up during peak days.',
        icon: 'fa-solid fa-list-check',
    },
    {
        eyebrow: 'Shipping',
        heading: 'Automatic shipping labels.',
        body: 'Straight from ShopLinkr you print a shipping label from PostNL, DPD, MyParcel, Sendcloud or another integration. The track and trace goes back to your sales channel and your customer automatically. No more copy-and-paste between marketplace and carrier.',
        icon: 'fa-solid fa-truck-fast',
    },
    {
        eyebrow: 'Purchase advice',
        heading: 'Smart forecasts for your purchasing.',
        body: 'Based on your sales history, ShopLinkr shows which products you are nearly out of and how much you should reorder. That way your best seller never suddenly sells out, without your warehouse filling up.',
        icon: 'fa-solid fa-chart-line',
    },
    {
        eyebrow: 'Start right away',
        heading: 'Sign up today, work today.',
        body: 'No lengthy implementation projects, no consultants. You connect your channels, your inventory rolls in and you can get going right away. For the first 14 days you try ShopLinkr for free, without a credit card and without obligations.',
        icon: 'fa-solid fa-bolt',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Inventory management - ShopLinkr',
    description: 'Want to manage your webshop inventory with ease? You can. In one solution you manage the inventory of all your products and channels.',
};

export const prerender = false;
---

<PageLayout
    title="Inventory management - ShopLinkr"
    description="Want to manage your webshop inventory with ease? You can. In one solution you manage the inventory of all your products and channels."
    eyebrow="Inventory management"
    heading="Inventory management for webshops that really want to grow."
    subheading="One place for the inventory of all your products across all your channels. ShopLinkr keeps your stock accurate in real time, so you never sell what you do not have again."
    routeKey="inventoryManagement"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Inventory management</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    One inventory, on every sales channel.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    ShopLinkr pulls all your products from your channels, brings them together in one overview and syncs your inventory back in real time. No double work, no oversells, and always a clear view of what is really on the shelf.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
