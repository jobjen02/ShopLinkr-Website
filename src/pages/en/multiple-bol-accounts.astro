---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'Why multiple',
        heading: 'Running multiple Bol accounts is more common than you think.',
        body: 'Plenty of sellers split their Bol activities across two accounts, for example keeping the Dutch and the Belgian market separate. That way you stay in control of region specific prices, delivery times and assortment. It is a sensible choice, but it does add a few management challenges.',
        icon: 'fa-solid fa-layer-group',
    },
    {
        eyebrow: 'Double work',
        heading: 'You now manage your product range twice.',
        body: 'For each account you have to keep your content up to date, maintain your prices and set your delivery times correctly. Change something about a product and you have to carry that change through on both sides. That does not just cost time, it is also a major source of errors.',
        icon: 'fa-solid fa-copy',
    },
    {
        eyebrow: 'Fragmented stock',
        heading: 'One physical stock, two accounts.',
        body: 'You do not suddenly have two stocks in your warehouse. You have one pile of products, but on paper it is split across two accounts. The risk of selling the same product on both sides is therefore real, leading to oversells and frustrated customers.',
        icon: 'fa-solid fa-arrows-split-up-and-left',
    },
    {
        eyebrow: 'Centralise',
        heading: 'Both accounts together in one place.',
        body: 'Connect both Bol accounts to ShopLinkr. We automatically link the products together so they are treated as a single stock. Sell on one account and ShopLinkr immediately adjusts the stock on the other. No more oversells, no matter where the order comes from.',
        icon: 'fa-solid fa-grip',
    },
    {
        eyebrow: 'One workflow',
        heading: 'Orders together, processing together.',
        body: 'All orders from your different accounts come together in one overview. You print pick and pack lists across all accounts, run shipping labels in bulk and send your track and trace back to the right account. It no longer matters which account an order comes from.',
        icon: 'fa-solid fa-list-check',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Connect multiple Bol accounts to ShopLinkr',
    description: 'Manage multiple Bol accounts from a single environment. ShopLinkr links your accounts and keeps your stock accurate in real time across all of them.',
};

export const prerender = false;
---

<PageLayout
    title="Connect multiple Bol accounts to ShopLinkr"
    description="Manage multiple Bol accounts from a single environment. ShopLinkr links your accounts and keeps your stock accurate in real time across all of them."
    eyebrow="Multiple Bol accounts"
    heading="Manage multiple Bol accounts without the double work."
    subheading="Working with multiple Bol accounts, for example for the Netherlands and Belgium? ShopLinkr links them together and keeps your stock on both accounts accurate at all times."
    routeKey="multipleBolAccounts"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Book a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Two accounts, one workflow</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    From two separate worlds to one overview.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Working with multiple Bol accounts brings benefits, but also a lot of double work and room for errors. ShopLinkr brings your accounts together, so instead of two environments you have one central workspace.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
