---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const jsonLd = {
    '@type': 'WebPage',
    name: 'ShopLinker or ShopLinkr?',
    description: 'Is it spelled ShopLinker or ShopLinkr? The correct spelling is ShopLinkr, without the e at the end. Read why here.',
};

export const prerender = false;
---

<PageLayout
    title="ShopLinker or ShopLinkr? The correct spelling"
    description="Is it spelled ShopLinker or ShopLinkr? The correct spelling is ShopLinkr, without the e at the end. Read why here."
    eyebrow="Which name is correct?"
    heading="ShopLinker or ShopLinkr?"
    subheading="You say it like 'ShopLinker', but that is not how you write it. ShopLinkr is the correct spelling."
    routeKey="shoplinkerOrShoplinkr"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Start for free
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Schedule a demo
                </a>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl">
                <p class="eyebrow mb-4">The correct spelling</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1] mb-8">
                    ShopLinker does not exist, ShopLinkr does.
                </h2>
                <div class="text-lg text-steel leading-relaxed space-y-6">
                    <p>
                        We hear it all the time: people type ShopLinker instead of ShopLinkr. Understandable, because that is exactly how you say it. The correct spelling is just a little shorter: ShopLinkr, without the 'e' at the end.
                    </p>
                    <p>
                        The name comes from what the platform does. With ShopLinkr you can link your different sales channels (your shops) together. Shop plus linking became ShopLinkr. We deliberately dropped the 'e' for a modern, shorter spelling.
                    </p>
                    <p>
                        So if you searched for ShopLinker and ended up here? Welcome. You are in the right place, just remember from now on: it is ShopLinkr.
                    </p>
                </div>
            </div>

            <div class="mt-16 md:mt-20 max-w-3xl">
                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight leading-tight mb-6">
                    What exactly does ShopLinkr do?
                </h2>
                <p class="text-base text-steel leading-relaxed">
                    ShopLinkr is an order and inventory management system for webshops that sell across multiple channels at once. Think of marketplaces such as bol and Kaufland and webshops such as Shopify and WooCommerce. We make sure your stock stays accurate at all times, your orders come together in one place, and you run your picking lists and shipping labels in a single workflow. Whether you type ShopLinker or ShopLinkr, you will find us here.
                </p>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
