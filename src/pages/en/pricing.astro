---
import PageLayout from '../../layouts/PageLayout.astro';
import PricingCalculator from '../../components/pricing/PricingCalculator.vue';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPageEn } from '../../data/faqs-en';
import { localizeHref } from '../../i18n/routes';

const locale = 'en';

const pricingExamples = [
    {
        label: 'Starter',
        sub: '2 channels, 250 orders',
        amount: '€ 50,00',
        breakdown: '€ 10 channels + € 40 orders',
    },
    {
        label: 'Growing',
        sub: '4 channels, 1.000 orders',
        amount: '€ 130,00',
        breakdown: '€ 20 channels + € 110 orders',
    },
    {
        label: 'Scale',
        sub: '6 channels, 5.000 orders',
        amount: '€ 317,45',
        breakdown: '€ 30 channels + € 287,45 orders',
    },
];

const inclusions = [
    {
        title: 'Every feature included',
        body: 'Stock, picklists, labels, purchasing. No separate modules or pricier tiers.',
        icon: 'fa-duotone fa-solid fa-grid-2',
    },
    {
        title: 'Unlimited users',
        body: 'Everyone in your warehouse pitches in. No price per seat, no ceiling.',
        icon: 'fa-duotone fa-solid fa-users',
    },
    {
        title: 'Fast support',
        body: 'Typically a reply within 2 hours during office hours. Direct contact with someone who knows ShopLinkr.',
        icon: 'fa-duotone fa-solid fa-comments',
    },
    {
        title: 'Free migration and onboarding',
        body: 'We help you move from your current system, import your products and set up your channels.',
        icon: 'fa-duotone fa-solid fa-arrow-right-arrow-left',
    },
    {
        title: 'Weekly updates',
        body: 'New features and improvements roll out every week. At no extra cost.',
        icon: 'fa-duotone fa-solid fa-arrows-rotate',
    },
    {
        title: 'No annual lock-in',
        body: 'Cancel monthly, no commitments.',
        icon: 'fa-duotone fa-solid fa-calendar-check',
    },
    {
        title: '14-day free trial',
        body: 'Try ShopLinkr with your own products and orders. No credit card needed.',
        icon: 'fa-duotone fa-solid fa-circle-play',
    },
    {
        title: 'No hidden costs',
        body: 'One transparent rate based on channels and orders. No setup fees or surcharges.',
        icon: 'fa-duotone fa-solid fa-shield-check',
    },
];

const faqs = faqsByPageEn.prijzen;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Pricing', '/en/pricing'],
    ]),
    {
        '@type': 'Product',
        name: 'ShopLinkr',
        description: 'Warehouse software for Dutch webshops. Stock, picklists, labels and order processing in one platform.',
        brand: {
            '@type': 'Brand',
            name: 'ShopLinkr',
        },
        offers: {
            '@type': 'Offer',
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
            url: 'https://shoplinkr.com/en/pricing',
            priceSpecification: {
                '@type': 'UnitPriceSpecification',
                priceCurrency: 'EUR',
                unitText: 'MONTH',
            },
        },
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Pricing | ShopLinkr"
    description="A transparent pricing model for ShopLinkr. Pay as you go: you pay per sales channel and per order, with all features included. 14-day free trial."
    eyebrow="Pricing"
    heading="One transparent pricing model."
    subheading="You only pay for what you use. Every feature is included, with no tiers or separate modules."
    routeKey="pricing"
    jsonLd={jsonLd}
>
    <PricingCalculator client:visible locale="en" />

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">How it works</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Two building blocks,
                        <span class="block text-sunstone-deep">no surprises.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Your bill consists of a fixed amount per sales channel and a tiered rate per order. Drag the calculator to see your monthly price, or work it out yourself with the figures below.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                <i class="fa-duotone fa-solid fa-plug text-[1.15rem]" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-2">Per sales channel</p>
                            <p class="text-2xl md:text-[1.625rem] font-semibold text-charcoal tracking-tight leading-snug">
                                Fixed monthly rate.
                            </p>
                            <p class="mt-4 text-sm text-steel leading-relaxed">
                                Every channel you connect costs the same. Whichever channel you connect, the monthly rate stays the same.
                            </p>
                        </article>

                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                <i class="fa-duotone fa-solid fa-layer-group text-[1.15rem]" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-2">Per order</p>
                            <p class="text-2xl md:text-[1.625rem] font-semibold text-charcoal tracking-tight leading-snug">
                                Tiered rate.
                            </p>
                            <p class="mt-4 text-sm text-steel leading-relaxed">
                                Each order tier has its own rate, dropping to just a few cents per order in the higher tiers. The more orders you process per month, the lower the average per order.
                            </p>
                        </article>
                    </div>

                    <div class="mt-6 rounded-2xl bg-chalk-light ring-1 ring-chalk-dark p-6 md:p-7">
                        <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-5">
                            Examples
                        </p>
                        <ul class="divide-y divide-chalk-dark">
                            {
                                pricingExamples.map((example) => (
                                    <li class="py-3 first:pt-0 last:pb-0 flex items-baseline justify-between gap-4">
                                        <div>
                                            <p class="text-sm font-semibold text-charcoal">{example.label}</p>
                                            <p class="text-xs text-gravel mt-0.5">{example.sub}</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-base font-semibold text-charcoal tabular-nums whitespace-nowrap">{example.amount}</p>
                                            <p class="text-xs text-gravel tabular-nums whitespace-nowrap mt-0.5">{example.breakdown}</p>
                                        </div>
                                    </li>
                                ))
                            }
                        </ul>
                        <p class="mt-5 text-xs text-gravel leading-relaxed">
                            Monthly totals, excluding VAT. Work it out yourself with the calculator above.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-2xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">What's included</p>
                <h2 class="text-4xl md:text-5xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Everything included, whatever your volume.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    No tiers with stripped-down features, no extra modules to add on. One pricing model based on your usage. Done.
                </p>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
                {
                    inclusions.map((item) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 transition duration-300 ease-out hover:ring-chalk-darker hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-6">
                                <i class={`${item.icon} text-[1.15rem]`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <h3 class="text-base md:text-[1.05rem] font-semibold text-charcoal mb-2 tracking-tight leading-snug">
                                {item.title}
                            </h3>
                            <p class="text-sm text-steel leading-relaxed">
                                {item.body}
                            </p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Ask us anything,
                        <span class="block text-sunstone-deep">we'll help you think it through.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Missing a question? Send us a message via chat or schedule a call with our team.
                    </p>
                    <a href={localizeHref('/contact', locale)} class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Ask your question
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
