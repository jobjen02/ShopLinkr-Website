---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import IntegrationCard from '../../components/template/IntegrationCard.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { breadcrumbs } from '../../utils/seo';

const all = await getCollection('integrationsEn');

const webshops = all
    .filter((i) => i.data.category === 'webshop')
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const marketplaces = all
    .filter((i) => i.data.category === 'marketplace')
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const carriers = all
    .filter((i) => i.data.category === 'carrier')
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const totalCount = webshops.length + marketplaces.length + carriers.length;

const popularCombinations = [
    {
        href: '/en/integrations/connect-shopify-to-bol-com',
        from: 'Shopify',
        fromLogo: '/assets/webshops/Shopify.jpg',
        to: 'bol',
        toLogo: '/assets/marketplaces/bol.jpeg',
        body: 'Stock in sync in real time and all your orders in one list.',
    },
    {
        href: '/en/integrations/connect-woocommerce-to-bol-com',
        from: 'WooCommerce',
        fromLogo: '/assets/webshops/WooCommerce.png',
        to: 'bol',
        toLogo: '/assets/marketplaces/bol.jpeg',
        body: 'WordPress plus Bol, connected without separate plugins per channel.',
    },
    {
        href: '/en/integrations/connect-woocommerce-to-shopify',
        from: 'WooCommerce',
        fromLogo: '/assets/webshops/WooCommerce.png',
        to: 'Shopify',
        toLogo: '/assets/webshops/Shopify.jpg',
        body: 'Two shops, one stock view. Ideal for parallel brands.',
    },
];

const jsonLd = [
    breadcrumbs([
        ['Home', '/en'],
        ['Integrations', '/en/integrations'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Integrations | ShopLinkr',
        description: 'ShopLinkr works with Bol, Shopify, WooCommerce, PostNL, DPD, MyParcel, Sendcloud and more. See every sales channel and carrier you can connect in a few clicks.',
    },
];

export const prerender = false;
---

<PageLayout
    title="Integrations | ShopLinkr"
    description="ShopLinkr works with Bol, Shopify, WooCommerce, PostNL, DPD, MyParcel, Sendcloud and more. See every sales channel and carrier you can connect in a few clicks."
    eyebrow="Integrations"
    heading="Connect your sales channels and carriers."
    subheading="ShopLinkr works with the tools you already use. From Shopify and Bol to PostNL and Sendcloud, all in one place."
    routeKey="integrations"
    jsonLd={jsonLd}
>
    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="flex items-baseline justify-between flex-wrap gap-4 mb-12">
                <p class="text-sm text-gravel" aria-live="polite" data-result-count>
                    {totalCount} integrations available
                </p>
                <div
                    class="inline-flex items-center gap-1 rounded-full bg-chalk-light ring-1 ring-chalk-dark p-1 text-sm"
                    role="group"
                    aria-label="Filter integrations by type"
                >
                    <button
                        type="button"
                        class="filter-tab is-active px-4 py-1.5 rounded-full font-medium text-charcoal transition-colors"
                        data-filter="all"
                        aria-pressed="true"
                    >
                        All
                    </button>
                    <button
                        type="button"
                        class="filter-tab px-4 py-1.5 rounded-full font-medium text-gravel transition-colors"
                        data-filter="webshop"
                        aria-pressed="false"
                    >
                        Webshops
                    </button>
                    <button
                        type="button"
                        class="filter-tab px-4 py-1.5 rounded-full font-medium text-gravel transition-colors"
                        data-filter="marketplace"
                        aria-pressed="false"
                    >
                        Marketplaces
                    </button>
                    <button
                        type="button"
                        class="filter-tab px-4 py-1.5 rounded-full font-medium text-gravel transition-colors"
                        data-filter="carrier"
                        aria-pressed="false"
                    >
                        Carriers
                    </button>
                </div>
            </div>

            {webshops.length > 0 && (
                <div class="integration-group mb-16" data-group="webshop">
                    <div class="flex items-baseline justify-between mb-6">
                        <h2 class="eyebrow">Webshops</h2>
                        <span class="text-xs text-gravel">
                            {webshops.length} {webshops.length === 1 ? 'webshop' : 'webshops'}
                        </span>
                    </div>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                        {webshops.map((i) => (
                            <IntegrationCard
                                {...i.data}
                                href={`/en/integrations/${i.data.slug}`}
                            />
                        ))}
                    </div>
                </div>
            )}

            {marketplaces.length > 0 && (
                <div class="integration-group mb-16" data-group="marketplace">
                    <div class="flex items-baseline justify-between mb-6">
                        <h2 class="eyebrow">Marketplaces</h2>
                        <span class="text-xs text-gravel">
                            {marketplaces.length} {marketplaces.length === 1 ? 'marketplace' : 'marketplaces'}
                        </span>
                    </div>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                        {marketplaces.map((i) => (
                            <IntegrationCard
                                {...i.data}
                                href={`/en/integrations/${i.data.slug}`}
                            />
                        ))}
                    </div>
                </div>
            )}

            {carriers.length > 0 && (
                <div class="integration-group" data-group="carrier">
                    <div class="flex items-baseline justify-between mb-6">
                        <h2 class="eyebrow">Carriers</h2>
                        <span class="text-xs text-gravel">
                            {carriers.length} carriers
                        </span>
                    </div>
                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                        {carriers.map((i) => (
                            <IntegrationCard
                                {...i.data}
                                href={`/en/integrations/${i.data.slug}`}
                            />
                        ))}
                    </div>
                </div>
            )}
        </div>
    </section>

    <section class="pb-12 md:pb-16">
        <div class="container-prose">
            <div class="mb-12 md:mb-16">
                <p class="eyebrow mb-4">Popular combinations</p>
                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight">
                    Two channels at once, one workflow.
                </h2>
                <p class="mt-6 text-steel leading-relaxed max-w-2xl">
                    Many shops already run multiple channels side by side. For these combinations we have written extra detail on what the connection does for you in practice.
                </p>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                {popularCombinations.map((combo) => (
                    <a
                        href={combo.href}
                        class="group relative block bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 transition duration-300 ease-out hover:ring-chalk-darker hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]"
                    >
                        <div class="flex items-center gap-2 mb-4">
                            <div class="h-10 w-10 rounded-lg bg-paper ring-1 ring-chalk-dark flex items-center justify-center overflow-hidden flex-shrink-0">
                                <img
                                    src={combo.fromLogo}
                                    alt=""
                                    class="h-full w-full object-contain p-1.5"
                                    loading="lazy"
                                />
                            </div>
                            <i class="fa-solid fa-arrow-right-arrow-left text-xs text-gravel" aria-hidden="true"></i>
                            <div class="h-10 w-10 rounded-lg bg-paper ring-1 ring-chalk-dark flex items-center justify-center overflow-hidden flex-shrink-0">
                                <img
                                    src={combo.toLogo}
                                    alt=""
                                    class="h-full w-full object-contain p-1.5"
                                    loading="lazy"
                                />
                            </div>
                        </div>
                        <p class="eyebrow !text-gravel mb-1">Combination</p>
                        <h3 class="text-base font-semibold text-charcoal tracking-tight">
                            {combo.from} and {combo.to}
                        </h3>
                        <p class="mt-3 text-sm text-steel leading-relaxed">
                            {combo.body}
                        </p>
                        <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-charcoal group-hover:text-sunstone-deep transition-colors">
                            View the integration
                            <i class="fa-solid fa-arrow-right text-[10px] transition-transform group-hover:translate-x-0.5" aria-hidden="true"></i>
                        </span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <section class="pb-20 md:pb-28">
        <div class="container-prose">
            <div class="max-w-2xl mx-auto text-center rounded-2xl ring-1 ring-chalk-dark bg-chalk-light px-8 py-12">
                <p class="eyebrow mb-4">Missing an integration?</p>
                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight">
                    Let us know.
                </h2>
                <p class="mt-4 text-steel leading-relaxed">
                    We are constantly building new connections. Tell us which tool you use and we will see if we can pick it up.
                </p>
                <div class="mt-7 flex flex-col sm:flex-row gap-3 justify-center">
                    <a
                        href="mailto:contact@shoplinkr.com?subject=Integration%20request"
                        class="btn btn-secondary text-sm"
                    >
                        <i class="fa-solid fa-envelope text-xs" aria-hidden="true"></i>
                        Send us an email
                    </a>
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>

<style>
    .filter-tab {
        cursor: pointer;
        border: 0;
        background: transparent;
    }

    .filter-tab.is-active {
        background-color: var(--color-paper, #fff);
        color: var(--color-charcoal);
        box-shadow: 0 1px 2px rgba(25, 25, 25, 0.08);
    }

    .filter-tab:not(.is-active):hover {
        color: var(--color-charcoal);
    }

    .integration-group.is-hidden {
        display: none;
    }
</style>

<script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
    const groups = document.querySelectorAll<HTMLElement>('.integration-group');
    const resultCount = document.querySelector<HTMLElement>('[data-result-count]');

    const totalByGroup: Record<string, number> = {};
    groups.forEach((group) => {
        const key = group.dataset.group ?? '';
        const cards = group.querySelectorAll('[data-integration]').length;
        totalByGroup[key] = cards;
    });
    const grandTotal = Object.values(totalByGroup).reduce((acc, n) => acc + n, 0);

    const labelFor = (filter: string, count: number): string => {
        if (filter === 'webshop') {
            return `${count} ${count === 1 ? 'webshop' : 'webshops'} available`;
        }
        if (filter === 'marketplace') {
            return `${count} ${count === 1 ? 'marketplace' : 'marketplaces'} available`;
        }
        if (filter === 'carrier') {
            return `${count} ${count === 1 ? 'carrier' : 'carriers'} available`;
        }
        return `${count} integrations available`;
    };

    const applyFilter = (tab: HTMLButtonElement): void => {
        const filter = tab.dataset.filter ?? 'all';

        tabs.forEach((t) => {
            const active = t === tab;
            t.classList.toggle('is-active', active);
            t.setAttribute('aria-pressed', active ? 'true' : 'false');
            t.classList.toggle('text-charcoal', active);
            t.classList.toggle('text-gravel', !active);
        });

        groups.forEach((group) => {
            if (filter === 'all') {
                group.classList.remove('is-hidden');
                return;
            }
            const matches = group.dataset.group === filter;
            group.classList.toggle('is-hidden', !matches);
        });

        if (resultCount) {
            const count = filter === 'all'
                ? grandTotal
                : (totalByGroup[filter] ?? 0);
            resultCount.textContent = labelFor(filter, count);
        }
    };

    tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => applyFilter(tab));

        tab.addEventListener('keydown', (event) => {
            if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') {
                return;
            }
            event.preventDefault();
            const direction = event.key === 'ArrowRight' ? 1 : -1;
            const next = tabs[(index + direction + tabs.length) % tabs.length];
            next.focus();
            applyFilter(next);
        });
    });
</script>
