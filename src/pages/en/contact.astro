---
import PageLayout from '../../layouts/PageLayout.astro';
import ContactForm from '../../components/islands/ContactForm.vue';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPageEn } from '../../data/faqs-en';
import { localizeHref } from '../../i18n/routes';
const locale = 'en';

const channels = [
    {
        eyebrow: 'Send a message',
        title: 'Fill in the form.',
        body: 'For specific questions, a quick intro or feedback. Reply usually within 2 hours during office hours.',
        icon: 'fa-duotone fa-solid fa-paper-plane',
        href: '#contactformulier',
        cta: 'Go to the form',
        external: false,
    },
    {
        eyebrow: 'Book a demo',
        title: 'Pick a slot in our calendar.',
        body: 'Twenty minutes walking through ShopLinkr together, tailored to your warehouse. No sales script.',
        icon: 'fa-duotone fa-solid fa-calendar-check',
        href: externalLinks.demoBooking,
        cta: 'Book a demo',
        external: true,
    },
    {
        eyebrow: 'Look it up yourself',
        title: 'Visit the help center.',
        body: 'Hundreds of articles with explanations, video and step by step guides. You will often find your answer here right away.',
        icon: 'fa-duotone fa-solid fa-book-open-cover',
        href: '/support',
        cta: 'Go to the help center',
        external: false,
    },
];

const expectations = [
    {
        title: 'A fast reply from a human.',
        body: 'Reply usually within 2 hours during office hours. No ticket in a queue, no bot.',
        icon: 'fa-duotone fa-solid fa-bolt',
    },
    {
        title: 'Someone who knows ShopLinkr.',
        body: 'You speak directly with our team. No warm handover, no repeating yourself.',
        icon: 'fa-duotone fa-solid fa-user-headset',
    },
    {
        title: 'No sales pressure.',
        body: 'We help you out, even if you are still unsure or not yet a customer. No strings attached.',
        icon: 'fa-duotone fa-solid fa-handshake',
    },
];

const faqs = faqsByPageEn.contact;

const jsonLd = [
    breadcrumbs([
        ['Home', '/en'],
        ['Contact', '/en/contact'],
    ]),
    {
        '@type': 'ContactPage',
        name: 'Contact | ShopLinkr',
        description: 'Get in touch with ShopLinkr. Send a message, book a demo or visit the help center. Reply usually within 2 hours during office hours.',
        mainEntity: {
            '@type': 'Organization',
            name: 'ShopLinkr',
            url: 'https://shoplinkr.com',
            contactPoint: [
                {
                    '@type': 'ContactPoint',
                    contactType: 'customer support',
                    email: 'contact@shoplinkr.com',
                    telephone: '+31649781212',
                    availableLanguage: ['Dutch', 'English'],
                    hoursAvailable: {
                        '@type': 'OpeningHoursSpecification',
                        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
                        opens: '08:30',
                        closes: '17:00',
                    },
                },
            ],
        },
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Contact | ShopLinkr"
    description="Send a message, book a demo or visit the help center. Reply usually within 2 hours during office hours."
    eyebrow="Contact"
    heading="Let's talk."
    subheading="A quick question, a first introduction or an in depth conversation about your warehouse. Pick the way that suits you best."
    routeKey="contact"
    jsonLd={jsonLd}
>
    <section class="pt-4 pb-12 md:pb-16">
        <div class="container-prose">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
                {
                    channels.map((channel) => (
                        <a
                            href={channel.external ? channel.href : localizeHref(channel.href, locale)}
                            target={channel.external ? '_blank' : undefined}
                            rel={channel.external ? 'noopener noreferrer' : undefined}
                            class="group flex flex-col gap-5 bg-paper rounded-2xl ring-1 ring-chalk-dark p-7 md:p-8 transition duration-300 ease-out hover:ring-chalk-darker hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]"
                        >
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${channel.icon} text-[1.15rem]`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div class="flex-1">
                                <p class="eyebrow mb-2">{channel.eyebrow}</p>
                                <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug mb-3">
                                    {channel.title}
                                </h3>
                                <p class="text-sm md:text-[0.975rem] text-steel leading-relaxed">
                                    {channel.body}
                                </p>
                            </div>
                            <span class="inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                                {channel.cta}
                                <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <section id="contactformulier" class="py-24 md:py-32 bg-chalk-light scroll-mt-24">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-7">
                    <ContactForm client:load locale="en" />
                </div>

                <aside class="lg:col-span-5 space-y-6">
                    <div class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-7 md:p-8">
                        <p class="eyebrow mb-4">What to expect</p>
                        <ul class="space-y-5">
                            {
                                expectations.map((item) => (
                                    <li class="flex items-start gap-4">
                                        <div class="flex-shrink-0 flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                            <i class={`${item.icon} text-base`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                                        </div>
                                        <div>
                                            <p class="text-base font-semibold text-charcoal tracking-tight leading-snug">
                                                {item.title}
                                            </p>
                                            <p class="text-sm text-steel leading-relaxed mt-1">
                                                {item.body}
                                            </p>
                                        </div>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-7 md:p-8">
                        <p class="eyebrow mb-4">Reach us directly</p>
                        <div class="space-y-5">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gravel mb-1.5">Email</p>
                                <a
                                    href="mailto:contact@shoplinkr.com"
                                    class="inline-flex items-center gap-2 py-2 min-h-11 text-charcoal font-semibold hover:text-sunstone-deep transition-colors"
                                >
                                    <i class="fa-solid fa-envelope text-sm text-sunstone-deep" aria-hidden="true"></i>
                                    contact@shoplinkr.com
                                </a>
                            </div>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gravel mb-1.5">Phone</p>
                                <a
                                    href="tel:+31649781212"
                                    class="inline-flex items-center gap-2 py-2 min-h-11 text-charcoal font-semibold hover:text-sunstone-deep transition-colors"
                                >
                                    <i class="fa-solid fa-phone text-sm text-sunstone-deep" aria-hidden="true"></i>
                                    +31 6 49 78 12 12
                                </a>
                            </div>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.14em] text-gravel mb-1.5">Availability</p>
                                <p class="text-charcoal font-semibold">
                                    Monday to Friday
                                </p>
                                <p class="text-sm text-steel mt-0.5">
                                    08:30 to 17:00
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="bg-charcoal text-paper rounded-2xl p-7 md:p-8">
                        <i class="fa-solid fa-quote-left text-sunstone-soft text-xl mb-4" aria-hidden="true"></i>
                        <p class="text-paper/90 text-base md:text-[1.05rem] leading-relaxed">
                            The service is excellent and the team is always ready to help quickly and kindly. You can tell they really think along with you.
                        </p>
                        <div class="mt-5">
                            <p class="text-sm font-semibold text-paper">
                                Nick Siep
                            </p>
                            <p class="text-xs text-paper/60 mt-0.5">
                                Voordelig Inslaan
                            </p>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Frequently asked questions</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Maybe your question
                        <span class="block text-sunstone-deep">is already answered here.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        A few things we get asked more often. If your question is not here, send us a message.
                    </p>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>
</PageLayout>
