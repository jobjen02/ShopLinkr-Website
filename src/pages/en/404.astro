---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { externalLinks } from '../../data/externalLinks';
import { localizeHref } from '../../i18n/routes';
const locale = 'en';

const quickLinks = [
    {
        title: 'Features',
        body: 'See everything ShopLinkr can do.',
        href: localizeHref('/functionaliteiten', locale),
        icon: 'fa-solid fa-grid-2',
    },
    {
        title: 'Integrations',
        body: 'See which channels and carriers we connect with.',
        href: localizeHref('/integraties', locale),
        icon: 'fa-solid fa-plug',
    },
    {
        title: 'Support',
        body: 'Find answers in our help articles.',
        href: localizeHref('/support', locale),
        icon: 'fa-solid fa-life-ring',
    },
    {
        title: 'Pricing',
        body: 'See what ShopLinkr costs per month.',
        href: localizeHref('/prijzen', locale),
        icon: 'fa-solid fa-tag',
    },
];

export const prerender = true;
---

<BaseLayout
    title="Page not found | ShopLinkr"
    description="The page you are looking for no longer exists or has moved. Find what you need right here."
>
    <section class="py-20 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mx-auto text-center">
                <p class="eyebrow mb-5">404</p>
                <h1 class="text-4xl md:text-6xl font-semibold text-charcoal tracking-tight leading-[1.05]">
                    Sorry, this page
                    <span class="block text-sunstone-deep">can no longer be found.</span>
                </h1>
                <p class="mt-7 text-lg text-steel leading-relaxed max-w-xl mx-auto">
                    The link may be outdated, or the page has moved. Try one of the shortcuts below or head back to the homepage.
                </p>

                <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
                    <a
                        href={localizeHref('/', locale)}
                        class="btn btn-sunstone text-base"
                    >
                        Back to home
                        <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                    </a>
                    <a
                        href={externalLinks.demoBooking}
                        class="btn btn-secondary text-base"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        Book a demo
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-3xl mx-auto">
                <p class="eyebrow mb-4 text-center">Or go straight to</p>
                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight leading-[1.15] text-center mb-10">
                    What are you looking for?
                </h2>

                <ul class="grid sm:grid-cols-2 gap-3">
                    {
                        quickLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="group flex items-start gap-4 bg-paper rounded-xl ring-1 ring-chalk-dark hover:ring-sunstone-soft hover:bg-sunstone-mist/30 px-5 py-5 transition-all duration-200"
                                >
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-10 w-10 rounded-lg bg-chalk-light text-gravel group-hover:bg-sunstone-mist group-hover:text-sunstone-deep transition-colors">
                                        <i class={`${link.icon} text-sm`} aria-hidden="true"></i>
                                    </span>
                                    <div class="flex-1">
                                        <p class="text-[15px] font-semibold text-charcoal group-hover:text-sunstone-deep transition-colors">
                                            {link.title}
                                        </p>
                                        <p class="mt-0.5 text-sm text-gravel">
                                            {link.body}
                                        </p>
                                    </div>
                                    <i class="fa-solid fa-arrow-right text-xs text-gravel group-hover:text-sunstone-deep group-hover:translate-x-0.5 transition-all mt-3" aria-hidden="true"></i>
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>
        </div>
    </section>
</BaseLayout>
