---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import SupportArticlePage from '../../../components/pages/SupportArticlePage.astro';
import {
    supportCategoriesEnBySlug,
} from '../../../data/supportCategories-en';
import { findSubcategoryBySlug } from '../../../data/supportCategories';

export const getStaticPaths: GetStaticPaths = async () => {
    const articles = await getCollection('supportArticlesEn');
    return articles.map((article) => ({
        params: {
            slug: article.id.split('/').pop(),
        },
        props: {
            article,
            allArticles: articles,
        },
    }));
};

const { article, allArticles } = Astro.props;

const categoryInfo = supportCategoriesEnBySlug[article.data.category];
const subcategoryInfo = categoryInfo && article.data.subcategory
    ? findSubcategoryBySlug(categoryInfo, article.data.subcategory)
    : undefined;

const articleSlug = article.id.split('/').pop();
const canonicalUrl = `https://shoplinkr.com/en/support/${articleSlug}`;

const alternates = article.data.translationKey
    ? { nl: `/support/${article.data.translationKey}`, en: `/en/support/${articleSlug}` }
    : { en: `/en/support/${articleSlug}` };

const articleId = article.id;
const sameSubcategoryArticles = allArticles
    .filter((a) => {
        return a.id !== articleId
            && a.data.category === article.data.category
            && article.data.subcategory !== undefined
            && a.data.subcategory === article.data.subcategory;
    })
    .sort((a, b) => a.data.order - b.data.order);

const sameCategoryArticles = allArticles
    .filter((a) => {
        return a.id !== articleId
            && a.data.category === article.data.category
            && a.data.subcategory !== article.data.subcategory;
    })
    .sort((a, b) => a.data.order - b.data.order);

const relatedArticles = [...sameSubcategoryArticles, ...sameCategoryArticles]
    .slice(0, 4)
    .map((a) => {
        const slug = a.id.split('/').pop() ?? a.id;
        return {
            title: a.data.title,
            summary: a.data.summary,
            href: `/en/support/${slug}`,
            subcategoryLabel: a.data.subcategoryLabel ?? null,
        };
    });

const lastUpdatedFormatted = new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
}).format(article.data.lastUpdated);

const articleSchema = {
    '@type': 'TechArticle',
    headline: article.data.title,
    description: article.data.summary,
    dateModified: article.data.lastUpdated.toISOString(),
    datePublished: article.data.lastUpdated.toISOString(),
    inLanguage: 'en-US',
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
    },
    articleSection: article.data.categoryLabel,
    author: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        url: 'https://shoplinkr.com',
    },
    publisher: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        logo: {
            '@type': 'ImageObject',
            url: 'https://shoplinkr.com/logo/logo-charcoal.svg',
        },
    },
};

const breadcrumbItems = [
    {
        href: '/en/support',
        label: 'Support',
    },
];

if (categoryInfo) {
    breadcrumbItems.push({
        href: `/en/support/categories/${categoryInfo.slug}`,
        label: categoryInfo.label,
    });
}

if (categoryInfo && subcategoryInfo) {
    breadcrumbItems.push({
        href: `/en/support/categories/${categoryInfo.slug}/${subcategoryInfo.slug}`,
        label: subcategoryInfo.label,
    });
}

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com/en',
        },
        ...breadcrumbItems.map((item, index) => ({
            '@type': 'ListItem',
            position: index + 2,
            name: item.label,
            item: `https://shoplinkr.com${item.href}`,
        })),
        {
            '@type': 'ListItem',
            position: breadcrumbItems.length + 2,
            name: article.data.title,
            item: canonicalUrl,
        },
    ],
};

const jsonLd = [articleSchema, breadcrumbSchema];

export const prerender = true;
---

<SupportArticlePage
    article={article}
    categoryInfo={categoryInfo}
    breadcrumbItems={breadcrumbItems}
    relatedArticles={relatedArticles}
    lastUpdatedFormatted={lastUpdatedFormatted}
    jsonLd={jsonLd}
    alternates={alternates}
/>
