---
import { getCollection } from 'astro:content';
import SupportSubcategoryPage from '../../../../../../components/pages/SupportSubcategoryPage.astro';
import { findSubcategoryBySlug } from '../../../../../../data/supportCategories';
import {
    supportCategoriesEn,
    supportCategoriesEnBySlug,
    CATEGORY_SLUG_NL_TO_EN,
    SUBCATEGORY_SLUG_NL_TO_EN,
} from '../../../../../../data/supportCategories-en';

export async function getStaticPaths() {
    return supportCategoriesEn.flatMap((c) => c.subcategories.map((s) => ({
        params: {
            category: c.slug,
            subcategory: s.slug,
        },
    })));
}

const { category, subcategory } = Astro.params;
const categoryInfo = supportCategoriesEnBySlug[category as string];
const subcategoryInfo = categoryInfo ? findSubcategoryBySlug(categoryInfo, subcategory as string) : undefined;

if (!categoryInfo || !subcategoryInfo) {
    throw new Error(`Unknown support path: ${category}/${subcategory}`);
}

const nlCategorySlug = Object.entries(CATEGORY_SLUG_NL_TO_EN).find(([, en]) => en === category)?.[0];
const nlSubcategorySlug = Object.entries(SUBCATEGORY_SLUG_NL_TO_EN).find(([, en]) => en === subcategory)?.[0];
const alternates = nlCategorySlug && nlSubcategorySlug
    ? {
        nl: `/support/categorieen/${nlCategorySlug}/${nlSubcategorySlug}`,
        en: `/en/support/categories/${categoryInfo.slug}/${subcategoryInfo.slug}`,
    }
    : { en: `/en/support/categories/${categoryInfo.slug}/${subcategoryInfo.slug}` };

const allArticles = await getCollection('supportArticlesEn');
const articlesInSubcategory = allArticles
    .filter((a) => a.data.category === category && a.data.subcategory === subcategoryInfo.slug)
    .sort((a, b) => a.data.order - b.data.order);

const siblingSubcategories = categoryInfo.subcategories.filter((s) => s.slug !== subcategory);
const otherSubcategories = supportCategoriesEn
    .filter((c) => c.slug !== category)
    .flatMap((c) => c.subcategories.slice(0, 1).map((s) => ({
        categorySlug: c.slug,
        subSlug: s.slug,
        label: s.label,
    })));

const otherTopics = [
    ...siblingSubcategories.map((s) => ({
        categorySlug: category as string,
        subSlug: s.slug,
        label: s.label,
    })),
    ...otherSubcategories,
].slice(0, 6);

const collectionSchema = {
    '@type': 'CollectionPage',
    name: `${subcategoryInfo.label} | ${categoryInfo.label} | ShopLinkr Support`,
    description: subcategoryInfo.summary ?? `Support articles about ${subcategoryInfo.label}.`,
    url: `https://shoplinkr.com/en/support/categories/${categoryInfo.slug}/${subcategoryInfo.slug}`,
    inLanguage: 'en-US',
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com/en',
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: 'Support',
            item: 'https://shoplinkr.com/en/support',
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: categoryInfo.label,
            item: `https://shoplinkr.com/en/support/categories/${categoryInfo.slug}`,
        },
        {
            '@type': 'ListItem',
            position: 4,
            name: subcategoryInfo.label,
            item: `https://shoplinkr.com/en/support/categories/${categoryInfo.slug}/${subcategoryInfo.slug}`,
        },
    ],
};

const jsonLd = [collectionSchema, breadcrumbSchema];

export const prerender = true;
---

<SupportSubcategoryPage
    categoryInfo={categoryInfo}
    subcategoryInfo={subcategoryInfo}
    articlesInSubcategory={articlesInSubcategory}
    otherTopics={otherTopics}
    alternates={alternates}
    jsonLd={jsonLd}
/>
