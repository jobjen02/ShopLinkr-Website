---
import { getCollection } from 'astro:content';
import SeoArticlePage from '../../components/pages/SeoArticlePage.astro';
import { routes } from '../../i18n/routes';

export async function getStaticPaths() {
    const pages = await getCollection('seoPagesEn');

    // Build guard: an EN root-served SEO slug must not collide with a reserved
    // /en/ route (a localized page slug or a real page/dir under src/pages/en).
    const reserved = new Set<string>();
    for (const r of Object.values(routes)) {
        if (r.en && !r.en.includes('/')) reserved.add(r.en);
    }
    for (const file of Object.keys(import.meta.glob('./*.astro'))) {
        const seg = file.replace('./', '').replace('.astro', '');
        if (seg !== '[slug]' && seg !== 'index') reserved.add(seg);
    }
    ['blog', 'features', 'integrations', 'support'].forEach((s) => reserved.add(s));

    for (const page of pages) {
        if (reserved.has(page.id)) {
            throw new Error(
                `EN SEO page slug "${page.id}" collides with a reserved /en/ route. Rename src/content/seo-en/${page.id}.md (and its redirect/links) or the conflicting route.`,
            );
        }
    }

    return pages.map((page) => ({
        params: { slug: page.id },
        props: { page },
    }));
}

const { page } = Astro.props;

const alternates = page.data.translationKey
    ? { nl: `/${page.data.translationKey}`, en: `/en/${page.id}` }
    : undefined;

const canonicalUrl = `https://shoplinkr.com/en/${page.id}`;

const articleSchema = {
    '@type': 'Article',
    headline: page.data.title,
    description: page.data.excerpt,
    datePublished: page.data.publishedAt.toISOString(),
    dateModified: page.data.publishedAt.toISOString(),
    inLanguage: 'en-US',
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
    author: { '@type': 'Organization', name: page.data.author || 'ShopLinkr', url: 'https://shoplinkr.com' },
    publisher: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        logo: { '@type': 'ImageObject', url: 'https://shoplinkr.com/logo/logo-charcoal.svg' },
    },
    ...(page.data.image && { image: `https://shoplinkr.com${page.data.image}` }),
    ...(page.data.category && { articleSection: page.data.category }),
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://shoplinkr.com/en' },
        { '@type': 'ListItem', position: 2, name: page.data.title, item: canonicalUrl },
    ],
};

const jsonLd = [articleSchema, breadcrumbSchema];

export const prerender = true;
---

<SeoArticlePage page={page} alternates={alternates} jsonLd={jsonLd} />
