---
import PageLayout from '../layouts/PageLayout.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { externalLinks } from '../data/externalLinks';

const rows = [
    {
        eyebrow: 'Eén overzicht',
        heading: 'Je hele webshop in één oogopslag.',
        body: 'Bestellingen, voorraad, klanten en retouren samen op één scherm. Geen schakelen tussen Bol, Shopify, WooCommerce en je vervoerdersportaal. Je werkt vanaf nu vanuit één centrale plek, ongeacht waar de bestelling vandaan komt.',
        icon: 'fa-solid fa-grip',
    },
    {
        eyebrow: 'Bulk',
        heading: 'Bestellingen in bulk verwerken.',
        body: 'Selecteer een stapel bestellingen en print picklijsten, verzendlabels en pakbonnen in één handeling. Tijdens piekdagen scheelt dat uren werk, en je werkstroom blijft soepel ook als de orders binnenstromen.',
        icon: 'fa-solid fa-layer-group',
    },
    {
        eyebrow: 'Realtime sync',
        heading: 'Voorraad die altijd klopt.',
        body: 'Verkoop je iets op het ene kanaal, dan past ShopLinkr je voorraad meteen aan op de andere. Geen oversells, geen geannuleerde bestellingen en geen vervelende klantgesprekken meer over iets dat eigenlijk al uitverkocht was.',
        icon: 'fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Tijdwinst',
        heading: 'Ruim een uur per dag terugkrijgen.',
        body: 'Klanten van ons winnen vaak ruim een uur per dag terug bij gemiddeld vijftig bestellingen. Dat is tijd die je in groei steekt in plaats van in handwerk: nieuwe producten zoeken, marketing draaien of gewoon vroeger naar huis.',
        icon: 'fa-solid fa-clock',
    },
    {
        eyebrow: 'Zonder gedoe',
        heading: 'Vandaag aanmelden, vandaag werken.',
        body: 'Je probeert ShopLinkr 14 dagen gratis uit. Geen creditcard, geen lange contracten, geen consultants. Koppel je kanalen, importeer je producten en draai meteen je eerste orders door het systeem.',
        icon: 'fa-solid fa-bolt',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Efficiënt webshopbeheer - ShopLinkr',
    description: 'Maak gebruik van ShopLinkr, syncroniseer je voorraad en verwerk bestellingen efficiënter dan ooit. Voorraadbeheer, picklijsten en verzending in één werkstroom.',
};

export const prerender = true;
---

<PageLayout
    title="Efficiënt webshopbeheer - ShopLinkr"
    description="Maak gebruik van ShopLinkr, syncroniseer je voorraad en verwerk bestellingen efficiënter dan ooit. Voorraadbeheer, picklijsten en verzending in één werkstroom."
    eyebrow="Efficiënt webshopbeheer"
    heading="Beheer je webshop efficiënter met ShopLinkr."
    subheading="Synchroniseer je voorraad, verwerk bestellingen in bulk en houd al je verkoopkanalen op één plek in de hand. Zo wordt je werkstroom eindelijk overzichtelijk."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Jouw werkdag, soepeler</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Jouw volledige webshopbeheer in één oogopslag.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Je hoeft niet langer per kanaal in een ander scherm te werken. ShopLinkr brengt je voorraad, je bestellingen en je verzending samen in één werkstroom, zodat je sneller schakelt en minder fouten maakt.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
