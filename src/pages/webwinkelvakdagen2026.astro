---
import PageLayout from '../layouts/PageLayout.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { externalLinks } from '../data/externalLinks';

const eventInfo = [
    {
        label: 'Editie',
        value: '20 en 21 januari 2026',
        icon: 'fa-solid fa-calendar-days',
    },
    {
        label: 'Locatie',
        value: 'Jaarbeurs Utrecht',
        icon: 'fa-solid fa-location-dot',
    },
    {
        label: 'Volgende editie',
        value: 'Plan een demo in tussendoor',
        icon: 'fa-solid fa-arrow-right',
    },
];

const reasons = [
    {
        eyebrow: 'Persoonlijk gesprek',
        heading: 'Praat met ons team in dezelfde sfeer.',
        body: 'Wat we op de Webwinkel Vakdagen het leukste vonden, doen we elke week via een online demo. Een gesprek over jouw werkstroom, je kanalen en wat ShopLinkr voor jouw situatie kan betekenen. Geen verkooppraatje, gewoon meedenken.',
        icon: 'fa-solid fa-comments',
    },
    {
        eyebrow: 'Live demo',
        heading: 'Zie ShopLinkr in actie.',
        body: 'We laten je live zien hoe een verkoop op bol direct je voorraad bijwerkt in Shopify of WooCommerce, hoe je picklijsten draait met locaties en hoe je verzendlabels in bulk print. Geen verhaal, gewoon zien hoe het werkt.',
        icon: 'fa-solid fa-display',
    },
    {
        eyebrow: 'Vrijblijvend starten',
        heading: '14 dagen gratis uitproberen.',
        body: 'Heb je het op de beurs gemist of wil je gewoon snel aan de slag? Maak een account aan en draai 14 dagen je eigen orders door ShopLinkr. Geen creditcard nodig, maandelijks opzegbaar.',
        icon: 'fa-solid fa-bolt',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Webwinkel Vakdagen 2026 - ShopLinkr',
    description: 'We waren aanwezig op de Webwinkel Vakdagen 2026 in de Jaarbeurs Utrecht. Plan een demo in voor een persoonlijk gesprek over je voorraadbeheer.',
};

export const prerender = true;
---

<PageLayout
    title="Webwinkel Vakdagen 2026 - ShopLinkr"
    description="We waren aanwezig op de Webwinkel Vakdagen 2026 in de Jaarbeurs Utrecht. Plan een demo in voor een persoonlijk gesprek over je voorraadbeheer."
    eyebrow="Webwinkel Vakdagen 2026"
    heading="We waren erbij op de Webwinkel Vakdagen 2026."
    subheading="Wat een geweldige editie. Bedankt voor alle goede gesprekken in de Jaarbeurs Utrecht. Wil je alsnog kennismaken? Plan een online demo in, dan praten we je rustig bij."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.register}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                </a>
            </div>
        </div>
    </section>

    <section class="py-16 md:py-20 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-4xl">
                <p class="eyebrow mb-4">Terugblik</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1] mb-10">
                    Bedankt voor de mooie editie.
                </h2>

                <div class="grid md:grid-cols-3 gap-6">
                    {
                        eventInfo.map((info) => (
                            <div class="bg-paper rounded-2xl p-7 ring-1 ring-chalk-dark">
                                <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                    <i class={`${info.icon} text-base`} aria-hidden="true" />
                                </div>
                                <p class="eyebrow mb-2">{info.label}</p>
                                <p class="text-lg font-semibold text-charcoal tracking-tight leading-snug">
                                    {info.value}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Beurs gemist?</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Geen probleem, we praten je graag bij.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    De Webwinkel Vakdagen 2026 zit erop, maar de gesprekken die we daar hadden voeren we het hele jaar door. Plan een online demo in, dan kijken we samen wat ShopLinkr voor jouw werkstroom kan doen.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    reasons.map((reason) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${reason.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{reason.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{reason.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{reason.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{reason.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {reason.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>

            <div class="mt-16 max-w-3xl">
                <p class="text-base text-steel leading-relaxed">
                    Liever direct aan de slag? Maak een account aan en start je gratis proefperiode van 14 dagen. Je hoeft geen creditcard achter te laten, en je kunt elk moment maandelijks opzeggen.
                </p>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
