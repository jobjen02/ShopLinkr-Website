---
import PageLayout from '../layouts/PageLayout.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { externalLinks } from '../data/externalLinks';

const rows = [
    {
        eyebrow: 'Waarom meerdere',
        heading: 'Meerdere bol-accounts gebruiken zie je vaker.',
        body: 'Veel verkopers splitsen hun bol.com-activiteiten over twee accounts, bijvoorbeeld voor de Nederlandse en de Belgische markt apart. Zo houd je controle over regiogebonden prijzen, levertijden en assortiment. Het is een gezonde keuze, maar je krijgt er ook beheer-uitdagingen bij.',
        icon: 'fa-solid fa-layer-group',
    },
    {
        eyebrow: 'Dubbel werk',
        heading: 'Je beheert je productaanbod nu twee keer.',
        body: 'Per account moet je je content bijhouden, je prijzen onderhouden en je levertijden goed zetten. Verandert er iets aan een product, dan moet je dat op beide kanten doortrekken. Dat kost niet alleen tijd, het is ook een grote bron van fouten.',
        icon: 'fa-solid fa-copy',
    },
    {
        eyebrow: 'Versplinterde voorraad',
        heading: 'Eén fysieke voorraad, twee accounts.',
        body: 'Je hebt niet ineens twee voorraden in je magazijn. Je hebt één stapel producten, maar die staat administratief verdeeld over twee accounts. Het risico dat je hetzelfde product op beide kanten verkoopt is dan ook reëel, met oversells en boze klanten als gevolg.',
        icon: 'fa-solid fa-arrows-split-up-and-left',
    },
    {
        eyebrow: 'Centraliseren',
        heading: 'Beide accounts samen op één plek.',
        body: 'Koppel beide bol-accounts aan ShopLinkr. Wij koppelen automatisch de producten aan elkaar, zodat ze als één voorraad worden behandeld. Verkoop je op het ene account, dan past ShopLinkr de voorraad direct aan op het andere. Geen oversells meer, ongeacht waar de bestelling vandaan komt.',
        icon: 'fa-solid fa-grip',
    },
    {
        eyebrow: 'Eén werkstroom',
        heading: 'Bestellingen samen, verwerking samen.',
        body: 'Alle bestellingen uit je verschillende accounts komen samen in één overzicht. Je print picklijsten over alle accounts heen, draait verzendlabels in bulk en stuurt je track en trace terug naar het juiste account. Het maakt niet meer uit van welk account een order komt.',
        icon: 'fa-solid fa-list-check',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Meerdere bol accounts koppelen aan ShopLinkr',
    description: 'Met ShopLinkr verwerk je eenvoudig bestellingen van al je webshops op één centrale plek.',
};

export const prerender = true;
---

<PageLayout
    title="Meerdere bol account koppelen aan ShopLinkr"
    description="Met ShopLinkr verwerk je eenvoudig bestellingen van al je webshops op één centrale plek."
    eyebrow="Meerdere bol accounts"
    heading="Meerdere bol-accounts beheren, zonder dubbel werk."
    subheading="Werk je met meerdere bol-accounts, bijvoorbeeld voor Nederland en België? ShopLinkr koppelt ze aan elkaar en houdt je voorraad op beide accounts altijd kloppend."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Twee accounts, één werkstroom</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Van twee aparte werelden naar één overzicht.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Met meerdere bol-accounts werken brengt voordelen, maar ook een hoop dubbel werk en risico op fouten. ShopLinkr brengt je accounts samen, zodat je in plaats van twee omgevingen één centrale werkplek hebt.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
