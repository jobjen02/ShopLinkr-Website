---
import PageLayout from '../layouts/PageLayout.astro';

const lastUpdated = '2026-05-28';

const categories = [
    {
        title: 'Noodzakelijke cookies',
        eyebrow: 'Altijd actief',
        body: 'Deze cookies zijn nodig om de site goed te laten werken. Denk aan inloggen, formulieren versturen en je sessie onthouden. Zonder deze cookies werkt de site niet correct.',
        items: [
            {
                name: 'shoplinkr-cookie-consent',
                purpose: 'Onthoudt je cookie-voorkeuren',
                duration: '12 maanden',
            },
            {
                name: 'session',
                purpose: 'Houdt je sessie op de site actief',
                duration: 'Tot je de browser sluit',
            },
        ],
    },
    {
        title: 'Analytische cookies',
        eyebrow: 'Optioneel',
        body: 'Deze cookies helpen ons begrijpen hoe je de site gebruikt, welke pagina\'s populair zijn en waar mensen blijven hangen. We gebruiken deze inzichten om de site te verbeteren. Volledig anoniem.',
        items: [
            {
                name: '_ga, _ga_*',
                purpose: 'Google Analytics 4: bezoekers en gedrag (anoniem)',
                duration: '2 jaar',
            },
        ],
    },
    {
        title: 'Marketing cookies',
        eyebrow: 'Optioneel',
        body: 'Deze cookies worden gebruikt om je relevante content te tonen op andere platforms (LinkedIn, Meta) en om de effectiviteit van advertenties te meten. Je kunt deze altijd uitschakelen.',
        items: [
            {
                name: '_fbp',
                purpose: 'Meta Pixel: voor remarketing op Facebook en Instagram',
                duration: '3 maanden',
            },
            {
                name: 'li_*',
                purpose: 'LinkedIn Insight Tag: voor remarketing op LinkedIn',
                duration: '90 dagen',
            },
        ],
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Cookiebeleid | ShopLinkr',
    description: 'Welke cookies gebruiken we, waarom gebruiken we ze en hoe je ze beheert.',
};

export const prerender = false;
---

<PageLayout
    title="Cookiebeleid | ShopLinkr"
    description="Welke cookies gebruiken we, waarom gebruiken we ze en hoe je ze beheert."
    eyebrow="Juridisch"
    heading="Cookiebeleid."
    subheading="Welke cookies we gebruiken, waarom en hoe je ze beheert."
    routeKey="cookies"
    jsonLd={jsonLd}
>
    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl">
                <p class="text-sm text-gravel mb-10">
                    Laatst bijgewerkt: {lastUpdated}
                </p>

                <p class="text-lg text-steel leading-relaxed mb-12">
                    Bij je eerste bezoek aan onze site vraagt onze cookiebanner welke cookies je accepteert. Hieronder lees je per categorie welke cookies we gebruiken en waarvoor. Je voorkeuren kun je op elk moment aanpassen via de cookiebanner.
                </p>

                <div class="space-y-12">
                    {
                        categories.map((category) => (
                            <article>
                                <p class="eyebrow mb-3">{category.eyebrow}</p>
                                <h2 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight mb-4">
                                    {category.title}
                                </h2>
                                <p class="text-steel leading-relaxed text-[15px] md:text-base mb-6">
                                    {category.body}
                                </p>

                                <div class="overflow-x-auto rounded-xl ring-1 ring-chalk-dark">
                                    <table class="w-full text-sm">
                                        <thead class="bg-chalk-light text-xs uppercase tracking-wider text-gravel">
                                            <tr>
                                                <th class="px-4 py-3 text-left font-semibold">Naam</th>
                                                <th class="px-4 py-3 text-left font-semibold">Doel</th>
                                                <th class="px-4 py-3 text-left font-semibold">Duur</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-chalk-dark">
                                            {category.items.map((item) => (
                                                <tr>
                                                    <td class="px-4 py-3 font-mono text-charcoal">{item.name}</td>
                                                    <td class="px-4 py-3 text-steel">{item.purpose}</td>
                                                    <td class="px-4 py-3 text-steel">{item.duration}</td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                            </article>
                        ))
                    }
                </div>

                <div class="mt-16 pt-10 border-t border-chalk-dark">
                    <h2 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight mb-4">
                        Voorkeuren aanpassen
                    </h2>
                    <p class="text-steel leading-relaxed text-[15px] md:text-base mb-4">
                        Wis de cookie-instellingen in je browser om de cookiebanner opnieuw te zien. Of stuur ons een mail op <a href="mailto:contact@shoplinkr.com" class="text-charcoal font-semibold hover:text-sunstone-deep transition-colors">contact@shoplinkr.com</a> als je hulp nodig hebt.
                    </p>
                </div>
            </div>
        </div>
    </section>
</PageLayout>
