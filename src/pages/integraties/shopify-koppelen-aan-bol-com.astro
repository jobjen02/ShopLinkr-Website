---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'ShopLinkr als brug',
        heading: 'Eén platform tussen je Shopify en bol.',
        body: 'ShopLinkr zit tussen je Shopify webshop en je bol verkoopaccount in. Je koppelt allebei aan, en vanaf dat moment praten ze via ShopLinkr met elkaar. Geen losse koppelingen onderhouden, geen exports tussendoor.',
        icon: 'fa-solid fa-arrows-left-right-to-line',
    },
    {
        eyebrow: 'Matchen op EAN',
        heading: 'Producten worden automatisch herkend.',
        body: 'ShopLinkr koppelt producten in Shopify aan dezelfde producten op bol op basis van EAN. Eén keer op orde brengen, daarna weet het systeem altijd welk product bij welk kanaal hoort. Nieuwe producten neem je in een paar klikken mee.',
        icon: 'fa-solid fa-barcode',
    },
    {
        eyebrow: 'Voorraad in sync',
        heading: 'Verkocht op bol, direct lager op Shopify.',
        body: 'Verkoop je een product op bol, dan past ShopLinkr de voorraad in Shopify direct aan. Andersom net zo. Zo houd je één betrouwbare voorraad, ook als je op beide kanalen druk verkoopt. Belangrijk: ShopLinkr synct alleen voorraad en orders, niet je productcontent of prijzen.',
        icon: 'fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Bestellingen op één plek',
        heading: 'Alle orders in dezelfde bestellingenlijst.',
        body: 'Bestellingen uit Shopify en uit bol komen samen in één overzicht in ShopLinkr. Je picked, verpakt en verstuurt vanuit dezelfde flow, ongeacht waar de order vandaan komt. Eén workflow voor je magazijn, ook als je op meer kanalen verkoopt.',
        icon: 'fa-solid fa-list-check',
    },
    {
        eyebrow: 'Geen oversells',
        heading: 'Voorkom dat je verkoopt wat je niet hebt.',
        body: 'Doordat de voorraad realtime tussen je kanalen meebeweegt, verkoop je nooit per ongeluk hetzelfde laatste product twee keer. Minder annuleringen, blijere klanten en geen verkoopboetes op bol.',
        icon: 'fa-solid fa-shield-check',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Koppel je bol webshop aan Shopify',
    description: 'Koppel je bol webshop aan je eigen Shopify webshop. Je voorraad is altijd gesynchroniseerd met elkaar en bestellingen komen op een plaats binnen.',
};

export const prerender = true;
---

<PageLayout
    title="Koppel je bol webshop aan Shopify - ShopLinkr"
    description="Koppel je bol webshop aan je eigen Shopify webshop. Je voorraad is altijd gesynchroniseerd met elkaar en bestellingen komen op één plaats binnen."
    eyebrow="Shopify en bol"
    heading="Shopify koppelen met bol via ShopLinkr."
    subheading="Verkoop je via Shopify en via bol? ShopLinkr houdt je voorraad realtime in sync en verzamelt alle bestellingen op één plek. Eén workflow, geen oversells."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <a
                href="/integraties"
                class="inline-flex items-center gap-2 text-sm text-gravel hover:text-charcoal transition-colors mb-8"
            >
                <i class="fa-solid fa-arrow-left text-xs" aria-hidden="true"></i>
                Terug naar alle integraties
            </a>

            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Voorraad synchronisatie</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Eén voorraadbron voor Shopify en bol.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    ShopLinkr verbindt je Shopify webshop met je bol verkoopaccount. Voorraadmutaties gaan beide kanten op, bestellingen komen samen op één plek. Hieronder zie je hoe de koppeling werkt.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
