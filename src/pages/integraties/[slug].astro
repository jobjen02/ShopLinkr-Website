---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import IntegrationDetailPage from '../../components/pages/IntegrationDetailPage.astro';

export const getStaticPaths: GetStaticPaths = async () => {
    const integrations = await getCollection('integrations');
    return integrations.map((integration) => ({
        params: {
            slug: integration.data.slug,
        },
        props: {
            integration,
            allIntegrations: integrations,
        },
    }));
};

const { integration, allIntegrations } = Astro.props;
const { name, category, summary, supportSlug } = integration.data;

const related = allIntegrations
    .filter((i) => i.data.category === category && i.data.slug !== integration.data.slug)
    .slice(0, 3);

const supportHref = supportSlug ? `/support/${supportSlug}` : '/support';

const integrationSchema = {
    '@type': 'WebPage',
    name: `${name} koppelen aan ShopLinkr`,
    description: summary,
    url: `https://shoplinkr.com/integraties/${integration.data.slug}`,
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com',
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: 'Integraties',
            item: 'https://shoplinkr.com/integraties',
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: `${name} koppelen aan ShopLinkr`,
            item: `https://shoplinkr.com/integraties/${integration.data.slug}`,
        },
    ],
};

const faqs = integration.data.faqs;
const faqSchema = faqs && faqs.length > 0
    ? {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.q,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.a,
            },
        })),
    }
    : null;

const jsonLd = faqSchema
    ? [integrationSchema, breadcrumbSchema, faqSchema]
    : [integrationSchema, breadcrumbSchema];

const integrationsEnAll = await getCollection('integrationsEn');
const enSlugs = new Set(integrationsEnAll.map((i) => i.data.slug));
const alternates = enSlugs.has(integration.data.slug)
    ? { nl: `/integraties/${integration.data.slug}`, en: `/en/integrations/${integration.data.slug}` }
    : undefined;

export const prerender = true;
---

<IntegrationDetailPage
    integration={integration}
    related={related}
    relatedHref={(slug) => `/integraties/${slug}`}
    supportHref={supportHref}
    homeHref="/"
    integrationsHref="/integraties"
    title={`${name} koppelen aan ShopLinkr | Integraties`}
    description={summary}
    alternates={alternates}
    jsonLd={jsonLd}
/>
