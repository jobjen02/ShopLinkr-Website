---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'ShopLinkr als brug',
        heading: 'Eén platform voor twee webshops naast elkaar.',
        body: 'Heb je een WooCommerce shop en een Shopify shop tegelijk draaien? ShopLinkr legt de verbinding ertussen. Je koppelt beide aan ShopLinkr, en vanaf dat moment zit alles in één overzicht. Geen aparte tools, geen dubbele administratie.',
        icon: 'fa-solid fa-arrows-left-right-to-line',
    },
    {
        eyebrow: 'Matchen op EAN',
        heading: 'Producten worden vanzelf aan elkaar gekoppeld.',
        body: 'ShopLinkr koppelt producten in WooCommerce en Shopify aan elkaar op basis van EAN. Eén keer op orde, en het systeem weet daarna altijd welke variant bij welk kanaal hoort. Nieuwe producten neem je in een paar klikken mee.',
        icon: 'fa-solid fa-barcode',
    },
    {
        eyebrow: 'Voorraad realtime in sync',
        heading: 'Verkopen op één shop, voorraad zakt in beide.',
        body: 'Verkoop je een product op Shopify, dan past ShopLinkr de voorraad op WooCommerce direct aan. En andersom. Zo houd je één waarheid voor je voorraad, ook als je op beide kanalen tegelijk actief verkoopt. Elke shop blijft z\'n eigen merk, je magazijn werkt met één voorraadstand.',
        icon: 'fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Bestellingen op één plek',
        heading: 'Alle orders in dezelfde bestellingenlijst.',
        body: 'Bestellingen uit WooCommerce en Shopify verschijnen samen in ShopLinkr. Je picked, verpakt en verstuurt vanuit dezelfde flow, ongeacht waar de order vandaan komt. Je magazijnteam werkt elke dag op dezelfde manier.',
        icon: 'fa-solid fa-list-check',
    },
    {
        eyebrow: 'Geen oversells',
        heading: 'Verkoop nooit meer wat je niet op voorraad hebt.',
        body: 'Doordat de voorraad razendsnel meebeweegt, voorkom je dat je hetzelfde laatste stuk twee keer verkoopt. Minder annuleringen, minder klantvragen en een consistente ervaring voor iedereen die bij je bestelt.',
        icon: 'fa-solid fa-shield-check',
    },
];

const useCases = [
    {
        icon: 'fa-solid fa-store',
        title: 'Twee merken, één magazijn',
        body: 'Je hebt een hoofd-webshop op WooCommerce en een tweede merk op Shopify, met dezelfde producten. Je voorraad zit fysiek op één plek, en zo wil je dat ook digitaal hebben.',
    },
    {
        icon: 'fa-solid fa-globe',
        title: 'Migreren zonder downtime',
        body: 'Je bent aan het migreren van WooCommerce naar Shopify, maar wilt niet alles in één keer omklappen. Met ShopLinkr kun je een tijdje naast elkaar draaien zonder voorraadchaos.',
    },
    {
        icon: 'fa-solid fa-language',
        title: 'B2B en B2C splitsen',
        body: 'Je B2C verkoopt via Shopify, je B2B via WooCommerce of andersom. Verschillende prijzen, hetzelfde magazijn. ShopLinkr houdt allebei de kanalen op één voorraadstand.',
    },
    {
        icon: 'fa-solid fa-flask',
        title: 'Een nieuwe niche testen',
        body: 'Je hoofdshop draait stabiel en je wilt op een tweede platform een niche-publiek aanboren, zonder een aparte voorraadadministratie te hoeven optuigen.',
    },
];

const faqs = [
    {
        question: 'Welke shop wordt de "leidende"?',
        answer: 'Geen. ShopLinkr is voor allebei je shops een gelijkwaardige bron. Een mutatie ergens in WooCommerce of Shopify wordt opgepikt en doorgezet naar het andere kanaal. Je magazijn blijft de fysieke waarheid, ShopLinkr bewaakt dat allebei de shops daarmee in lijn lopen.',
    },
    {
        question: 'Werkt dit ook als ik dezelfde producten op andere prijzen verkoop?',
        answer: 'Ja, prima. Elke shop behoudt zijn eigen prijslijst. ShopLinkr richt zich op voorraad-mutaties en orders, dus je prijsstrategie per kanaal blijft helemaal aan jou.',
    },
    {
        question: 'En als ik ook nog op een marketplace verkoop?',
        answer: 'Sluit aan. ShopLinkr is gebouwd om meerdere kanalen tegelijk te draaien. Voeg bol, Kaufland of een andere marketplace toe en je voorraadstand blijft over al die kanalen op één lijn.',
    },
];

const jsonLd = [
    {
        '@type': 'WebPage',
        name: 'WooCommerce koppelen aan Shopify via ShopLinkr',
        description: 'Draai je WooCommerce en Shopify naast elkaar? ShopLinkr houdt je voorraad realtime synchroon tussen beide shops en verzamelt alle orders in één flow.',
        url: 'https://shoplinkr.com/integraties/woocommerce-koppelen-aan-shopify',
    },
    {
        '@type': 'BreadcrumbList',
        itemListElement: [
            {
                '@type': 'ListItem',
                position: 1,
                name: 'Home',
                item: 'https://shoplinkr.com',
            },
            {
                '@type': 'ListItem',
                position: 2,
                name: 'Integraties',
                item: 'https://shoplinkr.com/integraties',
            },
            {
                '@type': 'ListItem',
                position: 3,
                name: 'WooCommerce koppelen aan Shopify',
                item: 'https://shoplinkr.com/integraties/woocommerce-koppelen-aan-shopify',
            },
        ],
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = true;
---

<PageLayout
    title="WooCommerce koppelen aan Shopify via ShopLinkr | Integraties"
    description="Draai je WooCommerce en Shopify naast elkaar? ShopLinkr houdt je voorraad realtime synchroon tussen beide shops en verzamelt alle orders in één flow."
    eyebrow="WooCommerce en Shopify"
    heading="WooCommerce koppelen met Shopify via ShopLinkr."
    subheading="Verkoop je via WooCommerce en Shopify tegelijk? ShopLinkr synchroniseert je voorraad realtime tussen beide shops en verzamelt alle bestellingen op één plek."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <nav aria-label="Breadcrumb" class="mb-8">
                <ol class="flex flex-wrap items-center gap-2 text-sm text-gravel">
                    <li>
                        <a href="/" class="hover:text-charcoal transition-colors">Home</a>
                    </li>
                    <li aria-hidden="true">
                        <i class="fa-solid fa-chevron-right text-[9px]"></i>
                    </li>
                    <li>
                        <a href="/integraties" class="hover:text-charcoal transition-colors">Integraties</a>
                    </li>
                    <li aria-hidden="true">
                        <i class="fa-solid fa-chevron-right text-[9px]"></i>
                    </li>
                    <li class="text-charcoal font-medium" aria-current="page">
                        WooCommerce koppelen aan Shopify
                    </li>
                </ol>
            </nav>

            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Voorraad synchronisatie</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Eén voorraadbron voor WooCommerce en Shopify.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    ShopLinkr verbindt je WooCommerce shop met je Shopify shop. Voorraadmutaties gaan beide kanten op, bestellingen komen samen in één overzicht. Hieronder zie je wat de koppeling concreet voor je doet.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-chalk-light/60">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-14">
                <p class="eyebrow mb-4">Wanneer dit slim is</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Waarom shops kiezen voor WooCommerce én Shopify.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Twee shops draaien is een keuze die je niet zomaar maakt. Hieronder een paar herkenbare situaties waarin ShopLinkr het verschil maakt.
                </p>
            </div>

            <div class="grid sm:grid-cols-2 gap-4 md:gap-5">
                {
                    useCases.map((useCase) => (
                        <div class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-4">
                                <i class={`${useCase.icon} text-base`} aria-hidden="true"></i>
                            </div>
                            <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight mb-2">
                                {useCase.title}
                            </h3>
                            <p class="text-sm text-steel leading-relaxed">
                                {useCase.body}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl">
                <p class="eyebrow mb-4">Veelgestelde vragen</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1] mb-10">
                    Twee shops, één voorraad.
                </h2>

                <FaqList items={faqs} />
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
