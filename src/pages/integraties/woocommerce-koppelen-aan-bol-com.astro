---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'ShopLinkr als brug',
        heading: 'Een betrouwbare schakel tussen WooCommerce en bol.',
        body: 'Je koppelt je WooCommerce webshop aan ShopLinkr, en je bol verkoopaccount ook. Vanaf dat moment houdt ShopLinkr alles in lijn. Geen losse plugins die je per kanaal moet onderhouden, geen exports tussendoor.',
        icon: 'fa-solid fa-arrows-left-right-to-line',
    },
    {
        eyebrow: 'Matchen op EAN',
        heading: 'Producten worden automatisch aan elkaar gekoppeld.',
        body: 'Op basis van het EAN-nummer herkent ShopLinkr welk WooCommerce product hetzelfde is als een bol-listing. Eén keer goed instellen, en je hoeft daarna nooit meer SKUs handmatig te matchen. Nieuwe producten neem je in een paar klikken mee.',
        icon: 'fa-solid fa-barcode',
    },
    {
        eyebrow: 'Voorraad realtime in sync',
        heading: 'Eén voorraadbeeld voor allebei je kanalen.',
        body: 'Verkoop je een product op bol, dan past ShopLinkr de voorraad op WooCommerce direct aan. Krijg je een order binnen via je eigen webshop, dan gaat de voorraad op bol omlaag. Belangrijk: ShopLinkr synct alleen voorraad en orders. Je productcontent en prijzen blijven van jou.',
        icon: 'fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Bestellingen op één plek',
        heading: 'Alle orders in dezelfde flow.',
        body: 'WooCommerce-orders en bol-orders verschijnen in dezelfde bestellingenlijst. Je picked, verpakt en verstuurt vanuit één omgeving. Het maakt niet meer uit waar de bestelling vandaan komt, je magazijn werkt altijd op dezelfde manier.',
        icon: 'fa-solid fa-list-check',
    },
    {
        eyebrow: 'Voorkom oversells',
        heading: 'Verkoop nooit meer wat je niet op voorraad hebt.',
        body: 'Doordat de voorraad razendsnel tussen kanalen meebeweegt, voorkom je dat hetzelfde laatste stuks op twee plekken tegelijk verkocht wordt. Minder annuleringen, geen bol verkoopboetes en blijere klanten.',
        icon: 'fa-solid fa-shield-check',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Koppel je bol webshop aan WooCommerce',
    description: 'Koppel je bol webshop aan je eigen WooCommerce webshop. Je voorraad is altijd gesynchroniseerd en bestellingen komen op een plek binnen.',
};

export const prerender = true;
---

<PageLayout
    title="Koppel je bol webshop aan WooCommerce - ShopLinkr"
    description="Koppel je bol webshop aan je eigen WooCommerce webshop. Je voorraad is altijd gesynchroniseerd en bestellingen komen op één plek binnen."
    eyebrow="WooCommerce en bol"
    heading="WooCommerce koppelen met bol via ShopLinkr."
    subheading="Verkoop je via WooCommerce en via bol? ShopLinkr synchroniseert je voorraad realtime en verzamelt alle bestellingen op één plek. Eén workflow, geen oversells."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <a
                href="/integraties"
                class="inline-flex items-center gap-2 text-sm text-gravel hover:text-charcoal transition-colors mb-8"
            >
                <i class="fa-solid fa-arrow-left text-xs" aria-hidden="true"></i>
                Terug naar alle integraties
            </a>

            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Voorraad synchronisatie</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Eén voorraadbron voor WooCommerce en bol.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    ShopLinkr verbindt je WooCommerce webshop met je bol verkoopaccount. Voorraad gaat beide kanten op, bestellingen komen samen in één overzicht. Hieronder zie je wat de koppeling precies voor je doet.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
