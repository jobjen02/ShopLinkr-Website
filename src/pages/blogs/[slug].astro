---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import BlogCard from '../../components/template/BlogCard.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';

export async function getStaticPaths() {
    const blogs = await getCollection('blogs');
    return blogs.map((blog) => ({
        params: {
            slug: blog.id,
        },
        props: {
            blog,
        },
    }));
}

const { blog } = Astro.props;
const { Content } = await render(blog);

const formattedDate = new Intl.DateTimeFormat('nl-NL', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
}).format(blog.data.publishedAt);

const allBlogs = await getCollection('blogs');
const others = allBlogs.filter((b) => b.id !== blog.id && b.data.isBlog);

const sameCategory = blog.data.category
    ? others.filter((b) => b.data.category === blog.data.category)
    : [];

const fallback = others.filter((b) => !sameCategory.includes(b));

const related = [...sameCategory, ...fallback]
    .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
    .slice(0, 3);

const canonicalUrl = `https://shoplinkr.com/blogs/${blog.id}`;

const articleSchema = {
    '@type': 'BlogPosting',
    headline: blog.data.title,
    description: blog.data.excerpt,
    datePublished: blog.data.publishedAt.toISOString(),
    dateModified: blog.data.publishedAt.toISOString(),
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
    },
    author: {
        '@type': 'Organization',
        name: blog.data.author || 'ShopLinkr',
        url: 'https://shoplinkr.com',
    },
    publisher: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        logo: {
            '@type': 'ImageObject',
            url: 'https://shoplinkr.com/logo/logo-charcoal.svg',
        },
    },
    ...(blog.data.image && {
        image: blog.data.image,
    }),
    ...(blog.data.category && {
        articleSection: blog.data.category,
    }),
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com',
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: 'Blog',
            item: 'https://shoplinkr.com/blogs',
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: blog.data.title,
            item: canonicalUrl,
        },
    ],
};

const jsonLd = [articleSchema, breadcrumbSchema];

export const prerender = true;
---

<ArticleLayout
    title={`${blog.data.title} | ShopLinkr Blog`}
    description={blog.data.excerpt}
    heading={blog.data.title}
    eyebrow={blog.data.category}
    meta={`${blog.data.author} · ${formattedDate}`}
    image={blog.data.image}
    imageAlt={blog.data.imageAlt}
    backHref="/blogs"
    backLabel="Alle blogs"
    jsonLd={jsonLd}
>
    <Content />

    <Fragment slot="after">
        {related.length > 0 && (
            <section class="py-20 md:py-24 bg-chalk-light border-t border-chalk-dark">
                <div class="container-prose">
                    <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight mb-10">
                        Gerelateerde artikelen
                    </h2>
                    <div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
                        {related.map((b) => (
                            <BlogCard
                                title={b.data.title}
                                excerpt={b.data.excerpt}
                                publishedAt={b.data.publishedAt}
                                image={b.data.image}
                                imageAlt={b.data.imageAlt}
                                slug={b.id}
                                category={b.data.category}
                            />
                        ))}
                    </div>
                </div>
            </section>
        )}

        <CtaBanner />
    </Fragment>
</ArticleLayout>
