---
import { getCollection } from 'astro:content';
import BlogArticlePage from '../../components/pages/BlogArticlePage.astro';

export async function getStaticPaths() {
    const blogs = await getCollection('blogs');
    const visibleBlogs = blogs.filter((b) => b.data.isBlog);

    const blogsEn = await getCollection('blogsEn');
    const enByNlId = new Map(
        blogsEn.filter((b) => b.data.translationKey).map((b) => [b.data.translationKey, b.id]),
    );

    return blogs.map((blog) => {
        const others = visibleBlogs.filter((b) => b.id !== blog.id);

        const sameCategory = blog.data.category
            ? others.filter((b) => b.data.category === blog.data.category)
            : [];

        const otherIds = new Set(sameCategory.map((b) => b.id));
        const fallback = others.filter((b) => !otherIds.has(b.id));

        const related = [...sameCategory, ...fallback]
            .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
            .slice(0, 3);

        return {
            params: {
                slug: blog.id,
            },
            props: {
                blog,
                related,
                enSlug: enByNlId.get(blog.id) ?? null,
            },
        };
    });
}

const { blog, related, enSlug } = Astro.props;

const alternates = enSlug
    ? { nl: `/blogs/${blog.id}`, en: `/en/blog/${enSlug}` }
    : undefined;

const formattedDate = new Intl.DateTimeFormat('nl-NL', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
}).format(blog.data.publishedAt);

const canonicalUrl = `https://shoplinkr.com/blogs/${blog.id}`;

const articleSchema = {
    '@type': 'BlogPosting',
    headline: blog.data.title,
    description: blog.data.excerpt,
    datePublished: blog.data.publishedAt.toISOString(),
    dateModified: blog.data.publishedAt.toISOString(),
    inLanguage: 'nl-NL',
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
    },
    author: {
        '@type': 'Organization',
        name: blog.data.author || 'ShopLinkr',
        url: 'https://shoplinkr.com',
    },
    publisher: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        logo: {
            '@type': 'ImageObject',
            url: 'https://shoplinkr.com/logo/logo-charcoal.svg',
        },
    },
    ...(blog.data.image && {
        image: `https://shoplinkr.com${blog.data.image}`,
    }),
    ...(blog.data.category && {
        articleSection: blog.data.category,
    }),
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com',
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: 'Blog',
            item: 'https://shoplinkr.com/blogs',
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: blog.data.title,
            item: canonicalUrl,
        },
    ],
};

const jsonLd = [articleSchema, breadcrumbSchema];

export const prerender = true;
---

<BlogArticlePage
    blog={blog}
    related={related}
    formattedDate={formattedDate}
    alternates={alternates}
    jsonLd={jsonLd}
/>
