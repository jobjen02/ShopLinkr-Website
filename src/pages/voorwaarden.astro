---
import PageLayout from '../layouts/PageLayout.astro';

const lastUpdated = '2026-05-28';

const sections = [
    {
        heading: '1. Wie zijn wij?',
        body: 'ShopLinkr is een Nederlands bedrijf. Onze software helpt webshops om voorraad, bestellingen en verzending centraal te beheren. Deze voorwaarden gelden voor het gebruik van shoplinkr.com en alle bijbehorende diensten.',
    },
    {
        heading: '2. Wanneer gelden deze voorwaarden?',
        body: 'Deze voorwaarden gelden zodra je een account aanmaakt op shoplinkr.com of gebruik maakt van onze diensten, ook tijdens een gratis proefperiode. Door een account aan te maken bevestig je dat je deze voorwaarden hebt gelezen en accepteert.',
    },
    {
        heading: '3. Wat mag je verwachten?',
        body: 'We doen ons best om onze dienst altijd beschikbaar te houden en je voorraad correct te synchroniseren met je verkoopkanalen. We zijn niet aansprakelijk voor tijdelijke storingen, geplande onderhoudsmomenten of fouten in externe systemen waar wij mee koppelen.',
    },
    {
        heading: '4. Wat verwachten wij van jou?',
        body: 'Je gebruikt ShopLinkr alleen voor legale doeleinden en niet op manieren die schade kunnen toebrengen aan ons, onze klanten of derden. Je bent zelf verantwoordelijk voor de juistheid van je productinformatie en de afhandeling van je orders richting je klanten.',
    },
    {
        heading: '5. Abonnement en facturatie',
        body: 'Wij werken met een pay-as-you-go model: je betaalt op basis van je daadwerkelijke gebruik. Facturatie gebeurt maandelijks achteraf. Je kunt je abonnement maandelijks opzeggen via je accountinstellingen. Bij opzegging stopt je abonnement aan het einde van de huidige periode.',
    },
    {
        heading: '6. Gratis proefperiode',
        body: 'Nieuwe gebruikers krijgen 14 dagen gratis toegang tot ShopLinkr zonder dat creditcardgegevens nodig zijn. Tijdens de proefperiode kun je alle functionaliteiten testen. Na de proefperiode word je gevraagd of je wilt doorgaan met een betaald abonnement.',
    },
    {
        heading: '7. Aansprakelijkheid',
        body: 'Onze aansprakelijkheid voor schade is beperkt tot het bedrag dat je in de afgelopen twaalf maanden aan ons hebt betaald. We zijn niet aansprakelijk voor indirecte schade, gederfde winst of schade door onjuiste gegevens van derde partijen waar wij mee koppelen.',
    },
    {
        heading: '8. Intellectueel eigendom',
        body: 'Alle rechten op ShopLinkr en onze software blijven bij ons. Je krijgt een persoonlijke, niet-overdraagbare licentie om de software te gebruiken zolang je een actief abonnement hebt. Je mag onze software niet reverse-engineeren of commercieel doorverkopen.',
    },
    {
        heading: '9. Geheimhouding',
        body: 'Beide partijen behandelen alle gegevens die ze via deze samenwerking ontvangen vertrouwelijk. We gebruiken jouw bedrijfsgegevens uitsluitend voor het leveren van onze dienst en gaan zorgvuldig om met je productinformatie en klantdata.',
    },
    {
        heading: '10. Wijzigingen',
        body: 'We kunnen deze voorwaarden in de toekomst aanpassen. Bij belangrijke wijzigingen informeren we je via e-mail of via een melding in het platform. Je kunt dan kiezen of je akkoord gaat met de nieuwe voorwaarden of dat je je abonnement wilt beëindigen.',
    },
    {
        heading: '11. Toepasselijk recht',
        body: 'Op deze voorwaarden is Nederlands recht van toepassing. Geschillen die hieruit voortvloeien, leggen we voor aan de bevoegde rechter in Nederland. We proberen geschillen altijd eerst in goed overleg op te lossen.',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Algemene voorwaarden | ShopLinkr',
    description: 'De algemene voorwaarden voor het gebruik van ShopLinkr. Heldere afspraken over wat je van ons mag verwachten en wat wij van jou verwachten.',
};

export const prerender = true;
---

<PageLayout
    title="Algemene voorwaarden | ShopLinkr"
    description="De algemene voorwaarden voor het gebruik van ShopLinkr. Heldere afspraken over wat je van ons mag verwachten en wat wij van jou verwachten."
    eyebrow="Juridisch"
    heading="Algemene voorwaarden."
    subheading="Heldere afspraken over wat je van ons mag verwachten en wat wij van jou verwachten."
    jsonLd={jsonLd}
>
    <section class="py-16 md:py-24 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl">
                <p class="text-sm text-gravel mb-12">
                    Laatst bijgewerkt: {lastUpdated}
                </p>

                <div class="space-y-10">
                    {
                        sections.map((section) => (
                            <article>
                                <h2 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight mb-4">
                                    {section.heading}
                                </h2>
                                <p class="text-steel leading-relaxed text-[15px] md:text-base">
                                    {section.body}
                                </p>
                            </article>
                        ))
                    }
                </div>

                <div class="mt-16 pt-10 border-t border-chalk-dark">
                    <p class="text-sm text-gravel italic">
                        Heb je een vraag over deze voorwaarden? Mail naar <a href="mailto:contact@shoplinkr.com" class="text-charcoal font-semibold hover:text-sunstone-deep transition-colors">contact@shoplinkr.com</a>.
                    </p>
                </div>
            </div>
        </div>
    </section>
</PageLayout>
