---
import { getCollection } from 'astro:content';
import SupportCategoryPage from '../../../../components/pages/SupportCategoryPage.astro';
import {
    supportCategories,
    supportCategoriesBySlug,
} from '../../../../data/supportCategories';
import { CATEGORY_SLUG_NL_TO_EN } from '../../../../data/supportCategories-en';

export async function getStaticPaths() {
    return supportCategories.map((c) => ({
        params: {
            category: c.slug,
        },
    }));
}

const { category } = Astro.params;
const categoryInfo = supportCategoriesBySlug[category as string];

if (!categoryInfo) {
    throw new Error(`Unknown support category: ${category}`);
}

const enCategorySlug = CATEGORY_SLUG_NL_TO_EN[category];
const alternates = enCategorySlug
    ? { nl: `/support/categorieen/${category}`, en: `/en/support/categories/${enCategorySlug}` }
    : undefined;

const allArticles = await getCollection('supportArticles');
const articlesInCategory = allArticles
    .filter((a) => a.data.category === category)
    .sort((a, b) => a.data.order - b.data.order);

interface SubcategoryGroup {
    slug: string;
    label: string;
    summary?: string;
    articles: typeof articlesInCategory;
}

const subcategoryGroups: Array<SubcategoryGroup> = categoryInfo.subcategories.map((s) => {
    const articles = articlesInCategory.filter((a) => a.data.subcategory === s.slug);
    return {
        slug: s.slug,
        label: s.label,
        summary: s.summary,
        articles,
    };
});

const otherCategories = supportCategories.filter((c) => c.slug !== category);

const collectionSchema = {
    '@type': 'CollectionPage',
    name: `${categoryInfo.label} | ShopLinkr Support`,
    description: categoryInfo.summary,
    url: `https://shoplinkr.com/support/categorieen/${categoryInfo.slug}`,
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com',
        },
        {
            '@type': 'ListItem',
            position: 2,
            name: 'Support',
            item: 'https://shoplinkr.com/support',
        },
        {
            '@type': 'ListItem',
            position: 3,
            name: categoryInfo.label,
            item: `https://shoplinkr.com/support/categorieen/${categoryInfo.slug}`,
        },
    ],
};

const jsonLd = [collectionSchema, breadcrumbSchema];

export const prerender = true;
---

<SupportCategoryPage
    categoryInfo={categoryInfo}
    subcategoryGroups={subcategoryGroups}
    otherCategories={otherCategories}
    alternates={alternates}
    jsonLd={jsonLd}
/>
