---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import SupportArticlePage from '../../components/pages/SupportArticlePage.astro';
import {
    supportCategoriesBySlug,
    findSubcategoryBySlug,
} from '../../data/supportCategories';

export const getStaticPaths: GetStaticPaths = async () => {
    const articles = await getCollection('supportArticles');
    return articles.map((article) => ({
        params: {
            slug: article.id.split('/').pop(),
        },
        props: {
            article,
            allArticles: articles,
        },
    }));
};

const { article, allArticles } = Astro.props;

const categoryInfo = supportCategoriesBySlug[article.data.category];
const subcategoryInfo = categoryInfo && article.data.subcategory
    ? findSubcategoryBySlug(categoryInfo, article.data.subcategory)
    : undefined;

const articleSlug = article.id.split('/').pop();
const canonicalUrl = `https://shoplinkr.com/support/${articleSlug}`;

const enArticles = await getCollection('supportArticlesEn');
const enSlugByTk = new Map(
    enArticles
        .filter((a) => a.data.translationKey)
        .map((a) => [a.data.translationKey, a.id.split('/').pop()]),
);
const enSlug = enSlugByTk.get(articleSlug);
const alternates = enSlug
    ? { nl: `/support/${articleSlug}`, en: `/en/support/${enSlug}` }
    : undefined;

const articleId = article.id;
const sameSubcategoryArticles = allArticles
    .filter((a) => {
        return a.id !== articleId
            && a.data.category === article.data.category
            && article.data.subcategory !== undefined
            && a.data.subcategory === article.data.subcategory;
    })
    .sort((a, b) => a.data.order - b.data.order);

const sameCategoryArticles = allArticles
    .filter((a) => {
        return a.id !== articleId
            && a.data.category === article.data.category
            && a.data.subcategory !== article.data.subcategory;
    })
    .sort((a, b) => a.data.order - b.data.order);

const relatedArticles = [...sameSubcategoryArticles, ...sameCategoryArticles]
    .slice(0, 4)
    .map((a) => {
        const slug = a.id.split('/').pop() ?? a.id;
        return {
            title: a.data.title,
            summary: a.data.summary,
            href: `/support/${slug}`,
            subcategoryLabel: a.data.subcategoryLabel ?? null,
        };
    });

const lastUpdatedFormatted = new Intl.DateTimeFormat('nl-NL', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
}).format(article.data.lastUpdated);

const articleSchema = {
    '@type': 'TechArticle',
    headline: article.data.title,
    description: article.data.summary,
    dateModified: article.data.lastUpdated.toISOString(),
    datePublished: article.data.lastUpdated.toISOString(),
    mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
    },
    articleSection: article.data.categoryLabel,
    author: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        url: 'https://shoplinkr.com',
    },
    publisher: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        logo: {
            '@type': 'ImageObject',
            url: 'https://shoplinkr.com/logo/logo-charcoal.svg',
        },
    },
};

const breadcrumbItems = [
    {
        href: '/support',
        label: 'Support',
    },
];

if (categoryInfo) {
    breadcrumbItems.push({
        href: `/support/categorieen/${categoryInfo.slug}`,
        label: categoryInfo.label,
    });
}

if (categoryInfo && subcategoryInfo) {
    breadcrumbItems.push({
        href: `/support/categorieen/${categoryInfo.slug}/${subcategoryInfo.slug}`,
        label: subcategoryInfo.label,
    });
}

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        {
            '@type': 'ListItem',
            position: 1,
            name: 'Home',
            item: 'https://shoplinkr.com',
        },
        ...breadcrumbItems.map((item, index) => ({
            '@type': 'ListItem',
            position: index + 2,
            name: item.label,
            item: `https://shoplinkr.com${item.href}`,
        })),
        {
            '@type': 'ListItem',
            position: breadcrumbItems.length + 2,
            name: article.data.title,
            item: canonicalUrl,
        },
    ],
};

const jsonLd = [articleSchema, breadcrumbSchema];

export const prerender = true;
---

<SupportArticlePage
    article={article}
    categoryInfo={categoryInfo}
    breadcrumbItems={breadcrumbItems}
    relatedArticles={relatedArticles}
    lastUpdatedFormatted={lastUpdatedFormatted}
    jsonLd={jsonLd}
    alternates={alternates}
/>
