---
import PageLayout from '../layouts/PageLayout.astro';
import PricingCalculator from '../components/pricing/PricingCalculator.vue';
import CtaBanner from '../components/sections/CtaBanner.astro';
import FaqList from '../components/template/FaqList.astro';
import { breadcrumbs } from '../utils/seo';
import { faqsByPage } from '../data/faqs';

const pricingExamples = [
    {
        label: 'Starter',
        sub: '2 kanalen, 250 orders',
        amount: '€ 50,00',
        breakdown: '€ 10 kanalen + € 40 orders',
    },
    {
        label: 'Groeiend',
        sub: '4 kanalen, 1.000 orders',
        amount: '€ 130,00',
        breakdown: '€ 20 kanalen + € 110 orders',
    },
    {
        label: 'Schaal',
        sub: '6 kanalen, 5.000 orders',
        amount: '€ 317,45',
        breakdown: '€ 30 kanalen + € 287,45 orders',
    },
];

const inclusions = [
    {
        title: 'Alle features inbegrepen',
        body: 'Voorraad, picklijsten, labels, inkoop. Geen losse modules of duurdere pakketten.',
        icon: 'fa-duotone fa-solid fa-grid-2',
    },
    {
        title: 'Ongelimiteerde gebruikers',
        body: 'Iedereen in je magazijn werkt mee. Geen prijs per seat, geen plafond.',
        icon: 'fa-duotone fa-solid fa-users',
    },
    {
        title: 'Snelle support',
        body: 'Reactie binnen 24 uur, vaak sneller. Direct contact met iemand die ShopLinkr kent.',
        icon: 'fa-duotone fa-solid fa-comments',
    },
    {
        title: 'Gratis migratie en onboarding',
        body: 'We helpen je vanaf je huidige systeem, importeren je producten en zetten je kanalen op.',
        icon: 'fa-duotone fa-solid fa-arrow-right-arrow-left',
    },
    {
        title: 'Wekelijkse updates',
        body: 'Nieuwe functies en verbeteringen rollen elke week uit. Zonder extra kosten.',
        icon: 'fa-duotone fa-solid fa-arrows-rotate',
    },
    {
        title: 'Geen jaarbinding',
        body: 'Maandelijks opzegbaar. Geen vendor lock-in. Je data is altijd van jou.',
        icon: 'fa-duotone fa-solid fa-calendar-check',
    },
    {
        title: '14 dagen gratis trial',
        body: 'Probeer ShopLinkr met je eigen producten en orders. Geen creditcard nodig.',
        icon: 'fa-duotone fa-solid fa-circle-play',
    },
    {
        title: 'Geen verborgen kosten',
        body: 'Eén transparant tarief op basis van kanalen en orders. Geen setup fees of toeslagen.',
        icon: 'fa-duotone fa-solid fa-shield-check',
    },
];

const faqs = faqsByPage.prijzen;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Prijzen', '/prijzen'],
    ]),
    {
        '@type': 'Product',
        name: 'ShopLinkr',
        description: 'Magazijnsoftware voor Nederlandse webshops. Voorraad, picklijsten, labels en orderverwerking in één platform.',
        brand: {
            '@type': 'Brand',
            name: 'ShopLinkr',
        },
        offers: {
            '@type': 'Offer',
            priceCurrency: 'EUR',
            availability: 'https://schema.org/InStock',
            url: 'https://shoplinkr.com/prijzen',
            priceSpecification: {
                '@type': 'UnitPriceSpecification',
                priceCurrency: 'EUR',
                unitText: 'MONTH',
            },
        },
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = true;
---

<PageLayout
    title="Prijzen | ShopLinkr"
    description="Transparant prijsmodel voor ShopLinkr. Pay as you go: je betaalt per verkoopkanaal en per order, alle features inbegrepen. 14 dagen gratis proberen."
    eyebrow="Prijzen"
    heading="Eén transparant prijsmodel."
    subheading="Je betaalt alleen voor wat je gebruikt. Alle features zitten erbij, ook in het kleinste pakket."
    jsonLd={jsonLd}
>
    <PricingCalculator client:visible />

    <section class="py-20 md:py-24">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Hoe het werkt</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Twee bouwstenen,
                        <span class="block text-sunstone-deep">geen verrassingen.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Je rekening bestaat uit een vast bedrag per verkoopkanaal en een staffeltarief per order. Schuif met de calculator om jouw maandprijs te zien, of reken zelf na met de getallen hieronder.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <div class="grid sm:grid-cols-2 gap-4">
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-7">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                <i class="fa-duotone fa-solid fa-plug text-[1.15rem]" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-2">Per verkoopkanaal</p>
                            <p class="text-2xl md:text-[1.625rem] font-semibold text-charcoal tracking-tight leading-snug">
                                Vast maandtarief.
                            </p>
                            <p class="mt-4 text-sm text-steel leading-relaxed">
                                Elk kanaal dat je koppelt, kost hetzelfde. Welk kanaal je ook koppelt, het tarief blijft hetzelfde per maand.
                            </p>
                        </article>

                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-7">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-5">
                                <i class="fa-duotone fa-solid fa-layer-group text-[1.15rem]" style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-2">Per order</p>
                            <p class="text-2xl md:text-[1.625rem] font-semibold text-charcoal tracking-tight leading-snug">
                                Staffeltarief.
                            </p>
                            <p class="mt-4 text-sm text-steel leading-relaxed">
                                Per orderstaffel een eigen tarief, dat in de hogere staffels naar enkele centen per order zakt. Hoe meer orders je per maand verwerkt, hoe lager het gemiddelde per order.
                            </p>
                        </article>
                    </div>

                    <div class="mt-6 rounded-2xl bg-chalk-light ring-1 ring-chalk-dark p-7">
                        <p class="text-xs uppercase tracking-[0.08em] font-semibold text-gravel mb-5">
                            Voorbeelden
                        </p>
                        <ul class="divide-y divide-chalk-dark">
                            {
                                pricingExamples.map((example) => (
                                    <li class="py-3 first:pt-0 last:pb-0 flex items-baseline justify-between gap-4">
                                        <div>
                                            <p class="text-sm font-semibold text-charcoal">{example.label}</p>
                                            <p class="text-xs text-gravel mt-0.5">{example.sub}</p>
                                        </div>
                                        <div class="text-right">
                                            <p class="text-base font-semibold text-charcoal tabular-nums whitespace-nowrap">{example.amount}</p>
                                            <p class="text-xs text-gravel tabular-nums whitespace-nowrap mt-0.5">{example.breakdown}</p>
                                        </div>
                                    </li>
                                ))
                            }
                        </ul>
                        <p class="mt-5 text-xs text-gravel leading-relaxed">
                            Totalen per maand, exclusief btw. Reken zelf na via de calculator hierboven.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="max-w-2xl mb-16 md:mb-20">
                <p class="eyebrow mb-4">Wat zit erbij</p>
                <h2 class="text-4xl md:text-5xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Alles inbegrepen, ongeacht je volume.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Geen pakketten met afgeknepen features, geen extra modules om bij te boeken. Eén prijsmodel op basis van je gebruik. Klaar.
                </p>
            </div>

            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5">
                {
                    inclusions.map((item) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-7 md:p-8 transition duration-300 ease-out hover:ring-chalk-darker hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]">
                            <div class="flex items-center justify-center h-11 w-11 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mb-6">
                                <i class={`${item.icon} text-[1.15rem]`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <h3 class="text-base md:text-[1.05rem] font-semibold text-charcoal mb-2 tracking-tight leading-snug">
                                {item.title}
                            </h3>
                            <p class="text-sm text-steel leading-relaxed">
                                {item.body}
                            </p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Veelgestelde vragen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vraag het ons,
                        <span class="block text-sunstone-deep">we denken mee.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Mis je een vraag? Stuur ons een bericht via de chat of plan een gesprek met ons team.
                    </p>
                    <a href="/contact" class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Stel je vraag
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
