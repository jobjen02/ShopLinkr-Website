---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'Bestsellers',
        heading: 'Zie welke producten het verschil maken.',
        body: 'Welke artikelen lopen er als een trein en welke zijn de stille winnaars die je over het hoofd ziet? In je rapportage zie je in één oogopslag je best verkochte producten over elke periode die je kiest.',
        icon: 'fa-solid fa-trophy',
    },
    {
        eyebrow: 'Dode voorraad',
        heading: 'Spoor producten op die geld kosten.',
        body: 'Producten die al maanden in je magazijn liggen zonder verkoop kosten je ruimte, geld en aandacht. Het overzicht van nooit-verkochte artikelen vertelt je precies welke voorraad je moet afprijzen of niet meer bestelt.',
        icon: 'fa-solid fa-box-archive',
    },
    {
        eyebrow: 'Inkoop',
        heading: 'Bestel op basis van data, niet op gevoel.',
        body: 'Je rapporten vertellen je welke producten je nodig hebt, hoeveel je er nodig hebt en wanneer. In plaats van ruwweg inschatten wat je gaat verkopen, baseer je je inkoop op cijfers die echt iets zeggen.',
        icon: 'fa-solid fa-cart-circle-check',
    },
    {
        eyebrow: 'Voorraadwaarde',
        heading: 'Weet wat er nu in je magazijn ligt.',
        body: 'Je voorraadwaarde rapport laat zien hoeveel kapitaal er op dit moment in je voorraad zit. Handig voor je boekhouding, voor financieringsaanvragen en voor het strakke gevoel dat je grip hebt op de cijfers.',
        icon: 'fa-solid fa-coins',
    },
    {
        eyebrow: 'ABC-analyse',
        heading: 'Focus op wat het verschil maakt.',
        body: 'Met een ABC of Pareto analyse zie je welke twintig procent van je producten tachtig procent van je omzet doen. Verdeel je aandacht slim en behandel je topproducten met de prioriteit die ze verdienen.',
        icon: 'fa-solid fa-chart-pie-simple',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Rapporten en inzicht in ShopLinkr',
    description: 'Krijg inzicht in je shop met de rapportages van ShopLinkr. Zie welke producten verkopen, welke nooit verkocht zijn, en ontdek waar je kansen laat liggen.',
};

export const prerender = true;
---

<PageLayout
    title="Rapporten en inzicht met ShopLinkr"
    description="Krijg inzicht in je shop met de rapportages van ShopLinkr. Zie welke producten verkopen, welke nooit verkocht zijn, en ontdek waar je kansen laat liggen."
    eyebrow="Inzicht & data"
    heading="Begrijp je shop op cijferniveau."
    subheading="Welke producten brengen geld in het laatje en welke liggen stof te vergaren? Met de rapportages van ShopLinkr maak je beslissingen op basis van wat er écht gebeurt in je shop."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Beslissen met cijfers</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Stop met gokken, begin met weten.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Veel webshopondernemers vertrouwen op hun gevoel. Met de rapportages van ShopLinkr krijg je harde cijfers over je producten, je voorraad en je omzet. Geen losse exports, geen Excel-acrobatiek. Gewoon één plek waar de antwoorden klaarliggen.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
