---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const stories = [
    {
        eyebrow: 'Slimme picklijst',
        heading: 'Eén route door je magazijn, geen omwegen.',
        body: 'Een goede picklijst is meer dan een opsomming van producten. ShopLinkr berekent op basis van je locaties de slimste route door je magazijn. Je picker loopt in één lijn van schap naar schap, zonder dubbele passages of gemiste stops. Voor elk product zie je direct hoeveel stuks nodig zijn en bij welke bestelling het hoort. Zo bespaar je per ronde flink wat looptijd.',
        icon: 'fa-duotone fa-solid fa-route',
        visualLabel: 'Pickroute',
    },
    {
        eyebrow: 'Batches samenstellen',
        heading: 'Tien bestellingen in één pickronde.',
        body: 'Bij grote ordervolumes is per bestelling picken zonde van de tijd. Met ShopLinkr stel je batches samen van bijvoorbeeld tien of twintig orders en pak je alle producten in één ronde mee. Aan het inpakstation verdeel je de buit netjes per bestelling. Eén keer lopen, vele orders dichter bij verzending.',
        icon: 'fa-duotone fa-solid fa-boxes-stacked',
        visualLabel: 'Batch samenstellen',
    },
    {
        eyebrow: 'Barcode scannen',
        heading: 'Nauwkeurig inpakken, vrijwel zonder fouten.',
        body: 'Bij elke pick scan je de barcode van het product. ShopLinkr controleert direct of het juiste artikel in de juiste hoeveelheid wordt verwerkt. Pak je per ongeluk een verkeerd item? Dan krijg je meteen een melding. Foutreductie zonder dat je medewerkers harder moeten nadenken, gewoon scannen en doorgaan.',
        icon: 'fa-duotone fa-solid fa-barcode-read',
        visualLabel: 'Barcode scan',
    },
    {
        eyebrow: 'Labels uit picklijst',
        heading: 'Klaar met picken, direct verzendklaar.',
        body: 'Vanuit dezelfde picklijst print je in één klik de verzendlabels voor alle bestellingen erin. Geen aparte stap om je orders nog eens op te zoeken, geen heen en weer naar de bestellingenpagina. Plak de labels op de pakketten en het transport kan ze ophalen. Snel, gestroomlijnd en zonder extra handelingen.',
        icon: 'fa-duotone fa-solid fa-print',
        visualLabel: 'Bulk labels',
    },
    {
        eyebrow: 'Schaalbare logistiek',
        heading: 'Meer orders zonder meer personeel.',
        body: 'Als je verkoop groeit, wil je niet evenredig meer mensen hoeven aan te nemen om alle pakketten de deur uit te krijgen. Pick en pack lijsten zijn precies wat je nodig hebt om met hetzelfde team meer volume aan te kunnen. Strakke routes, batchverwerking en barcodescanning maken je magazijnoperatie schaalbaar. Groei wordt iets om naar uit te kijken in plaats van te vrezen.',
        icon: 'fa-duotone fa-solid fa-chart-line',
        visualLabel: 'Volume per dag',
    },
    {
        eyebrow: 'Magazijnpersoneel ondersteunen',
        heading: 'Een hulpmiddel waar je medewerkers blij van worden.',
        body: 'Nieuwe medewerkers zijn sneller productief omdat de picklijst hen letterlijk de weg wijst. Ervaren krachten waarderen het dat ze niet meer hoeven na te denken over de route of de juiste aantallen. ShopLinkr neemt het denkwerk uit handen en laat je team focussen op nauwkeurig werken. Minder frustratie, meer flow.',
        icon: 'fa-duotone fa-solid fa-people-carry-box',
        visualLabel: 'Pickerweergave',
    },
];

const efficiencyPoints = [
    {
        title: 'Gestroomlijnde fulfillment',
        body: 'Van picken tot inpakken tot label printen, alles in één doorlopende workflow zonder losse stappen.',
    },
    {
        title: 'Foutreductie via scanning',
        body: 'Barcodecontrole op elk product zorgt voor nauwkeurige orders en minder retouren door verkeerd verzonden artikelen.',
    },
    {
        title: 'Tijdwinst bij volume',
        body: 'Slimme pickroutes en batches halen uren werk per dag uit je orderverwerking als de volumes oplopen.',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Pick & Pack lijsten genereren met ShopLinkr',
    description: 'Optimaliseer je orderverwerking met ShopLinkr: Leer hoe je pick-and-pack lijsten maakt voor een soepele en efficiënte logistiek binnen je e-commercebedrijf.',
};

export const prerender = true;
---

<PageLayout
    title="Pick & Pack lijsten genereren met ShopLinkr"
    description="Optimaliseer je orderverwerking met ShopLinkr: Leer hoe je pick-and-pack lijsten maakt voor een soepele en efficiënte logistiek binnen je e-commercebedrijf."
    eyebrow="Pick & pack"
    heading="Sneller picken, minder fouten."
    subheading="Genereer picklijsten met slimme routes door je magazijn, verwerk batches in één ronde en scan barcodes voor nauwkeurigheid. Een magazijnoperatie die meegroeit met je verkoop."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="bg-paper">
        <div class="container-prose">
            {
                stories.map((story, index) => {
                    const isReversed = index % 2 === 1;

                    return (
                        <article class="py-20 md:py-28 border-b border-chalk-dark last:border-b-0">
                            <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
                                <div class={`lg:col-span-7 ${isReversed ? 'lg:order-2' : 'lg:order-1'}`}>
                                    <div
                                        class="relative w-full rounded-3xl overflow-hidden bg-chalk-light ring-1 ring-chalk-dark"
                                        style="aspect-ratio: 4 / 3;"
                                    >
                                        <div class="absolute inset-0 flex flex-col items-center justify-center gap-5 p-10 text-center">
                                            <div class="flex items-center justify-center h-20 w-20 rounded-2xl bg-paper text-sunstone-deep ring-1 ring-chalk-dark shadow-[0_8px_24px_-12px_rgba(25,25,25,0.10)]">
                                                <i class={`${story.icon} text-3xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                                            </div>
                                            <div>
                                                <p class="text-[11px] uppercase tracking-[0.22em] text-gravel font-semibold mb-2">
                                                    Visual: {story.visualLabel}
                                                </p>
                                                <p class="text-sm text-gravel max-w-[32ch]">
                                                    Hier komt later een echte screenshot uit ShopLinkr.
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class={`lg:col-span-5 ${isReversed ? 'lg:order-1' : 'lg:order-2'}`}>
                                    <p class="eyebrow mb-5">{story.eyebrow}</p>
                                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.15] mb-6">
                                        {story.heading}
                                    </h2>
                                    <p class="text-lg text-steel leading-relaxed">
                                        {story.body}
                                    </p>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Waar het verschil zit</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Drie redenen waarom
                        <span class="block text-sunstone-deep">je het direct merkt.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Een slimme picklijst lijkt een klein detail, maar in de praktijk verandert het de manier waarop je magazijn draait. Sneller, nauwkeuriger en klaar voor groei.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            efficiencyPoints.map((point) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-bolt text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{point.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{point.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
