---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';

const carriers = (await getCollection('integrations'))
    .filter((i) => i.data.category === 'carrier')
    .sort((a, b) => a.data.name.localeCompare(b.data.name));

const subFeatures = [
    {
        eyebrow: 'AutoPrint',
        heading: 'Labels meteen uit de printer.',
        body: 'AutoPrint stuurt het label via PrintNode naar de printer bij je inpakstation. Jij verwerkt de bestelling, het label wordt meteen geprint. Geen PDF\'s openen, geen handmatige printopdrachten.',
        icon: 'fa-duotone fa-solid fa-print',
    },
    {
        eyebrow: 'Per bestelling kiezen',
        heading: 'Wissel van vervoerder waar nodig.',
        body: 'Een standaard vervoerder voor je dagelijkse pakketten, een snellere voor spoedorders, een ander voor het buitenland. Per bestelling kies je eenvoudig de juiste vervoerder.',
        icon: 'fa-duotone fa-solid fa-shuffle',
    },
    {
        eyebrow: 'Track en trace terug',
        heading: 'Automatisch terug naar je kanaal.',
        body: 'Zodra je het label aanmaakt, koppelen wij de track & trace direct terug naar je verkoopkanaal, zodat alles direct bijgewerkt is.',
        icon: 'fa-duotone fa-solid fa-location-arrow',
    },
    {
        eyebrow: 'Verzendregels',
        heading: 'De juiste vervoerder kiest zichzelf.',
        body: 'Stel een regel in op gewicht, land, kanaal of waarde. ShopLinkr selecteert dan automatisch de bijbehorende vervoerder. Eén keer inrichten en je hoeft er niet meer over na te denken.',
        icon: 'fa-duotone fa-solid fa-route',
    },
];

const faqs = faqsByPage.vervoerders;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Functionaliteiten', '/functionaliteiten'],
        ['Vervoerders', '/functionaliteiten/vervoerders'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Vervoerders koppelen met ShopLinkr',
        description: 'Print verzendlabels bij elke vervoerder die je gebruikt, kies per bestelling de juiste en stuur track en trace automatisch terug naar je kanaal.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Vervoerders koppelen met ShopLinkr"
    description="Print verzendlabels bij elke vervoerder die je gebruikt. Kies per bestelling de juiste en stuur track en trace automatisch terug naar je verkoopkanaal."
    eyebrow="Verzending"
    heading="Print labels bij elke vervoerder die je gebruikt."
    subheading="Of een bestelling nu via Bol, je eigen webshop of een andere marketplace binnenkomt: je print het label vanuit ShopLinkr en de track en trace gaat automatisch terug naar het verkoopkanaal."
    routeKey="features.carriers"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Van bestelling tot label</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            De juiste vervoerder,
                            <span class="block">automatisch gekozen.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 flex flex-col gap-4 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3">
                            <div class="flex items-center gap-2.5">
                                <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-bag-shopping text-[0.7rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-sm font-semibold text-charcoal">Bestelling #28411</span>
                            </div>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">Bol</span>
                        </div>
                        <div class="flex flex-wrap items-center gap-2 text-xs">
                            <span class="inline-flex items-center px-2 py-1 rounded-md bg-chalk-light ring-1 ring-chalk-dark font-medium text-charcoal tabular-nums">1,4 kg</span>
                            <span class="inline-flex items-center px-2 py-1 rounded-md bg-chalk-light ring-1 ring-chalk-dark font-medium text-charcoal">Nederland</span>
                            <span class="inline-flex items-center px-2 py-1 rounded-md bg-chalk-light ring-1 ring-chalk-dark font-medium text-charcoal">Brievenbus</span>
                        </div>

                        <div class="flex items-center gap-3 py-1">
                            <span class="flex-1 h-px bg-chalk-dark"></span>
                            <span class="inline-flex items-center gap-1.5 text-[10px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep">
                                <i class="fa-solid fa-route text-[0.65rem]" aria-hidden="true"></i>
                                Regel kiest
                            </span>
                            <span class="flex-1 h-px bg-chalk-dark"></span>
                        </div>

                        <div class="rounded-lg ring-1 ring-charcoal/15 bg-paper p-4 flex flex-col gap-3">
                            <div class="flex items-center justify-between">
                                <span class="text-[10px] uppercase tracking-[0.14em] font-semibold text-gravel">Verzendlabel</span>
                                <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-sunstone-mist text-sunstone-deep text-[10px] uppercase tracking-[0.08em] font-semibold ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-print text-[0.55rem]" aria-hidden="true"></i>
                                    AutoPrint
                                </span>
                            </div>
                            <div class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5 text-xs">
                                <span class="text-gravel">Vervoerder</span>
                                <span class="text-charcoal font-semibold">PostNL Brievenbuspakket</span>
                                <span class="text-gravel">Naar</span>
                                <span class="text-charcoal">L. de Vries, 1015 NL Amsterdam</span>
                            </div>
                            <div class="flex items-center justify-between gap-3 pt-2 border-t border-chalk-dark">
                                <span class="text-[11px] text-gravel">T&amp;T</span>
                                <span class="font-mono text-[11px] text-charcoal tabular-nums">3SLINKR0428411NL</span>
                            </div>
                            <div class="flex gap-[2px] h-7 mt-1">
                                <span class="w-px bg-charcoal"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/70"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/60"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/70"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/60"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/70"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/60"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/70"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/70"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/60"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                                <span class="w-[2px] bg-charcoal"></span>
                                <span class="w-px bg-charcoal/70"></span>
                                <span class="w-[3px] bg-charcoal"></span>
                            </div>
                        </div>

                        <div class="flex items-center gap-2 text-[11px] text-gravel">
                            <i class="fa-solid fa-arrow-turn-up rotate-180 text-sunstone-deep text-[0.65rem]" aria-hidden="true"></i>
                            <span>T&amp;T direct terug naar Bol, klant krijgt de melding.</span>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Regel kiest de vervoerder, AutoPrint stuurt het label naar je printer en de track en trace gaat terug naar het kanaal. Jij verwerkt, ShopLinkr doet de rest.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start mb-12 md:mb-16">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Vervoerders die je koppelt</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Eén integratie aanzetten,
                        <span class="block text-sunstone-deep">direct labels printen.</span>
                    </h2>
                </div>
                <div class="lg:col-span-7">
                    <p class="text-base text-steel leading-relaxed">
                        Koppel zoveel vervoerders als je wilt, met je eigen contract of via een verzendplatform zoals Sendcloud, MyParcel of ParcelPro. Via zo'n platform koppel je vaak in één keer meerdere vervoerders tegelijk.
                    </p>
                    <a href="/integraties" class="group mt-6 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Bekijk alle integraties
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>
            </div>

            <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 md:gap-4">
                {
                    carriers.map((carrier) => (
                        <li>
                            <a
                                href={`/integraties/${carrier.data.slug}`}
                                class="group flex flex-col items-center justify-center gap-3 h-full rounded-2xl bg-paper ring-1 ring-chalk-dark p-5 md:p-6 transition duration-300 ease-out hover:ring-chalk-darker hover:shadow-[0_12px_40px_-20px_rgba(25,25,25,0.18)]"
                            >
                                <div class="h-12 w-12 rounded-lg bg-paper ring-1 ring-chalk-dark flex items-center justify-center overflow-hidden flex-shrink-0">
                                    <img
                                        src={carrier.data.logo}
                                        alt={`${carrier.data.name} logo`}
                                        class="h-full w-full object-contain p-1.5"
                                        loading="lazy"
                                    />
                                </div>
                                <span class="text-sm font-semibold text-charcoal tracking-tight text-center">
                                    {carrier.data.name}
                                </span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Veelgestelde vragen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vragen die vaak terugkomen,
                        <span class="block text-sunstone-deep">helder beantwoord.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Staat je vraag er niet bij? Plan een gesprek of stuur ons een bericht, we denken graag mee over jouw situatie.
                    </p>
                    <a href="/contact" class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Stel je vraag
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
