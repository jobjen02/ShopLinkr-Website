---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';

const subFeatures = [
    {
        eyebrow: 'Rollen en rechten',
        heading: 'Iedereen ziet precies wat bij zijn werk hoort.',
        body: 'Vijf standaardrollen voor beheer, magazijn, administratie, klantenservice en inkoop. Maak daarnaast je eigen rollen aan en bepaal per onderdeel wie mag bekijken, aanmaken, bewerken of verwijderen.',
        icon: 'fa-duotone fa-solid fa-user-shield',
    },
    {
        eyebrow: 'Uitnodigen via e-mail',
        heading: 'Een collega werkt in een paar klikken mee.',
        body: 'Vul het e-mailadres in, kies een rol en klik op uitnodigen. Je collega ontvangt een mail, kiest zelf een wachtwoord en logt direct in op dezelfde omgeving.',
        icon: 'fa-duotone fa-solid fa-envelope-open-text',
    },
    {
        eyebrow: 'QR-login voor magazijn',
        heading: 'Snel inloggen op een gedeeld inpakstation.',
        body: 'Magazijnmedewerkers scannen hun persoonlijke QR-code en typen een pincode van vier cijfers in. Ideaal voor inpakstations waar meerdere mensen achter dezelfde computer werken.',
        icon: 'fa-duotone fa-solid fa-qrcode',
    },
    {
        eyebrow: 'Tweefactorauthenticatie',
        heading: 'Een extra slot op je accounts.',
        body: 'Schakel 2FA per gebruiker in met Google Authenticator, Microsoft Authenticator, Authy of 1Password. Combineer je het met QR-login, dan vul je na de scan nog je code in voor extra zekerheid.',
        icon: 'fa-duotone fa-solid fa-shield-halved',
    },
];

const permissionTypes = [
    {
        title: 'Bekijken',
        body: 'De gebruiker mag gegevens inzien, maar er niets aan wijzigen. Handig voor rollen die alleen hoeven mee te kijken, zoals een stagiair of een externe boekhouder.',
    },
    {
        title: 'Aanmaken',
        body: 'De gebruiker mag nieuwe items toevoegen binnen een onderdeel. Denk aan een nieuwe bestelling aanmaken, een product toevoegen of een leverancier vastleggen.',
    },
    {
        title: 'Bewerken',
        body: 'De gebruiker mag bestaande gegevens wijzigen. Denk aan een adres op een bestelling corrigeren, een bestelling bijwerken of een voorraadcorrectie doorvoeren.',
    },
    {
        title: 'Verwijderen',
        body: 'De gebruiker mag items definitief uit ShopLinkr halen. Dit recht geef je meestal alleen aan rollen die volledige controle nodig hebben.',
    },
];

const faqs = faqsByPage.gebruikers;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Functionaliteiten', '/functionaliteiten'],
        ['Gebruikers', '/functionaliteiten/gebruikers'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Gebruikersbeheer, rollen en rechten met ShopLinkr',
        description: 'Werk samen met je hele team in ShopLinkr. Nodig collega\'s uit, geef ze een rol en bepaal per onderdeel wie wat mag. Voeg zoveel gebruikers toe als je wilt, zonder extra kosten per gebruiker.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Gebruikers, rollen en rechten met ShopLinkr"
    description="Werk samen met je hele team in ShopLinkr. Nodig collega's uit, geef ze een rol en bepaal per onderdeel wie wat mag. Voeg zoveel gebruikers toe als je wilt, zonder extra kosten per gebruiker."
    eyebrow="Team & toegang"
    heading="Werk samen met je hele team."
    subheading="Nodig collega's uit en geef ze de juiste rol, dan werkt iedereen in dezelfde omgeving. Zo ziet en doet elke medewerker precies wat bij zijn werk hoort."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Wie mag wat?</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Iedereen erbij,
                            <span class="block">elk met eigen rechten.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)] overflow-x-auto">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">
                                Rechten per rol
                            </p>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">Voorbeeld</span>
                        </div>

                        <div class="grid grid-cols-[1fr_auto_auto_auto_auto] items-center gap-x-2 sm:gap-x-3 gap-y-2 text-sm min-w-[300px]">
                            <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-gravel"></span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">Bekijken</span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">Aanmaken</span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">Bewerken</span>
                            <span class="text-[9px] uppercase tracking-[0.06em] font-semibold text-gravel text-center leading-tight">Verwijderen</span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-user-shield text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Beheerder</span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Bekijken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Aanmaken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Bewerken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Verwijderen toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-chalk-light text-steel ring-1 ring-chalk-dark">
                                    <i class="fa-solid fa-boxes-packing text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Magazijn</span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Bekijken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Aanmaken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Bewerken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Verwijderen niet toegestaan">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-chalk-light text-steel ring-1 ring-chalk-dark">
                                    <i class="fa-solid fa-headset text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Klantenservice</span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Bekijken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Aanmaken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Bewerken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Verwijderen niet toegestaan">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>

                            <div class="flex items-center gap-2 py-2 border-t border-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 w-6 rounded-md bg-sunstone-mist/60 text-sunstone-deep ring-1 ring-sunstone-soft/60">
                                    <i class="fa-solid fa-user-plus text-[0.65rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-charcoal font-medium">Stagiair <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-sunstone-deep ml-1">eigen rol</span></span>
                            </div>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-sunstone-deep" aria-label="Bekijken toegestaan">
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Aanmaken niet toegestaan">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Bewerken niet toegestaan">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>
                            <span class="flex items-center justify-center py-2 border-t border-chalk-dark text-gravel/60" aria-label="Verwijderen niet toegestaan">
                                <i class="fa-solid fa-minus text-[0.65rem]" aria-hidden="true"></i>
                            </span>
                        </div>

                        <div class="flex items-center justify-between gap-3 pt-4 mt-4 border-t border-chalk-darker">
                            <span class="text-sm font-semibold text-charcoal">Gebruikers</span>
                            <span class="inline-flex items-baseline gap-1.5">
                                <i class="fa-solid fa-infinity text-sunstone-deep text-base" aria-hidden="true"></i>
                                <span class="text-sm font-semibold text-sunstone-deep">geen kosten per gebruiker</span>
                            </span>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Begin met vijf standaardrollen en maak daarnaast eigen rollen aan voor wie net iets anders nodig heeft.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Rechten per onderdeel</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vier soorten rechten,
                        <span class="block text-sunstone-deep">precies de juiste toegang.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Per onderdeel van ShopLinkr, zoals bestellingen, producten, voorraad en instellingen, bepaal je wat een rol mag. Combineer de rechten tot een rol die past bij de verantwoordelijkheid van je medewerker.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            permissionTypes.map((type) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-key text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{type.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{type.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Veelgestelde vragen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vragen die vaak terugkomen,
                        <span class="block text-sunstone-deep">helder beantwoord.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Mis je een vraag? Plan een gesprek of stuur ons een bericht. We denken graag mee over jouw situatie.
                    </p>
                    <a href="/contact" class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Stel je vraag
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
