---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'Eén scherm',
        heading: 'Alle retouren bij elkaar.',
        body: 'Retouren van Bol, je eigen webshop en je andere kanalen komen samen in één overzicht. Je hoeft niet langer per platform in te loggen om iets af te handelen.',
        icon: 'fa-solid fa-arrow-rotate-left',
    },
    {
        eyebrow: 'Terug op voorraad',
        heading: 'Eén klik en het product is weer beschikbaar.',
        body: 'Boek een geaccepteerde retour direct terug naar je verkoopbare voorraad. ShopLinkr werkt automatisch je voorraad bij op alle gekoppelde verkoopkanalen.',
        icon: 'fa-solid fa-boxes-stacked',
    },
    {
        eyebrow: 'Notities',
        heading: 'Je team weet altijd de status.',
        body: 'Voeg interne notities toe per retour, zodat je collega bij de pakkettafel meteen ziet waar hij rekening mee moet houden. Iedereen op één lijn, zonder eindeloze appjes.',
        icon: 'fa-solid fa-note-sticky',
    },
    {
        eyebrow: 'Status volgen',
        heading: 'Houd grip op elke retourstap.',
        body: 'Van aangevraagd tot afgehandeld, je ziet per retour precies waar het staat. Niets blijft hangen en je klant krijgt sneller duidelijkheid.',
        icon: 'fa-solid fa-list-check',
    },
    {
        eyebrow: 'Inzicht',
        heading: 'Stuur bij op retourpercentages.',
        body: 'Krijg per product inzicht in hoe vaak het retour komt. Foute foto, een te krappe maat of misleidende tekst? Je stuurt erop bij voordat het je marge kost.',
        icon: 'fa-solid fa-chart-line-up',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Retouren | ShopLinkr',
    description: 'Makkelijk retouren verwerken in ShopLinkr. Retouren verwerken doe je eenvoudig en snel. Boek geaccepteerde retouren direct terug naar je huidige voorraad. Het wordt zelfs bijna leuk om retouren te verwerken in ShopLinkr.',
};

export const prerender = true;
---

<PageLayout
    title="Retouren verwerken met ShopLinkr"
    description="Makkelijk retouren verwerken in ShopLinkr. Retouren verwerken doe je eenvoudig en snel. Boek geaccepteerde retouren direct terug naar je huidige voorraad. Het wordt zelfs bijna leuk om retouren te verwerken in ShopLinkr."
    eyebrow="Retourbeheer"
    heading="Retouren afhandelen, zonder de rommel."
    subheading="Retouren horen erbij, maar het verwerken hoeft je dag niet te kosten. Met ShopLinkr accepteer je een retour, boek je hem terug op voorraad en je bent klaar voor de volgende."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Retouren onder controle</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Alle retouren op één plek, snel afgehandeld.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    In plaats van per kanaal door retouren te ploegen, werk je in ShopLinkr alles bij vanuit één scherm. Je accepteert of weigert een retour, voegt een notitie toe en je voorraad wordt automatisch bijgewerkt.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
