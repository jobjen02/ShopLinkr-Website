---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';

const subFeatures = [
    {
        eyebrow: 'Retourstatus per item',
        heading: 'Beoordeel elk item apart.',
        body: 'Een retour bevat soms meerdere producten, en niet elk product handel je hetzelfde af. Je geeft ze stuk voor stuk een eigen retourstatus, met precies de opties die je verkoopkanaal aanbiedt.',
        icon: 'fa-duotone fa-solid fa-list-check',
    },
    {
        eyebrow: "Foto's als bewijs",
        heading: 'Leg vast wat je binnenkrijgt.',
        body: "Voeg meerdere foto's per retouritem toe. Handig bij beschadigde of incomplete retouren, als bewijs richting de klant of om intern vast te leggen wat je hebt ontvangen.",
        icon: 'fa-duotone fa-solid fa-camera',
    },
    {
        eyebrow: 'Restock',
        heading: 'Terug op voorraad, of niet.',
        body: 'Bepaal per item of het terug op voorraad gaat en kies de magazijnlocatie. Bij bundels stel je per subproduct een locatie in.',
        icon: 'fa-duotone fa-solid fa-boxes-stacked',
    },
    {
        eyebrow: 'T&T scannen',
        heading: 'Eén scan, de juiste retour.',
        body: 'Pak het retourpakket, scan de track en trace code en de bijbehorende retour staat meteen voor je open. Geen lijsten doorzoeken, gewoon verwerken.',
        icon: 'fa-duotone fa-solid fa-barcode-read',
    },
];

const workflowSteps = [
    {
        title: 'Retour openen',
        body: 'Open de retour vanuit je overzicht of scan de T&T code op het pakket. Je ziet meteen de details, de klant en de producten die terugkomen.',
    },
    {
        title: 'Items beoordelen',
        body: "Kies per item de retourstatus, vul het aantal ontvangen stuks in en voeg eventueel foto's toe van de staat waarin het product binnenkwam.",
    },
    {
        title: 'Terug op voorraad zetten',
        body: 'Bepaal per item of het weer verkocht kan worden en kies de magazijnlocatie.',
    },
    {
        title: 'Retour afronden',
        body: 'Je handelt de retour in één keer af. ShopLinkr zet de retour op Afgehandeld en koppelt de verwerking automatisch terug naar je verkoopkanaal.',
    },
];

const faqs = faqsByPage.retouren;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Functionaliteiten', '/functionaliteiten'],
        ['Retouren', '/functionaliteiten/retouren'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Retouren verwerken met ShopLinkr',
        description: 'Verwerk retouren gestructureerd in ShopLinkr. Beoordeel per item, voeg foto\'s toe als bewijs en boek items terug op de juiste magazijnlocatie. Je voorraad en kanalen blijven automatisch in sync.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Retouren verwerken met ShopLinkr"
    description="Verwerk retouren gestructureerd in ShopLinkr. Beoordeel per item, voeg foto's toe als bewijs en boek items terug op de juiste magazijnlocatie. Je voorraad en kanalen blijven automatisch in sync."
    eyebrow="Retourbeheer"
    heading="Retouren afhandelen, in een vast ritme."
    subheading="Retouren horen erbij, de verwerking hoeft geen gedoe te zijn. Beoordeel per item, leg vast met foto's en boek terug op voorraad. Door naar de volgende."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Retouren onder controle</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Retouren gestructureerd
                            <span class="block">verwerken.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <div class="flex items-center gap-2.5">
                                <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-rotate-left text-[0.7rem]" aria-hidden="true"></i>
                                </span>
                                <div class="flex flex-col">
                                    <span class="text-sm font-semibold text-charcoal">Retour #R-48217</span>
                                    <span class="text-[11px] text-gravel">Webshop · 2 items</span>
                                </div>
                            </div>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">In verwerking</span>
                        </div>

                        <ul class="space-y-3 mb-4">
                            <li class="px-3 py-3 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center justify-between gap-3 mb-2.5">
                                    <span class="text-sm font-medium text-charcoal">Linnen kussenhoes, beige</span>
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 text-[11px] font-semibold">
                                        <i class="fa-solid fa-check text-[9px]" aria-hidden="true"></i>
                                        Gegrond
                                    </span>
                                </div>
                                <div class="flex items-center justify-between gap-3 text-xs">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center h-4 w-7 rounded-full bg-sunstone-deep relative">
                                            <span class="absolute right-0.5 h-3 w-3 rounded-full bg-paper"></span>
                                        </span>
                                        <span class="text-charcoal font-medium">Toevoegen aan voorraad</span>
                                    </div>
                                    <span class="text-gravel tabular-nums">A.3</span>
                                </div>
                            </li>
                            <li class="px-3 py-3 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center justify-between gap-3 mb-2.5">
                                    <span class="text-sm font-medium text-charcoal">Keramische theepot, 1L</span>
                                    <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-chalk-dark text-charcoal ring-1 ring-chalk-darker text-[11px] font-semibold">
                                        <i class="fa-solid fa-triangle-exclamation text-[9px]" aria-hidden="true"></i>
                                        Beschadigd
                                    </span>
                                </div>
                                <div class="flex items-center justify-between gap-3 text-xs">
                                    <div class="flex items-center gap-2">
                                        <span class="inline-flex items-center h-4 w-7 rounded-full bg-chalk-dark relative">
                                            <span class="absolute left-0.5 h-3 w-3 rounded-full bg-paper"></span>
                                        </span>
                                        <span class="text-charcoal font-medium">Toevoegen aan voorraad</span>
                                    </div>
                                    <span class="text-gravel">Afgeschreven</span>
                                </div>
                            </li>
                        </ul>

                        <div class="flex items-center justify-between gap-3 pt-3 border-t border-chalk-darker">
                            <span class="text-sm font-semibold text-charcoal">Status naar kanaal</span>
                            <span class="inline-flex items-center gap-1.5 text-sunstone-deep font-semibold text-sm">
                                Teruggekoppeld
                                <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                            </span>
                        </div>
                        <p class="text-[11px] text-gravel mt-2 leading-relaxed">
                            Elk item krijgt een eigen beoordeling en je voorraad wordt meteen bijgewerkt.
                        </p>
                    </div>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Zo verwerk je een retour</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vier stappen,
                        <span class="block text-sunstone-deep">van binnenkomst tot afgehandeld.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Elke retour volgt dezelfde route in ShopLinkr. Voorspelbaar voor jou en snel uit te leggen aan nieuwe collega's.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ol class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            workflowSteps.map((step, index) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5 text-sm font-semibold">
                                        {index + 1}
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{step.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{step.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Veelgestelde vragen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vragen die vaak terugkomen,
                        <span class="block text-sunstone-deep">helder beantwoord.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Staat je vraag er niet bij? Plan een gesprek of stuur ons een bericht. We denken graag mee over jouw situatie.
                    </p>
                    <a href="/contact" class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Stel je vraag
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
