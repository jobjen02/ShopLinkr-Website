---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const rows = [
    {
        eyebrow: 'Hiërarchie',
        heading: 'Bouw locaties op zoals je magazijn echt is.',
        body: 'Maak een hiërarchische structuur van gang, stelling, schap en vak. Aan elk niveau koppel je producten, zodat je in één oogopslag weet waar iets ligt zonder eindeloos te zoeken.',
        icon: 'fa-solid fa-sitemap',
    },
    {
        eyebrow: 'Picklijst',
        heading: 'Locatie staat direct op de picklijst.',
        body: 'Op de bestellingenpagina en op de picklijst zie je per product meteen de locatie. Je picker loopt de meest efficiënte route en haalt in één keer alles op voor je bestellingen.',
        icon: 'fa-solid fa-list-check',
    },
    {
        eyebrow: 'Pick locatie',
        heading: 'Eerst de voorraad uit het schap.',
        body: 'De voorraad van een pick locatie gebruik je als eerst. Hier loopt je picker langs voor de dagelijkse orders, zodat je magazijnvloer altijd in beweging blijft.',
        icon: 'fa-solid fa-hand-pointer',
    },
    {
        eyebrow: 'Voorraad locatie',
        heading: 'Bulk pas aanspreken als het schap leeg is.',
        body: 'Is de pick locatie leeg, dan gaat ShopLinkr automatisch over op de voorraad locatie. Zo houd je je bulkvoorraad apart en spreek je hem pas aan wanneer het nodig is.',
        icon: 'fa-solid fa-warehouse',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Locaties beheren met ShopLinkr',
    description: 'Locatiebeheer in ShopLinkr. Je kunt een hiërarchie aanmaken van locaties en hier producten aan koppelen. Overzichtelijk, gemakkelijk en efficiënt!',
};

export const prerender = true;
---

<PageLayout
    title="Locaties beheren met ShopLinkr"
    description="Locatiebeheer in ShopLinkr. Je kunt een hiërarchie aanmaken van locaties en hier producten aan koppelen. Overzichtelijk, gemakkelijk en efficiënt!"
    eyebrow="Locatiebeheer"
    heading="Beheer eenvoudig de locaties van je producten."
    subheading="Een goed magazijn begint bij goede locaties. Met ShopLinkr zie je direct waar elk product ligt en hoeveel stuks je nodig hebt voor je bestelling."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="max-w-3xl mb-12 md:mb-16">
                <p class="eyebrow mb-4">Locatiebeheer</p>
                <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                    Kinderlijk eenvoudig je locaties beheren.
                </h2>
                <p class="mt-6 text-lg text-steel leading-relaxed">
                    Het wordt kinderlijk eenvoudig om de locaties van je producten te beheren. Je ziet eenvoudig waar je een product moet halen in je magazijn om je bestelling compleet te maken.
                </p>
            </div>

            <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                {
                    rows.map((row) => (
                        <li class="py-10 md:py-12">
                            <div class="grid md:grid-cols-12 gap-6 md:gap-10">
                                <div class="md:col-span-4 flex md:items-start gap-4">
                                    <div class="flex items-center justify-center h-10 w-10 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class={`${row.icon} text-base`} aria-hidden="true" />
                                    </div>
                                    <div class="md:hidden">
                                        <p class="eyebrow mb-1">{row.eyebrow}</p>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight">{row.heading}</h3>
                                    </div>
                                    <div class="hidden md:block">
                                        <p class="eyebrow mb-2">{row.eyebrow}</p>
                                        <h3 class="text-xl md:text-2xl font-semibold text-charcoal tracking-tight leading-snug">{row.heading}</h3>
                                    </div>
                                </div>
                                <div class="md:col-span-8">
                                    <p class="text-steel leading-relaxed text-[0.975rem] md:text-base">
                                        {row.body}
                                    </p>
                                </div>
                            </div>
                        </li>
                    ))
                }
            </ul>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
