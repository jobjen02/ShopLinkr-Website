---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';

const subFeatures = [
    {
        eyebrow: 'Drie snelkeuzes',
        heading: 'Van backorders dekken tot slim inkopen.',
        body: 'Kies in één klik of je alleen backorders wilt dekken, je voorraadniveaus wilt aanhouden, of slim wilt inkopen op basis van prognose en levertijd. Daarna kun je losse onderdelen nog aan of uit zetten.',
        icon: 'fa-duotone fa-solid fa-sliders',
    },
    {
        eyebrow: 'Per leverancier',
        heading: 'Eén advies, gescheiden per leverancier.',
        body: 'Selecteer een of meerdere leveranciers. ShopLinkr rekent per leverancier uit wat je moet bestellen. Alleen producten die aan die leveranciers gekoppeld zijn tellen mee.',
        icon: 'fa-duotone fa-solid fa-truck-fast',
    },
    {
        eyebrow: 'Omzetten in één klik',
        heading: 'Van advies naar concept-levering.',
        body: 'Tevreden met het advies? Eén klik op Omzetten naar leveringen en ShopLinkr maakt per leverancier een concept-levering aan, klaar om te bestellen.',
        icon: 'fa-duotone fa-solid fa-arrow-right-arrow-left',
    },
    {
        eyebrow: 'Slow movers eruit',
        heading: 'Geen dood kapitaal in je advies.',
        body: 'Stel een minimum aantal verkopen in. Producten die daaronder zitten blijven automatisch buiten het advies, zodat eenmalige verkopen je inkoop niet sturen.',
        icon: 'fa-duotone fa-solid fa-filter',
    },
];

const signals = [
    {
        title: 'Backorders dekken',
        body: 'Producten met openstaande backorders komen in het advies, zodat je de bestellingen die je al hebt aangenomen ook echt kunt leveren.',
    },
    {
        title: 'Voorraaddrempels',
        body: 'Per product stel je een inkoopdrempel en een inkoopdoel in. Zakt de beschikbare voorraad onder de drempel, dan vult het advies aan tot het doel.',
    },
    {
        title: 'Verwachte verkoop',
        body: 'Op basis van de gemiddelde verkoop per dag berekent ShopLinkr hoeveel je nodig hebt voor de adviesperiode. Kies uit 14 dagen, 28 dagen, 3 maanden of een eigen periode.',
    },
    {
        title: 'Levertijd meetellen',
        body: 'Tel de levertijd van je leverancier optioneel op bij de adviesperiode, zodat je niet zonder voorraad zit terwijl je inkoop nog onderweg is.',
    },
    {
        title: 'Openstaande leveringen aftrekken',
        body: 'Wat je al bij een leverancier hebt besteld wordt van het advies afgetrokken. Geen dubbele inkoop, ook niet als een eerdere levering nog onderweg is.',
    },
];

const faqs = faqsByPage.inkoopadvies;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Functionaliteiten', '/functionaliteiten'],
        ['Inkoopadvies', '/functionaliteiten/inkoopadvies'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Inkoopadvies met ShopLinkr',
        description: 'Laat ShopLinkr per leverancier uitrekenen wat je moet bijbestellen, op basis van voorraad, backorders en verwachte verkoop. Zet het advies in één klik om naar concept-leveringen.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Inkoopadvies met ShopLinkr"
    description="Laat ShopLinkr per leverancier uitrekenen wat je moet bijbestellen, op basis van voorraad, backorders en verwachte verkoop. Zet het advies in één klik om naar concept-leveringen."
    eyebrow="Slim inkopen"
    heading="Weet wanneer je wat moet inkopen."
    subheading="ShopLinkr rekent per leverancier uit wat je moet bijbestellen, op basis van je voorraad, backorders en verwachte verkoop. Zet het advies in één klik om naar concept-leveringen."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Proactief inkopen</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Zo komt het advies
                            <span class="block">tot stand.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel mb-4">
                            Voorbeeld berekening
                        </p>
                        <dl class="divide-y divide-chalk-dark text-sm">
                            <div class="flex items-baseline justify-between py-2.5">
                                <dt class="text-steel">Voorraad nu</dt>
                                <dd class="text-charcoal font-semibold tabular-nums">5 stuks</dd>
                            </div>
                            <div class="flex items-baseline justify-between py-2.5">
                                <dt class="text-steel">+ Backorders</dt>
                                <dd class="text-charcoal font-semibold tabular-nums">12 stuks</dd>
                            </div>
                            <div class="flex items-baseline justify-between py-2.5">
                                <dt class="text-steel">
                                    + Verwachte verkoop
                                    <span class="block text-[11px] text-gravel mt-0.5">14 dagen × 2,3 per dag</span>
                                </dt>
                                <dd class="text-charcoal font-semibold tabular-nums">32 stuks</dd>
                            </div>
                            <div class="flex items-baseline justify-between py-2.5">
                                <dt class="text-steel">
                                    + Levertijd meetellen
                                    <span class="block text-[11px] text-gravel mt-0.5">3 dagen × 2,3 per dag</span>
                                </dt>
                                <dd class="text-charcoal font-semibold tabular-nums">7 stuks</dd>
                            </div>
                            <div class="flex items-baseline justify-between py-3 mt-1 border-t border-chalk-darker">
                                <dt class="text-charcoal font-semibold">Bestel</dt>
                                <dd class="text-sunstone-deep font-semibold text-xl tabular-nums">46 stuks</dd>
                            </div>
                        </dl>
                        <p class="text-[11px] text-gravel mt-3 leading-relaxed">
                            Afgerond op dozen van 12 wordt het advies <span class="text-charcoal font-semibold">48 stuks</span>.
                        </p>
                    </div>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Hoe rekent het advies?</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vijf signalen,
                        <span class="block text-sunstone-deep">één concreet advies.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Zet elk onderdeel los aan of uit, of pak een snelkeuze die de juiste combinatie voor je instelt. Backorders, voorraaddrempels en verwachte verkoop wegen samen mee. Openstaande leveringen worden afgetrokken, zodat je niet dubbel inkoopt.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            signals.map((signal) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-check text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{signal.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{signal.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Veelgestelde vragen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vragen die vaak terugkomen,
                        <span class="block text-sunstone-deep">helder beantwoord.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Mis je een vraag? Plan een gesprek of stuur ons een bericht, we denken graag mee over jouw situatie.
                    </p>
                    <a href="/contact" class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Stel je vraag
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
