---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const stories = [
    {
        eyebrow: 'Centraal productoverzicht',
        heading: 'Al je producten samen op één plek.',
        body: 'ShopLinkr haalt je producten op uit Bol, Shopify, WooCommerce en Kaufland en zet ze samen in één overzicht. Vanuit dat overzicht beheer je voorraad, magazijnlocaties, barcodes en bundels en verwerk je je orders. Eén centrale plek voor alles wat met je magazijn te maken heeft.',
        icon: 'fa-duotone fa-solid fa-cubes',
    },
    {
        eyebrow: 'Voorraad per variant',
        heading: 'Maten, kleuren en smaken nauwkeurig bijhouden.',
        body: 'Verkoop je hetzelfde product in meerdere varianten? ShopLinkr houdt de voorraad per variant bij en zet die voorraad per variant terug naar je verkoopkanalen. Zo zie je in één oogopslag welke variant goed loopt en welke nog op het schap ligt.',
        icon: 'fa-duotone fa-solid fa-shapes',
    },
    {
        eyebrow: 'Productbundels',
        heading: 'Meerdere artikelen, één verkoopeenheid.',
        body: 'Stel een bundel samen door losse artikelen te koppelen tot één verkoopproduct. Verkoop je een cadeauset of combideal, dan trekt ShopLinkr automatisch de juiste hoeveelheid af van elk component. De voorraad van de bundel rekent vanzelf op het minst beschikbare onderdeel.',
        icon: 'fa-duotone fa-solid fa-boxes-packing',
    },
    {
        eyebrow: 'Voorraadmeldingen',
        heading: 'Krijg een seintje voordat je misgrijpt.',
        body: 'Stel per product een drempelwaarde in en ontvang automatisch een melding zodra de voorraad daaronder zakt. Zo weet je op tijd wanneer je moet inkopen en voorkom je dat een topverkoper opeens uitverkocht raakt.',
        icon: 'fa-duotone fa-solid fa-bell',
    },
    {
        eyebrow: 'Fictieve voorraad',
        heading: 'Houd je echte cijfers privé.',
        body: 'Wil je niet dat concurrenten kunnen zien hoeveel je verkoopt? Stel een fictief aantal in dat ShopLinkr doorgeeft aan je verkoopkanalen. Zolang je werkelijke voorraad boven de drempel blijft, communiceren we het fictieve aantal. Daalt je echte voorraad? Dan schakelen we automatisch over, zodat je nooit meer verkoopt dan je hebt.',
        icon: 'fa-duotone fa-solid fa-eye-slash',
    },
    {
        eyebrow: 'Barcodes en EAN',
        heading: 'Elke variant met een eigen scancode.',
        body: 'Leg per product en per variant de barcode of EAN vast en gebruik die overal terug in ShopLinkr. Tijdens het picken scant je medewerker het juiste artikel, bij inkomende leveringen vink je producten af op code. Eén scan, en je weet zeker dat je de goede pakt.',
        icon: 'fa-duotone fa-solid fa-barcode',
    },
    {
        eyebrow: 'Magazijnlocaties',
        heading: 'Direct weten waar elk product ligt.',
        body: 'Koppel een magazijnlocatie aan je producten en zie tijdens het picken precies waar je moet zijn. Werkt naadloos samen met de pick & pack lijsten en bespaart elke picker minuten per order.',
        icon: 'fa-duotone fa-solid fa-location-dot',
    },
];

const channels = [
    {
        title: 'Bol',
        body: 'We importeren je Bol-aanbod in ShopLinkr en houden de voorraad realtime kloppend, inclusief slimme LVB-switch zodra je eigen magazijn de verkoop overneemt.',
    },
    {
        title: 'Shopify',
        body: 'ShopLinkr leest je Shopify-producten in en houdt de voorraad in je shop accuraat, ook als er via andere kanalen wordt verkocht.',
    },
    {
        title: 'WooCommerce',
        body: 'Je WooCommerce-producten komen automatisch in je ShopLinkr-omgeving terecht. De voorraad blijft realtime synchroon met je shop.',
    },
    {
        title: 'Kaufland',
        body: 'Breid uit naar de Duitse markt zonder dubbel voorraadwerk. ShopLinkr koppelt met Kaufland en houdt de voorraad daar net zo nauwkeurig als op je andere kanalen.',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Productbeheer met ShopLinkr',
    description: 'Beheer je producten, varianten, bundels en magazijnlocaties centraal in ShopLinkr. Eén overzicht voor al je verkoopkanalen.',
};

export const prerender = true;
---

<PageLayout
    title="Producten beheren met ShopLinkr"
    description="Beheer je producten, varianten, bundels en magazijnlocaties centraal in ShopLinkr. Eén overzicht voor al je verkoopkanalen."
    eyebrow="Producten"
    heading="Al je producten in één centraal overzicht."
    subheading="ShopLinkr haalt je producten op uit Bol, Shopify, WooCommerce en Kaufland en zet ze in één centraal overzicht. Vanuit die plek beheer je voorraad, varianten, bundels en magazijnlocaties voor je hele assortiment."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="bg-paper">
        <div class="container-prose">
            {
                stories.map((story, index) => {
                    const isReversed = index % 2 === 1;

                    return (
                        <article class="py-20 md:py-28 border-b border-chalk-dark last:border-b-0">
                            <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
                                <div class={`lg:col-span-7 ${isReversed ? 'lg:order-2' : 'lg:order-1'}`}>
                                    <div
                                        class="relative w-full rounded-3xl overflow-hidden bg-gradient-to-br from-sunstone-mist via-paper to-chalk-light ring-1 ring-chalk-dark"
                                        style="aspect-ratio: 4 / 3;"
                                    >
                                        <div class="absolute inset-0 opacity-40 pointer-events-none" style="background: radial-gradient(circle at 30% 30%, var(--color-sunstone-soft) 0%, transparent 55%);"></div>
                                        <div class="absolute inset-0 flex items-center justify-center p-10">
                                            <div class="flex items-center justify-center h-28 w-28 md:h-32 md:w-32 rounded-3xl bg-paper text-sunstone-deep ring-1 ring-chalk-dark shadow-[0_18px_40px_-18px_rgba(25,25,25,0.18)]">
                                                <i class={`${story.icon} text-5xl md:text-6xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class={`lg:col-span-5 ${isReversed ? 'lg:order-1' : 'lg:order-2'}`}>
                                    <p class="eyebrow mb-5">{story.eyebrow}</p>
                                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.15] mb-6">
                                        {story.heading}
                                    </h2>
                                    <p class="text-lg text-steel leading-relaxed">
                                        {story.body}
                                    </p>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Multi-channel</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Eén voorraad,
                        <span class="block text-sunstone-deep">op elk verkoopkanaal.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Verkoop je via meerdere kanalen, dan houd je je voorraad niet meer op elk platform apart bij. ShopLinkr importeert je producten uit je verkoopkanalen en stuurt voorraadupdates realtime terug. Zo voorkom je oversells zonder dat je iets dubbel hoeft te doen.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            channels.map((channel) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-plug text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{channel.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{channel.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
