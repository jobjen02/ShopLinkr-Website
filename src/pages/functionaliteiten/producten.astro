---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';

const subFeatures = [
    {
        eyebrow: 'Variantgroepen',
        heading: 'Maten, kleuren en hoeveelheden netjes gegroepeerd.',
        body: 'Groepeer hetzelfde product in andere maten, kleuren of hoeveelheden onder één hoofdproduct. Elke variant houdt zijn eigen voorraad, in het overzicht zie je de gecombineerde stand.',
        icon: 'fa-duotone fa-solid fa-shapes',
    },
    {
        eyebrow: 'Productbundels',
        heading: 'Combineer losse producten tot één verkoopeenheid.',
        body: 'Verkoop een cadeauset of combideal als bundel. ShopLinkr berekent de bundelvoorraad op basis van het schaarste onderdeel en boekt elk onderdeel af zodra de bundel verkocht wordt.',
        icon: 'fa-duotone fa-solid fa-boxes-packing',
    },
    {
        eyebrow: 'Voorraadbronnen',
        heading: 'Eén bron, meerdere varianten op gewicht of lengte.',
        body: 'Houd je basisvoorraad bij in kilo, meter of liter en koppel varianten van bijvoorbeeld 500 gram of 1 meter. ShopLinkr rekent per variant uit hoeveel er nog beschikbaar is.',
        icon: 'fa-duotone fa-solid fa-scale-balanced',
    },
    {
        eyebrow: 'ABC-analyse',
        heading: 'Zie welke producten je magazijn draaiende houden.',
        body: 'ShopLinkr classificeert je assortiment op pickfrequentie van de afgelopen 90 dagen. Zo plaats je je A-producten dicht bij je inpakstation en houd je je magazijnindeling actueel.',
        icon: 'fa-duotone fa-solid fa-chart-pie',
    },
];

const productTypes = [
    {
        title: 'Losse producten',
        body: 'De standaard. Elk product heeft een eigen EAN, voorraad en magazijnlocatie. Geschikt voor de meeste artikelen die je los inkoopt en los verkoopt.',
        icon: 'fa-solid fa-cube',
    },
    {
        title: 'Bundelproducten',
        body: 'Meerdere producten samengevoegd tot één verkoopeenheid. De bundelvoorraad volgt automatisch het schaarste onderdeel en bij elke verkoop wordt elk onderdeel afgeboekt.',
        icon: 'fa-solid fa-boxes-packing',
    },
    {
        title: 'Voorraadbronproducten',
        body: 'Houd voorraad bij in een meeteenheid zoals gewicht, lengte of volume. Vanuit die ene bron verkoop je varianten van bijvoorbeeld 500 gram, 1 kilo of 3 meter.',
        icon: 'fa-solid fa-scale-balanced',
    },
    {
        title: 'Onbeperkte voorraad',
        body: 'Voor producten die altijd beschikbaar zijn, zoals softwarelicenties of downloads. Geen afboeking bij verkoop, geen telling, altijd leverbaar op je kanalen.',
        icon: 'fa-solid fa-infinity',
    },
];

const faqs = faqsByPage.producten;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Functionaliteiten', '/functionaliteiten'],
        ['Producten', '/functionaliteiten/producten'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Producten beheren met ShopLinkr',
        description: 'Eén centraal productoverzicht voor al je verkoopkanalen. Werk met variantgroepen, bundels, voorraadbronnen en ABC-analyse vanuit dezelfde plek.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Producten beheren met ShopLinkr"
    description="Eén centraal productoverzicht voor al je verkoopkanalen. Werk met variantgroepen, bundels, voorraadbronnen en ABC-analyse vanuit dezelfde plek."
    eyebrow="Producten"
    heading="Al je producten in één overzicht."
    subheading="Je producten uit elk verkoopkanaal komen samen in één overzicht. Vanuit daar beheer je voorraad, varianten, bundels en voorraadbronnen."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Je centrale overzicht</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Eén overzicht
                            <span class="block">voor je hele assortiment.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4 pb-3 border-b border-chalk-dark">
                            <span class="text-sm font-semibold text-charcoal">Producten</span>
                            <span class="text-[11px] text-gravel tabular-nums">5 van 2.847</span>
                        </div>

                        <ul class="space-y-2">
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center gap-2.5 text-sm min-w-0">
                                    <span class="inline-flex items-center justify-center h-6 w-6 rounded bg-paper text-gravel ring-1 ring-chalk-dark flex-shrink-0">
                                        <i class="fa-solid fa-cube text-[0.65rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-charcoal font-medium truncate">Bidon RVS 750ml</span>
                                </div>
                                <span class="text-xs text-charcoal font-semibold tabular-nums whitespace-nowrap">240 stuks</span>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                                <div class="flex items-center gap-2.5 text-sm min-w-0">
                                    <span class="inline-flex items-center justify-center h-6 w-6 rounded bg-paper text-sunstone-deep ring-1 ring-sunstone-soft/40 flex-shrink-0">
                                        <i class="fa-solid fa-shapes text-[0.65rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-charcoal font-medium truncate">T-shirt classic</span>
                                    <span class="text-[10px] uppercase tracking-[0.1em] font-semibold text-gravel flex-shrink-0">Variantgroep</span>
                                </div>
                                <span class="text-xs text-sunstone-deep font-semibold tabular-nums whitespace-nowrap">12 varianten</span>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center gap-2.5 text-sm min-w-0">
                                    <span class="inline-flex items-center justify-center h-6 w-6 rounded bg-paper text-gravel ring-1 ring-chalk-dark flex-shrink-0">
                                        <i class="fa-solid fa-boxes-packing text-[0.65rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-charcoal font-medium truncate">Cadeauset Tech Starter</span>
                                    <span class="text-[10px] uppercase tracking-[0.1em] font-semibold text-gravel flex-shrink-0">Bundel</span>
                                </div>
                                <span class="text-xs text-charcoal font-semibold tabular-nums whitespace-nowrap">6 stuks</span>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center gap-2.5 text-sm min-w-0">
                                    <span class="inline-flex items-center justify-center h-6 w-6 rounded bg-paper text-gravel ring-1 ring-chalk-dark flex-shrink-0">
                                        <i class="fa-solid fa-scale-balanced text-[0.65rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-charcoal font-medium truncate">Hondenbrokken premium</span>
                                    <span class="text-[10px] uppercase tracking-[0.1em] font-semibold text-gravel flex-shrink-0">Bron</span>
                                </div>
                                <span class="text-xs text-charcoal font-semibold tabular-nums whitespace-nowrap">85 kg</span>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center gap-2.5 text-sm min-w-0">
                                    <span class="inline-flex items-center justify-center h-6 w-6 rounded bg-paper text-gravel ring-1 ring-chalk-dark flex-shrink-0">
                                        <i class="fa-solid fa-infinity text-[0.65rem]" aria-hidden="true"></i>
                                    </span>
                                    <span class="text-charcoal font-medium truncate">Softwarelicentie Pro</span>
                                    <span class="text-[10px] uppercase tracking-[0.1em] font-semibold text-gravel flex-shrink-0">Onbeperkt</span>
                                </div>
                                <span class="text-xs text-charcoal font-semibold tabular-nums whitespace-nowrap">∞</span>
                            </li>
                        </ul>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Losse producten, variantgroepen, bundels, voorraadbronnen en producten met onbeperkte voorraad staan naast elkaar in hetzelfde overzicht.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Soorten producten</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vier producttypes,
                        <span class="block text-sunstone-deep">één manier van werken.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Niet elk product werkt hetzelfde. Een bundel rekent zijn voorraad af op de losse onderdelen, een voorraadbron werkt vanuit een meeteenheid en producten met onbeperkte voorraad houden helemaal geen aantallen bij. ShopLinkr ondersteunt elk type vanuit hetzelfde overzicht.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            productTypes.map((type) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class={`${type.icon} text-xs`} aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{type.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{type.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>
    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Productbundels</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Combineer losse producten
                        <span class="block text-sunstone-deep">tot één bundel.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Een bundel is een nieuw product dat je samenstelt uit producten die je al verkoopt. Geef de bundel een eigen titel, prijs en afbeelding, en bepaal welke onderdelen er met welk aantal in zitten.
                    </p>
                    <p class="mt-4 text-base text-steel leading-relaxed">
                        Stel je verkoopt een cadeauset met 1 telefoon, 1 oplader en 2 hoesjes. ShopLinkr berekent de bundelvoorraad automatisch op basis van het onderdeel dat het minst beschikbaar is. Verkoop je een hoesje los? Dan zakt de bundelvoorraad meteen mee.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel mb-3">
                        Voorbeeld: cadeauset
                    </p>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <div class="flex items-center gap-2.5">
                                <span class="inline-flex items-center justify-center h-7 w-7 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-boxes-packing text-[0.7rem]" aria-hidden="true"></i>
                                </span>
                                <span class="text-sm font-semibold text-charcoal">Cadeauset</span>
                            </div>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel">Bundel</span>
                        </div>

                        <ul class="space-y-2 mb-4">
                            <li class="flex items-center justify-between gap-3 px-3 py-2 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center gap-2 text-sm">
                                    <span class="text-charcoal font-medium">Telefoon</span>
                                    <span class="text-gravel">× 1</span>
                                </div>
                                <span class="text-xs text-gravel tabular-nums">10 op voorraad → <span class="text-charcoal font-semibold">10 stuks</span></span>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <div class="flex items-center gap-2 text-sm">
                                    <span class="text-charcoal font-medium">Oplader</span>
                                    <span class="text-gravel">× 1</span>
                                </div>
                                <span class="text-xs text-gravel tabular-nums">8 op voorraad → <span class="text-charcoal font-semibold">8 stuks</span></span>
                            </li>
                            <li class="flex items-center justify-between gap-3 px-3 py-2 rounded-md bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                                <div class="flex items-center gap-2 text-sm">
                                    <span class="text-charcoal font-medium">Hoesje</span>
                                    <span class="text-gravel">× 2</span>
                                </div>
                                <span class="text-xs text-sunstone-deep font-semibold tabular-nums">12 op voorraad → 6 stuks</span>
                            </li>
                        </ul>

                        <div class="flex items-baseline justify-between gap-3 pt-3 border-t border-chalk-darker">
                            <span class="text-sm font-semibold text-charcoal">Bundelvoorraad</span>
                            <span class="text-xl font-semibold text-sunstone-deep tabular-nums">6 stuks</span>
                        </div>
                        <p class="text-[11px] text-gravel mt-2 leading-relaxed">
                            Hoesje is hier de beperkende factor. Elke bundel heeft er 2 nodig, dus 12 hoesjes maken 6 complete bundels.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Voorraadbronnen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Eén bron,
                        <span class="block text-sunstone-deep">meerdere varianten.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Verkoop je op gewicht, lengte of volume? Houd dan één basisvoorraad bij in kilo, meter of liter. ShopLinkr herberekent automatisch hoeveel er van elke variant beschikbaar is, zonder dat je per variant apart hoeft te tellen.
                    </p>
                    <p class="mt-4 text-base text-steel leading-relaxed">
                        Stel je hebt 100 kilo hondenbrokken in een grote bak liggen. Bij elke bestelling vul je de juiste hoeveelheid af uit die ene bron, of dat nu 500 gram of 5 kilo is. Het gewicht dat je afvult gaat direct van de bronvoorraad af en alle varianten worden meteen opnieuw berekend.
                    </p>
                    <p class="mt-4 text-base text-steel leading-relaxed">
                        Hetzelfde werkt voor stof per meter of parfum per milliliter.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel mb-3">
                        Voorbeeld: hondenbrokken
                    </p>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="grid grid-cols-4 gap-3 text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel border-b border-chalk-dark pb-3 mb-3">
                            <span>Situatie</span>
                            <span class="text-right">Bron</span>
                            <span class="text-right">500 gram</span>
                            <span class="text-right">1 kilo</span>
                        </div>

                        <ul class="space-y-2">
                            <li class="grid grid-cols-4 gap-3 items-baseline px-2 py-2 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="text-sm text-charcoal font-medium">Start</span>
                                <span class="text-sm text-charcoal font-semibold tabular-nums text-right">100 kilo</span>
                                <span class="text-sm text-charcoal tabular-nums text-right">200</span>
                                <span class="text-sm text-charcoal tabular-nums text-right">100</span>
                            </li>
                            <li class="grid grid-cols-4 gap-3 items-baseline px-2 py-2 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="text-sm text-charcoal font-medium">Na verkoop 1× 1 kilo</span>
                                <span class="text-sm text-charcoal font-semibold tabular-nums text-right">99 kilo</span>
                                <span class="text-sm text-charcoal tabular-nums text-right">198</span>
                                <span class="text-sm text-charcoal tabular-nums text-right">99</span>
                            </li>
                            <li class="grid grid-cols-4 gap-3 items-baseline px-2 py-2 rounded-md bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                                <span class="text-sm text-charcoal font-medium">Na verkoop 1× 500 gram</span>
                                <span class="text-sm text-sunstone-deep font-semibold tabular-nums text-right">98,5 kilo</span>
                                <span class="text-sm text-sunstone-deep font-semibold tabular-nums text-right">197</span>
                                <span class="text-sm text-sunstone-deep font-semibold tabular-nums text-right">98</span>
                            </li>
                        </ul>

                        <p class="text-[11px] text-gravel mt-3 leading-relaxed">
                            Bij elke verkoop gaat de juiste hoeveelheid van de bron af en alle varianten worden automatisch herberekend.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Onbeperkte voorraad</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Producten die
                        <span class="block text-sunstone-deep">altijd beschikbaar zijn.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Verkoop je digitale producten zoals softwarelicenties, downloads of toegangscodes? Dan hoef je geen voorraad bij te houden. Zet onbeperkte voorraad aan en het product blijft altijd leverbaar op je kanalen, zonder afboeking bij verkoop en zonder telling.
                    </p>
                    <p class="mt-4 text-base text-steel leading-relaxed">
                        Bestaat je bundel uit producten die allemaal op onbeperkte voorraad staan? Dan krijgt de bundel die status automatisch ook.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel mb-3">
                        Voorbeeld: softwarelicentie
                    </p>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-5 pb-4 border-b border-chalk-dark">
                            <div class="flex items-center gap-3">
                                <span class="inline-flex items-center justify-center h-9 w-9 rounded-md bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                    <i class="fa-solid fa-infinity text-sm" aria-hidden="true"></i>
                                </span>
                                <div>
                                    <p class="text-sm font-semibold text-charcoal leading-tight">Softwarelicentie</p>
                                    <p class="text-[11px] text-gravel mt-0.5">Onbeperkte voorraad aan</p>
                                </div>
                            </div>
                            <p class="text-2xl font-semibold text-sunstone-deep tabular-nums leading-none">∞</p>
                        </div>

                        <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel mb-3">
                            Wat je kanalen zien
                        </p>
                        <ul class="space-y-2">
                            <li class="flex items-center justify-between gap-3 px-3 py-2 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
