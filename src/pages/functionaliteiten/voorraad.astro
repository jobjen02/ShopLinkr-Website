---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';

const subFeatures = [
    {
        eyebrow: 'Voorraadprognose',
        heading: 'Zie op tijd dat je moet bijbestellen.',
        body: 'ShopLinkr kijkt naar je gemiddelde verkoop per dag en rekent uit hoeveel je nodig hebt. Levertijd van je leverancier telt automatisch mee in het advies.',
        icon: 'fa-duotone fa-solid fa-chart-line',
    },
    {
        eyebrow: 'Voorraadhistorie',
        heading: 'Elke mutatie terug te vinden per product.',
        body: 'Per product zie je elke verkoop, pick, retour, levering, correctie en telling. Compleet met oude en nieuwe voorraad, locatie, datum en wie de wijziging deed.',
        icon: 'fa-duotone fa-solid fa-magnifying-glass-chart',
    },
    {
        eyebrow: 'Fictieve voorraad',
        heading: 'Verberg je voorraad voor concurrenten.',
        body: 'Stel een vast aantal in (bijvoorbeeld 400) plus een drempel (bijvoorbeeld 20). Zit je boven de drempel, dan zien je kanalen het fictieve aantal. Eronder schakelt ShopLinkr over op je echte voorraad, zodat je nooit een product verkoopt dat je niet hebt.',
        icon: 'fa-duotone fa-solid fa-eye-slash',
    },
    {
        eyebrow: 'LVB switch',
        heading: 'Automatisch terug naar eigen magazijn.',
        body: 'Raakt je LVB-voorraad op? ShopLinkr zet de verzendlocatie automatisch om naar je eigen magazijn, inclusief jouw levertijd.',
        icon: 'fa-duotone fa-solid fa-shuffle',
    },
];

const stockTypes = [
    {
        title: 'Beschikbare voorraad',
        body: 'Wat je nog kunt verkopen. Dit aantal sturen we door naar je verkoopkanalen.',
    },
    {
        title: 'Gereserveerde voorraad',
        body: 'Voorraad die al vastligt voor bestellingen die nog verwerkt moeten worden.',
    },
    {
        title: 'Totale voorraad',
        body: 'Beschikbaar plus gereserveerd. Wat je tegenkomt als je naar het schap loopt.',
    },
];

const faqs = faqsByPage.voorraad;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Functionaliteiten', '/functionaliteiten'],
        ['Voorraad', '/functionaliteiten/voorraad'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Voorraad beheren met ShopLinkr',
        description: 'Beheer en synchroniseer je voorraad vanuit één plek. Met voorraadmutaties, notificaties, prognose en fictieve voorraad houd je grip op wat er ligt en wat er nog beschikbaar is.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = true;
---

<PageLayout
    title="Voorraad beheren met ShopLinkr"
    description="Beheer en synchroniseer je voorraad vanuit één plek. Met voorraadmutaties, notificaties, prognose en fictieve voorraad houd je grip op wat er ligt en wat er nog beschikbaar is."
    eyebrow="Voorraadbeheer"
    heading="Op één plek al je voorraad beheren."
    subheading="Realtime synchronisatie tussen ShopLinkr en je verkoopkanalen, zodat je altijd ziet wat er werkelijk ligt en wat er nog te verkopen is."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Realtime synchronisatie</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Eén voorraad,
                            <span class="block">overal in sync.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-5">
                            <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">Sync-tijdlijn</p>
                            <div class="flex items-center gap-2">
                                <span class="relative flex h-2 w-2">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sunstone-deep opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-2 w-2 bg-sunstone-deep"></span>
                                </span>
                                <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep">live</span>
                            </div>
                        </div>

                        <ol class="space-y-0">
                            <li class="grid grid-cols-[auto_1fr] gap-x-4">
                                <p class="text-[11px] font-mono tabular-nums text-gravel pt-1 text-right">14:32:18</p>
                                <div class="border-l-2 border-chalk-dark pl-5 pb-5 relative">
                                    <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full bg-chalk-darker ring-2 ring-paper"></span>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#0000A4] text-paper">Bol</span>
                                        <p class="text-sm font-semibold text-charcoal">Verkocht 1 stuk</p>
                                    </div>
                                    <p class="text-[11px] text-gravel">Bestelling binnengekomen</p>
                                </div>
                            </li>

                            <li class="grid grid-cols-[auto_1fr] gap-x-4">
                                <p class="text-[11px] font-mono tabular-nums text-gravel pt-1 text-right">14:32:24</p>
                                <div class="border-l-2 border-chalk-dark pl-5 pb-5 relative">
                                    <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full bg-chalk-darker ring-2 ring-paper"></span>
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-charcoal text-paper">ShopLinkr</span>
                                        <p class="text-sm font-semibold text-charcoal">Voorraad bijgewerkt</p>
                                    </div>
                                    <p class="text-[11px] text-gravel">Beschikbaar: 11 stuks</p>
                                </div>
                            </li>

                            <li class="grid grid-cols-[auto_1fr] gap-x-4">
                                <p class="text-[11px] font-mono tabular-nums text-sunstone-deep font-semibold pt-1 text-right">14:32:31</p>
                                <div class="pl-5 relative">
                                    <span class="absolute -left-[7px] top-1.5 h-3 w-3 rounded-full bg-sunstone-deep ring-2 ring-paper"></span>
                                    <div class="flex items-center gap-2 mb-1 flex-wrap">
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#5A8A1F] text-paper">Shop</span>
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#674399] text-paper">Woo</span>
                                        <span class="inline-flex items-center justify-center h-5 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#E10915] text-paper">Kaufland</span>
                                        <p class="text-sm font-semibold text-charcoal">in sync</p>
                                    </div>
                                    <p class="text-[11px] text-gravel">Alle kanalen op 11 stuks</p>
                                </div>
                            </li>
                        </ol>

                        <div class="mt-5 flex items-center justify-center gap-2 px-3 py-3 rounded-md bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                            <i class="fa-solid fa-bolt text-sunstone-deep text-xs" aria-hidden="true"></i>
                            <span class="text-[11px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep">Totaal</span>
                            <span class="text-base font-semibold text-sunstone-deep tabular-nums">13 seconden</span>
                        </div>
                    </div>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Fictieve voorraad</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Verberg je voorraad
                        <span class="block text-sunstone-deep">voor concurrenten.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Sommige tools laten concurrenten precies zien hoeveel voorraad je hebt liggen. Met fictieve voorraad stuurt ShopLinkr een vast getal naar je kanalen in plaats van je echte aantallen. Pas wanneer je voorraad onder een ingestelde drempel zakt, schakelt ShopLinkr automatisch over op de echte aantallen, zodat je nooit een product verkoopt dat je niet hebt.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel mb-3">
                        Voorbeeld met fictief 400 en drempel 20
                    </p>
                    <ul class="space-y-2.5">
                        <li class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 px-4 py-3 rounded-xl bg-chalk-light ring-1 ring-chalk-dark">
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">Werkelijk in magazijn</p>
                                <p class="text-xl font-semibold text-charcoal tabular-nums">850</p>
                            </div>
                            <i class="fa-solid fa-arrow-right text-gravel text-sm" aria-hidden="true"></i>
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">Op je kanalen</p>
                                <p class="text-xl font-semibold text-charcoal tabular-nums">400</p>
                            </div>
                        </li>
                        <li class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 px-4 py-3 rounded-xl bg-chalk-light ring-1 ring-chalk-dark">
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">Werkelijk in magazijn</p>
                                <p class="text-xl font-semibold text-charcoal tabular-nums">350</p>
                            </div>
                            <i class="fa-solid fa-arrow-right text-gravel text-sm" aria-hidden="true"></i>
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel mb-1">Op je kanalen</p>
                                <p class="text-xl font-semibold text-charcoal tabular-nums">400</p>
                            </div>
                        </li>
                        <li class="grid grid-cols-[1fr_auto_1fr] items-center gap-3 px-4 py-3 rounded-xl bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep mb-1">Werkelijk in magazijn</p>
                                <p class="text-xl font-semibold text-sunstone-deep tabular-nums">15</p>
                            </div>
                            <i class="fa-solid fa-arrow-right text-sunstone-deep text-sm" aria-hidden="true"></i>
                            <div>
                                <p class="text-[10px] uppercase tracking-[0.12em] font-semibold text-sunstone-deep mb-1">Op je kanalen</p>
                                <p class="text-xl font-semibold text-sunstone-deep tabular-nums">15</p>
                            </div>
                        </li>
                    </ul>
                    <p class="text-[11px] text-gravel mt-3 leading-relaxed">
                        Boven de drempel laat ShopLinkr het fictieve aantal zien. Onder de drempel schakelt het automatisch over op de echte aantallen.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Soorten voorraad</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Drie soorten voorraad,
                        <span class="block text-sunstone-deep">één duidelijk overzicht.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        In ShopLinkr werken we met drie soorten voorraad zodat je precies weet wat beschikbaar is, wat al gereserveerd is en wat er werkelijk op je schap ligt.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            stockTypes.map((type) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-boxes-stacked text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{type.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{type.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Veelgestelde vragen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vragen die vaak terugkomen,
                        <span class="block text-sunstone-deep">helder beantwoord.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Mis je een vraag? Plan een gesprek of stuur ons een bericht. We denken graag mee over jouw situatie.
                    </p>
                    <a href="/contact" class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Stel je vraag
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
