---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import { externalLinks } from '../../data/externalLinks';

const stories = [
    {
        eyebrow: 'Realtime synchronisatie',
        heading: 'Nooit meer misgrijpen op een product.',
        body: 'Een klant die zijn pakket morgen verwacht maar het ligt niet op je schap. Die situatie wil je voorkomen. ShopLinkr haalt elke minuut je bestellingen op uit al je kanalen en houdt zo een accuraat beeld van je voorraad. Die voorraad wordt direct teruggekoppeld naar je verkoopkanalen, zodat wat je verkoopt ook echt klaarligt.',
        icon: 'fa-duotone fa-solid fa-arrows-rotate',
    },
    {
        eyebrow: 'Voorraadprognose',
        heading: 'Weet op tijd wanneer je moet inkopen.',
        body: 'Wanneer raakt een populair product uitverkocht? ShopLinkr berekent het voor je op basis van je verkoopsnelheid van de afgelopen weken. Je ziet per product precies hoeveel dagen voorraad je nog hebt, zodat je je inkoop op tijd in gang zet en geen omzet misloopt.',
        icon: 'fa-duotone fa-solid fa-chart-line',
    },
    {
        eyebrow: 'Voorraadhistorie',
        heading: 'Zie precies waarom je voorraad zo laag is.',
        body: 'Soms duikt een product opeens op nul en weet je niet meer hoe dat kwam. In ShopLinkr zie je per artikel een complete tijdlijn van mutaties: verkopen, retouren, leveringen en handmatige correcties. Geen verrassingen meer, alles is herleidbaar.',
        icon: 'fa-duotone fa-solid fa-magnifying-glass-chart',
    },
    {
        eyebrow: 'Magazijnlocaties',
        heading: 'Een goede basis begint bij locaties.',
        body: 'Klein magazijn of groot magazijn, het begint allebei bij dezelfde basis: weten waar je producten liggen. In ShopLinkr bouw je een hiërarchie van gangen, stellingen, schappen en vakken en koppel je producten aan de juiste locatie. Op de bestellingenpagina en op de pick en pack lijst staat de locatie meteen in beeld, zodat ook nieuwe medewerkers direct meedoen.',
        icon: 'fa-duotone fa-solid fa-location-dot',
    },
    {
        eyebrow: 'Fictieve voorraad',
        heading: 'Houd je concurrenten in het ongewisse.',
        body: 'Concurrenten die meekijken hoeveel je verkoopt, of spiders die continu je voorraadstand scannen. Met fictieve voorraad geef je een afgesproken aantal door, bijvoorbeeld 300 stuks, zolang je eigen voorraad boven een drempel blijft. Daalt je echte voorraad onder die drempel? Dan schakelt ShopLinkr automatisch over op je werkelijke aantallen, zodat je nooit meer verkoopt dan je hebt.',
        icon: 'fa-duotone fa-solid fa-eye-slash',
    },
    {
        eyebrow: 'LVB switch',
        heading: 'Automatisch overschakelen naar je eigen magazijn.',
        body: 'Je LVB-voorraad raakt op en je product staat op het kanaal direct op uitverkocht, terwijl het bij jou nog gewoon op het schap ligt. Frustrerend, en zonder ShopLinkr lastig te ondervangen. Met de slimme LVB switch zet ShopLinkr de verzendlocatie automatisch over naar je eigen magazijn zodra de LVB-voorraad nul nadert, inclusief jouw levertijd. Je product blijft beschikbaar, jij houdt de omzet.',
        icon: 'fa-duotone fa-solid fa-shuffle',
    },
];

const stockTypes = [
    {
        title: 'Beschikbare voorraad',
        body: 'Dit is de voorraad die beschikbaar is voor verkoop.',
    },
    {
        title: 'Gereserveerde voorraad',
        body: 'Dit is de voorraad die gereserveerd is voor openstaande bestellingen.',
    },
    {
        title: 'Totale voorraad',
        body: 'Dit is de som van de beschikbare en gereserveerde voorraad. Loop je in je magazijn naar dit product, dan zie je deze voorraad liggen.',
    },
];

const jsonLd = {
    '@type': 'WebPage',
    name: 'Voorraad beheren met ShopLinkr',
    description: 'Verbeter je voorraadbeheer met ShopLinkr. Beheer en synchroniseer je voorraad vanuit één plek. Ontdek handige functies zoals productbundels, voorraadmeldingen, voorraadprognoses en fictieve voorraad.',
};

export const prerender = true;
---

<PageLayout
    title="Voorraad beheren met ShopLinkr"
    description="Verbeter je voorraadbeheer met ShopLinkr. Beheer en synchroniseer je voorraad vanuit één plek. Ontdek handige functies zoals productbundels, voorraadmeldingen, voorraadprognoses en fictieve voorraad."
    eyebrow="Voorraadbeheer"
    heading="Op één plek al je voorraad beheren."
    subheading="Realtime synchronisatie tussen ShopLinkr en je verkoopkanalen. Geen oversells, geen handmatige correcties, altijd een accuraat beeld van wat er ligt."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="bg-paper">
        <div class="container-prose">
            {
                stories.map((story, index) => {
                    const isReversed = index % 2 === 1;

                    return (
                        <article class="py-20 md:py-28 border-b border-chalk-dark last:border-b-0">
                            <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center">
                                <div class={`lg:col-span-7 ${isReversed ? 'lg:order-2' : 'lg:order-1'}`}>
                                    <div
                                        class="relative w-full rounded-3xl overflow-hidden bg-gradient-to-br from-sunstone-mist via-paper to-chalk-light ring-1 ring-chalk-dark"
                                        style="aspect-ratio: 4 / 3;"
                                    >
                                        <div class="absolute inset-0 opacity-40 pointer-events-none" style="background: radial-gradient(circle at 30% 30%, var(--color-sunstone-soft) 0%, transparent 55%);"></div>
                                        <div class="absolute inset-0 flex items-center justify-center p-10">
                                            <div class="flex items-center justify-center h-28 w-28 md:h-32 md:w-32 rounded-3xl bg-paper text-sunstone-deep ring-1 ring-chalk-dark shadow-[0_18px_40px_-18px_rgba(25,25,25,0.18)]">
                                                <i class={`${story.icon} text-5xl md:text-6xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class={`lg:col-span-5 ${isReversed ? 'lg:order-1' : 'lg:order-2'}`}>
                                    <p class="eyebrow mb-5">{story.eyebrow}</p>
                                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.15] mb-6">
                                        {story.heading}
                                    </h2>
                                    <p class="text-lg text-steel leading-relaxed">
                                        {story.body}
                                    </p>
                                </div>
                            </div>
                        </article>
                    );
                })
            }
        </div>
    </section>

    <section class="py-24 md:py-32 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Soorten voorraad</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Drie soorten voorraad,
                        <span class="block text-sunstone-deep">één duidelijk overzicht.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        In ShopLinkr werken we met drie soorten voorraad zodat je precies weet wat beschikbaar is, wat al gereserveerd is en wat er werkelijk op je schap ligt.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ul class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            stockTypes.map((type) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5">
                                        <i class="fa-solid fa-boxes-stacked text-xs" aria-hidden="true"></i>
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{type.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{type.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
