---
import PageLayout from '../../layouts/PageLayout.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';
import FaqList from '../../components/template/FaqList.astro';
import { externalLinks } from '../../data/externalLinks';
import { breadcrumbs } from '../../utils/seo';
import { faqsByPage } from '../../data/faqs';

const subFeatures = [
    {
        eyebrow: 'Bulk verwerken',
        heading: 'Grote volumes in één beweging.',
        body: 'Selecteer een groep bestellingen, verwerk ze als batch en download de verzendlabels en picklijst in één keer.',
        icon: 'fa-duotone fa-solid fa-layer-group',
    },
    {
        eyebrow: 'Bestellingen samenvoegen',
        heading: 'Eén pakket voor dezelfde klant.',
        body: 'Heeft een klant meerdere orders geplaatst, eventueel op verschillende kanalen? Voeg ze samen tot één zending. De track en trace gaat terug naar elk origineel kanaal.',
        icon: 'fa-duotone fa-solid fa-code-merge',
    },
    {
        eyebrow: 'Backorders',
        heading: 'Vrijgegeven zodra de voorraad er is.',
        body: 'Niet genoeg voorraad? De bestelling krijgt de status Backorder. Zodra je een levering ontvangt, springt de order automatisch terug naar Open. Daar heb je geen omkijken naar.',
        icon: 'fa-duotone fa-solid fa-clock-rotate-left',
    },
    {
        eyebrow: 'Handmatige zendingen',
        heading: 'Ook orders buiten je kanaal om.',
        body: 'Telefonische bestellingen of B2B-zendingen. Vul de klantgegevens en het afleveradres in, kies een vervoerder en ShopLinkr genereert het verzendlabel.',
        icon: 'fa-duotone fa-solid fa-pen-to-square',
    },
];

const workflowSteps = [
    {
        title: 'Bestelling komt binnen',
        body: 'Een order vanuit een van je verkoopkanalen verschijnt direct in je centrale overzicht, met de productdetails en voorraadlocaties al klaargezet.',
    },
    {
        title: 'Picken en inpakken',
        body: 'Pak losse orders, stel een batch samen of werk met picklijsten en inpakstations. De picklijst toont precies waar elk product in je magazijn ligt.',
    },
    {
        title: 'Label en verzenden',
        body: 'Kies je vervoerder en print het label. De status loopt automatisch terug naar het kanaal waar de bestelling vandaan kwam.',
    },
];

const faqs = faqsByPage.bestellingen;

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Functionaliteiten', '/functionaliteiten'],
        ['Bestellingen', '/functionaliteiten/bestellingen'],
    ]),
    {
        '@type': 'WebPage',
        name: 'Bestellingen verwerken met ShopLinkr',
        description: 'Verwerk bestellingen uit al je verkoopkanalen op één plek. Maak verzendlabels bij je favoriete vervoerder, werk in batches of pak losse orders tussendoor.',
    },
    {
        '@type': 'FAQPage',
        mainEntity: faqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Bestellingen verwerken met ShopLinkr"
    description="Verwerk bestellingen uit al je verkoopkanalen op één plek. Maak verzendlabels bij je favoriete vervoerder, werk in batches of pak losse orders tussendoor."
    eyebrow="Bestellingen"
    heading="Alles verwerken op één plek."
    subheading="Bestellingen vanuit al je verkoopkanalen komen samen in één overzicht. Verwerk losse orders of grote batches, print labels van elke vervoerder en de status wordt automatisch teruggekoppeld."
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose">
            <div class="flex flex-col sm:flex-row gap-3">
                <a
                    href={externalLinks.register}
                    class="btn btn-sunstone text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Gratis starten
                    <i class="fa-solid fa-arrow-right text-sm" aria-hidden="true"></i>
                </a>
                <a
                    href={externalLinks.demoBooking}
                    class="btn btn-secondary text-base"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    Demo inplannen
                </a>
            </div>
        </div>
    </section>

    <section class="py-12 md:py-16 bg-paper">
        <div class="container-wide">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-3 md:gap-4">
                <article class="md:col-span-2 md:row-span-2 bg-gradient-to-br from-sunstone-mist/70 via-sunstone-mist/25 to-paper rounded-2xl ring-1 ring-chalk-dark p-8 md:p-10 flex flex-col gap-7 transition duration-300 ease-out hover:ring-chalk-darker">
                    <div>
                        <p class="eyebrow mb-3">Eén centraal overzicht</p>
                        <h2 class="text-3xl md:text-[2.25rem] font-semibold text-charcoal tracking-tight leading-[1.05]">
                            Al jouw verkoopkanalen
                            <span class="block">op één werkplek.</span>
                        </h2>
                    </div>

                    <div class="bg-paper rounded-xl ring-1 ring-chalk-dark p-5 md:p-6 shadow-[0_12px_40px_-24px_rgba(25,25,25,0.18)]">
                        <div class="flex items-center justify-between gap-3 mb-4">
                            <p class="text-[11px] uppercase tracking-[0.12em] font-semibold text-gravel">Open bestellingen</p>
                            <span class="text-[10px] uppercase tracking-[0.12em] font-semibold text-gravel tabular-nums">4 orders</span>
                        </div>

                        <ul class="space-y-2">
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#0000A4] text-paper">Bol</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">Bluetooth oortjes</p>
                                    <p class="text-[11px] text-gravel tabular-nums">#12384</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-gravel">Open</span>
                            </li>
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-sunstone-mist/60 ring-1 ring-sunstone-soft/60">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#95BF47] text-paper">Shopify</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">Set wieldoppen</p>
                                    <p class="text-[11px] text-sunstone-deep font-semibold tabular-nums">#12385 + #12388 samengevoegd</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-sunstone-deep">Picken</span>
                            </li>
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#7F54B3] text-paper">WooComm</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">Houten tafellamp</p>
                                    <p class="text-[11px] text-gravel tabular-nums">#12386</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-gravel">Verwerken</span>
                            </li>
                            <li class="flex items-center gap-3 px-3 py-2.5 rounded-md bg-chalk-light ring-1 ring-chalk-dark">
                                <span class="inline-flex items-center justify-center h-6 px-2 rounded text-[10px] font-semibold tracking-tight bg-[#E10915] text-paper">Kaufland</span>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm text-charcoal font-medium truncate">Notitieboek A5</p>
                                    <p class="text-[11px] text-gravel tabular-nums">#12387</p>
                                </div>
                                <span class="text-[10px] uppercase tracking-[0.08em] font-semibold text-charcoal">Afgehandeld</span>
                            </li>
                        </ul>

                        <div class="flex items-center justify-between gap-3 pt-4 mt-4 border-t border-chalk-darker">
                            <span class="text-sm font-semibold text-charcoal">Selecteer en verwerk</span>
                            <span class="inline-flex items-center gap-1.5 text-xs text-sunstone-deep font-semibold">
                                <i class="fa-solid fa-layer-group text-[0.65rem]" aria-hidden="true"></i>
                                In één batch
                            </span>
                        </div>
                    </div>

                    <p class="text-steel leading-relaxed text-sm md:text-[0.95rem]">
                        Geen losse exports, geen geschakel tussen tabbladen. Filter op kanaal, status of vervoerder en verwerk alles vanuit hetzelfde scherm.
                    </p>
                </article>

                {
                    subFeatures.map((feature) => (
                        <article class="bg-paper rounded-2xl ring-1 ring-chalk-dark p-6 md:p-7 flex flex-col gap-4 transition duration-300 ease-out hover:ring-chalk-darker">
                            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40">
                                <i class={`${feature.icon} text-xl`} style="--fa-secondary-opacity: 0.32;" aria-hidden="true"></i>
                            </div>
                            <div>
                                <p class="text-[11px] uppercase tracking-[0.08em] font-semibold text-gravel mb-1.5">{feature.eyebrow}</p>
                                <h3 class="text-base md:text-lg font-semibold text-charcoal tracking-tight leading-snug">{feature.heading}</h3>
                                <p class="text-sm text-steel leading-relaxed mt-2">{feature.body}</p>
                            </div>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-20 md:py-28 bg-chalk-light">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                <div class="lg:col-span-5">
                    <p class="eyebrow mb-4">Zo loopt een bestelling</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Drie stappen,
                        <span class="block text-sunstone-deep">geen losse eindjes.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Elke bestelling volgt in ShopLinkr dezelfde heldere route. Voorspelbaar voor jou, snel voor je klant.
                    </p>
                </div>

                <div class="lg:col-span-7">
                    <ol class="divide-y divide-chalk-dark border-y border-chalk-dark">
                        {
                            workflowSteps.map((step, index) => (
                                <li class="py-7 flex items-start gap-5">
                                    <span class="flex-shrink-0 inline-flex items-center justify-center h-8 w-8 rounded-full bg-sunstone-mist text-sunstone-deep ring-1 ring-sunstone-soft/40 mt-0.5 text-sm font-semibold">
                                        {index + 1}
                                    </span>
                                    <div>
                                        <h3 class="text-lg font-semibold text-charcoal tracking-tight leading-snug">{step.title}</h3>
                                        <p class="mt-2 text-steel leading-relaxed text-[0.975rem]">{step.body}</p>
                                    </div>
                                </li>
                            ))
                        }
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 md:py-32 bg-paper">
        <div class="container-prose">
            <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
                <div class="lg:col-span-4">
                    <p class="eyebrow mb-4">Veelgestelde vragen</p>
                    <h2 class="text-3xl md:text-4xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                        Vragen die vaak terugkomen,
                        <span class="block text-sunstone-deep">helder beantwoord.</span>
                    </h2>
                    <p class="mt-6 text-base text-steel leading-relaxed">
                        Mis je een vraag? Plan een gesprek of stuur ons een bericht. We denken graag mee over jouw situatie.
                    </p>
                    <a href="/contact" class="group mt-8 inline-flex items-center gap-2 text-charcoal font-semibold text-sm">
                        Stel je vraag
                        <i class="fa-solid fa-arrow-right text-xs transition-transform duration-200 group-hover:translate-x-1" aria-hidden="true"></i>
                    </a>
                </div>

                <div class="lg:col-span-8">
                    <FaqList items={faqs} />
                </div>
            </div>
        </div>
    </section>

    <CtaBanner />
</PageLayout>
