---
import PageLayout from '../layouts/PageLayout.astro';
import FaqList from '../components/template/FaqList.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { faqsByPage, faqCategories } from '../data/faqs';
import { breadcrumbs } from '../utils/seo';

const allFaqs = faqCategories.flatMap((cat) =>
    cat.pages.flatMap((page) => faqsByPage[page] ?? []),
);

const jsonLd = [
    breadcrumbs([
        ['Home', '/'],
        ['Veelgestelde vragen', '/veelgestelde-vragen'],
    ]),
    {
        '@type': 'FAQPage',
        mainEntity: allFaqs.map((faq) => ({
            '@type': 'Question',
            name: faq.question,
            acceptedAnswer: {
                '@type': 'Answer',
                text: faq.answer,
            },
        })),
    },
];

export const prerender = false;
---

<PageLayout
    title="Veelgestelde vragen over ShopLinkr"
    description="Antwoord op de meestgestelde vragen over ShopLinkr: voorraadbeheer, orderverwerking, verzending, integraties, prijzen en meer."
    eyebrow="Veelgestelde vragen"
    heading="Alles over ShopLinkr op een rij."
    subheading="De vragen die we het vaakst krijgen, gebundeld en helder beantwoord. Mis je iets? Neem gerust contact op, we denken graag mee."
    routeKey="faq"
    jsonLd={jsonLd}
>
    <section class="pb-12 md:pb-16 bg-paper">
        <div class="container-prose space-y-14 md:space-y-20">
            {
                faqCategories.map((cat) => {
                    const items = cat.pages.flatMap(
                        (page) => faqsByPage[page] ?? [],
                    );
                    return (
                        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
                            <div class="lg:col-span-4 lg:sticky lg:top-28">
                                <h2 class="text-2xl md:text-3xl font-semibold text-charcoal tracking-tight leading-[1.1]">
                                    {cat.title}
                                </h2>
                                <p class="mt-4 text-base text-steel leading-relaxed">
                                    {cat.intro}
                                </p>
                            </div>
                            <div class="lg:col-span-8">
                                <FaqList items={items} />
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </section>

    <CtaBanner />
</PageLayout>
