---
import { getCollection } from 'astro:content';
import SeoArticlePage from '../components/pages/SeoArticlePage.astro';
import { routes } from '../i18n/routes';

export async function getStaticPaths() {
    const pages = await getCollection('seoPages');
    const pagesEn = await getCollection('seoPagesEn');
    const enByNlId = new Map(
        pagesEn.filter((p) => p.data.translationKey).map((p) => [p.data.translationKey, p.id]),
    );

    // Build guard: a root-served SEO slug must never collide with a reserved
    // root route (a localized page slug or a real page/dir under src/pages).
    // The build fails loudly if it does, so the shared root namespace stays safe.
    const reserved = new Set<string>();
    for (const r of Object.values(routes)) {
        if (r.nl && !r.nl.includes('/')) reserved.add(r.nl);
    }
    for (const file of Object.keys(import.meta.glob('./*.astro'))) {
        const seg = file.replace('./', '').replace('.astro', '');
        if (seg !== '[slug]' && seg !== 'index') reserved.add(seg);
    }
    ['blogs', 'functionaliteiten', 'integraties', 'support', 'en', 'api'].forEach((s) => reserved.add(s));

    for (const page of pages) {
        if (reserved.has(page.id)) {
            throw new Error(
                `SEO page slug "${page.id}" collides with a reserved root route. Rename src/content/seo/${page.id}.md (and its redirect/links) or the conflicting route.`,
            );
        }
    }

    return pages.map((page) => ({
        params: { slug: page.id },
        props: { page, enSlug: enByNlId.get(page.id) ?? null },
    }));
}

const { page, enSlug } = Astro.props;

const alternates = enSlug
    ? { nl: `/${page.id}`, en: `/en/${enSlug}` }
    : undefined;

const canonicalUrl = `https://shoplinkr.com/${page.id}`;

const articleSchema = {
    '@type': 'Article',
    headline: page.data.title,
    description: page.data.excerpt,
    datePublished: page.data.publishedAt.toISOString(),
    dateModified: page.data.publishedAt.toISOString(),
    inLanguage: 'nl-NL',
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
    author: { '@type': 'Organization', name: page.data.author || 'ShopLinkr', url: 'https://shoplinkr.com' },
    publisher: {
        '@type': 'Organization',
        name: 'ShopLinkr',
        logo: { '@type': 'ImageObject', url: 'https://shoplinkr.com/logo/logo-charcoal.svg' },
    },
    ...(page.data.image && { image: `https://shoplinkr.com${page.data.image}` }),
    ...(page.data.category && { articleSection: page.data.category }),
};

const breadcrumbSchema = {
    '@type': 'BreadcrumbList',
    itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://shoplinkr.com' },
        { '@type': 'ListItem', position: 2, name: page.data.title, item: canonicalUrl },
    ],
};

const jsonLd = [articleSchema, breadcrumbSchema];

export const prerender = true;
---

<SeoArticlePage page={page} alternates={alternates} jsonLd={jsonLd} />
